fi

# Test: branch named 'add' does NOT trigger the guard for other subcommands
run_test
result=$(run_wrapper_agent "worktree remove add" || true)
if [[ $result != *'"code":"git_worktree_add_blocked"'* ]]
then
  pass "'git worktree remove add' is not blocked (add is a path, not subcommand)"
else
  fail "'git worktree remove add' should not be blocked: got '${result}'"
fi

echo ""
echo "Results: $((tests - failures))/${tests} passed"

if (( 0 < failures ))
then
  exit 1
fi
