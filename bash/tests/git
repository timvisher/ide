#!/usr/bin/env bash

# Tests for git wrapper

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

script="$(cd "$(dirname "$0")/.." && pwd)/bin/git"
funcs_dir="$(cd "$(dirname "$0")/../functions" && pwd)"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# Create a mock brew prefix with git inside it
mkdir -p "$tmpdir/prefix/bin"
cat > "$tmpdir/prefix/bin/git" <<'MOCK'
#!/usr/bin/env bash
echo "real-git $*"
MOCK
chmod +x "$tmpdir/prefix/bin/git"

mkdir -p "$tmpdir/mockbin"
cat > "$tmpdir/mockbin/brew" <<MOCK
#!/usr/bin/env bash
echo "$tmpdir/prefix"
MOCK
chmod +x "$tmpdir/mockbin/brew"

run_wrapper() {
  PATH="$tmpdir/mockbin:$PATH" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

run_wrapper_agent() {
  TIMVISHER_AGENT=true \
  PATH="$tmpdir/mockbin:$PATH" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

# Test 1: blocks 'git push' when agent
run_test
result=$(TIMVISHER_AGENT=true CLAUDECODE=1 PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' push origin main" 2>&1 || true)
if [[ $result == *'"code":"git_push_blocked"'* ]]
then
  pass "blocks 'git push' when agent"
else
  fail "blocks 'git push': got '${result}'"
fi

# Test 2: blocks 'git send-pack' when agent
run_test
result=$(TIMVISHER_AGENT=true CLAUDECODE=1 PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' send-pack" 2>&1 || true)
if [[ $result == *'"code":"git_push_blocked"'* ]]
then
  pass "blocks 'git send-pack' when agent"
else
  fail "blocks 'git send-pack': got '${result}'"
fi

# Test 3: allows 'git push' when not agent
run_test
result=$(PATH="$tmpdir/mockbin:$PATH" bash -c "unset TIMVISHER_AGENT; source '${funcs_dir}/logging.bash'; '$script' push origin main" 2>&1)
if [[ $result == *"real-git push origin main"* ]]
then
  pass "allows 'git push' when not agent"
else
  fail "allows 'git push': got '${result}'"
fi

# Test 4: requires Co-authored-by trailer for Claude agent commits
run_test
result=$(TIMVISHER_AGENT=true CLAUDECODE=1 PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' commit -m 'no trailer'" 2>&1 || true)
if [[ $result == *'"code":"git_commit_missing_trailer"'* ]]
then
  pass "requires Co-authored-by trailer for Claude commits"
else
  fail "requires trailer: got '${result}'"
fi

# Test 5: accepts commit with proper Co-authored-by trailer
run_test
msg=$'Fix a bug\n\nCo-authored-by: Claude <noreply@anthropic.com>'
result=$(TIMVISHER_AGENT=true CLAUDECODE=1 PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' commit -m '$msg'" 2>&1)
if [[ $result == *"real-git commit"* ]]
then
  pass "accepts commit with proper trailer"
else
  fail "accepts commit with trailer: got '${result}'"
fi

# Test 6: passes through normal commands for agents
run_test
result=$(TIMVISHER_AGENT=true PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' status" 2>&1)
if [[ $result == *"real-git status"* ]]
then
  pass "passes through 'git status' for agents"
else
  fail "passes through status: got '${result}'"
fi

# Test 7: passes through all args when not agent
run_test
result=$(PATH="$tmpdir/mockbin:$PATH" bash -c "unset TIMVISHER_AGENT; source '${funcs_dir}/logging.bash'; '$script' log --oneline -5" 2>&1)
if [[ $result == *"real-git log --oneline -5"* ]]
then
  pass "passes through all args when not agent"
else
  fail "passes through all args: got '${result}'"
fi

# ---------------------------------------------------------------------------
# Range expression guard tests (agent must use @{u} not hardcoded branches)
# ---------------------------------------------------------------------------

# Test: blocks 'git log master..HEAD' for agents (warning)
run_test
result=$(run_wrapper_agent "log --oneline master..HEAD" || true)
if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git log master..HEAD' for agents"
else
  fail "blocks 'git log master..HEAD': got '${result}'"
fi

# Test: blocks 'git diff origin/main..HEAD' for agents
