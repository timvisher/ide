if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git log HEAD..master' for agents"
else
  fail "blocks 'git log HEAD..master': got '${result}'"
fi

# Test: blocks arbitrary branch names in range expressions
