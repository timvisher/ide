if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git log feature/my-branch..HEAD' for agents"
else
  fail "blocks 'git log feature/my-branch..HEAD': got '${result}'"
fi

# Test: blocks origin/arbitrary-branch in range expressions
run_test
