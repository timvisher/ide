if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git diff origin/develop...HEAD' for agents"
else
  fail "blocks 'git diff origin/develop...HEAD': got '${result}'"
fi

# Test: blocks SHA..HEAD for agents (must use @{u})
run_test
result=$(run_wrapper_agent "log abc123..HEAD" || true)
if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git log abc123..HEAD' for agents"
else
  fail "blocks SHA..HEAD: got '${result}'"
fi

# Test: blocks HEAD..HEAD for agents (no @{u} present)
run_test
result=$(run_wrapper_agent "diff HEAD..HEAD" || true)
if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git diff HEAD..HEAD' for agents (no @{u})"
else
  fail "blocks HEAD..HEAD: got '${result}'"
fi

# Test: blocks empty range '...' for agents (no @{u} present)
run_test
result=$(run_wrapper_agent "log ..." || true)
if [[ $result == *'"code":"git_range_no_upstream_ref"'* ]]
then
  pass "blocks 'git log ...' for agents (no @{u})"
else
  fail "blocks empty range: got '${result}'"
fi

# Test: NIRMI bypasses range guard
run_test
run_wrapper_agent_nirmi() {
  TIMVISHER_AGENT=true TIMVISHER_AGENT_NIRMI=1 \
  PATH="$tmpdir/mockbin:$PATH" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}
result=$(run_wrapper_agent_nirmi "log abc123..HEAD" || true)
if [[ $result == *'"level":"bypass"'* ]] && [[ $result == *"git_range_no_upstream_ref"* ]] && [[ $result != *'"level":"warning"'* ]]
then
  pass "NIRMI bypasses range guard"
else
  fail "NIRMI bypass: got '${result}'"
fi

# Test: NIRMI does NOT bypass push guard
run_test
result=$(TIMVISHER_AGENT=true TIMVISHER_AGENT_NIRMI=1 PATH="$tmpdir/mockbin:$PATH" bash -c "source '${funcs_dir}/logging.bash'; '$script' push origin main" 2>&1 || true)
if [[ $result == *'"code":"git_push_blocked"'* ]]
then
  pass "NIRMI does NOT bypass push guard"
else
  fail "NIRMI should not bypass push: got '${result}'"
fi

# Test: allows @{u}..HEAD for agents (not blocked, real git runs)
run_test
result=$(run_wrapper_agent "log '@{u}..HEAD'" || true)
if [[ $result != *'"level":"error"'* ]] && [[ $result != *'"level":"warning"'* ]] && [[ $result == *"real-git log"* ]]
then
  pass "allows 'git log @{u}..HEAD' for agents"
else
  fail "allows 'git log @{u}..HEAD': got '${result}'"
fi

# Test: allows @{upstream}...HEAD for agents (not blocked, real git runs)
run_test
result=$(run_wrapper_agent "diff '@{upstream}...HEAD'" || true)
if [[ $result != *'"level":"error"'* ]] && [[ $result != *'"level":"warning"'* ]] && [[ $result == *"real-git diff"* ]]
then
  pass "allows 'git diff @{upstream}...HEAD' for agents"
else
  fail "allows @{upstream}...HEAD: got '${result}'"
fi

# Test: allows 'git log master..HEAD' for non-agents
run_test
result=$(PATH="$tmpdir/mockbin:$PATH" bash -c "unset TIMVISHER_AGENT; source '${funcs_dir}/logging.bash'; '$script' log master..HEAD" 2>&1)
if [[ $result != *'"level":"error"'* ]] && [[ $result != *'"level":"warning"'* ]]
then
  pass "allows 'git log master..HEAD' for non-agents"
else
  fail "allows 'git log master..HEAD' for non-agents: got '${result}'"
fi

# ---------------------------------------------------------------------------
# Upstream guard integration tests (using real git repos)
# ---------------------------------------------------------------------------

real_git=/opt/homebrew/bin/git

# For upstream guard tests, the wrapper needs the real git binary (not the
# echo mock) because it calls rev-parse/config internally.
mkdir -p "$tmpdir/real-prefix/bin"
ln -sf "$real_git" "$tmpdir/real-prefix/bin/git"
cat > "$tmpdir/mockbin/brew-real" <<MOCK
#!/usr/bin/env bash
echo "$tmpdir/real-prefix"
MOCK
chmod +x "$tmpdir/mockbin/brew-real"

run_wrapper_real_git() {
  TIMVISHER_AGENT= CLAUDECODE= TIMVISHER_CODEX= \
  PATH="$tmpdir/mockbin:$PATH" \
  bash -c "cp '$tmpdir/mockbin/brew-real' '$tmpdir/mockbin/brew'; source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

run_wrapper_real_git_agent() {
  TIMVISHER_AGENT=true \
  PATH="$tmpdir/mockbin:$PATH" \
  bash -c "cp '$tmpdir/mockbin/brew-real' '$tmpdir/mockbin/brew'; source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

# Helper: create a minimal repo with a branch tracking a remote
setup_tracking_repo() {
  local repo_dir=$1 branch_name=$2

  "$real_git" -C "$tmpdir" init --bare "remote-${branch_name}.git" >/dev/null 2>&1
  "$real_git" -C "$tmpdir" clone "remote-${branch_name}.git" "$repo_dir" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" commit --allow-empty -m "init" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" push origin HEAD >/dev/null 2>&1
  if [[ $branch_name != main ]]
  then
    "$real_git" -C "${tmpdir}/${repo_dir}" checkout -b "$branch_name" >/dev/null 2>&1
    "$real_git" -C "${tmpdir}/${repo_dir}" push -u origin "$branch_name" >/dev/null 2>&1
  fi
}

# Test 8: upstream guard fires when tracking is dropped (pre-check)
run_test
setup_tracking_repo "guard-pre-test" "feature"
# Create cookie to indicate tracking was previously observed
touch "${tmpdir}/guard-pre-test/x.upstream-configured"
# Strip tracking to simulate the broken state
"$real_git" -C "${tmpdir}/guard-pre-test" config --unset branch.feature.remote
"$real_git" -C "${tmpdir}/guard-pre-test" config --unset branch.feature.merge

result=$(cd "${tmpdir}/guard-pre-test" && run_wrapper_real_git status 2>&1 || true)
if [[ $result == *"UPSTREAM TRACKING DROPPED"* ]]
then
  pass "upstream guard fires when tracking is dropped"
else
  fail "upstream guard should fire when tracking dropped: got '${result}'"
fi

# Test 9: upstream guard uses -C target, not CWD
run_test
setup_tracking_repo "guard-C-target" "mybranch"
# Create a second repo with detached HEAD (like a cache)
"$real_git" -C "$tmpdir" init "detached-cache" >/dev/null 2>&1
"$real_git" -C "${tmpdir}/detached-cache" commit --allow-empty -m "init" >/dev/null 2>&1
"$real_git" -C "${tmpdir}/detached-cache" checkout --detach HEAD >/dev/null 2>&1

# Make guard-C-target have broken tracking (cookie + no remote)
touch "${tmpdir}/guard-C-target/x.upstream-configured"
"$real_git" -C "${tmpdir}/guard-C-target" config --unset branch.mybranch.remote
"$real_git" -C "${tmpdir}/guard-C-target" config --unset branch.mybranch.merge

# Run git -C <detached-cache> status FROM the broken worktree dir.
# With the fix, the guard should check the detached cache (and skip),
# NOT the CWD (which is broken).
result=$(cd "${tmpdir}/guard-C-target" && run_wrapper_real_git "-C '${tmpdir}/detached-cache' status" 2>&1 || true)
if [[ $result != *"UPSTREAM TRACKING DROPPED"* ]]
then
  pass "upstream guard uses -C target, not CWD"
else
  fail "upstream guard should not fire for -C target with detached HEAD: got '${result}'"
fi

# ---------------------------------------------------------------------------
# @{u} resolve guard tests (agent must have upstream configured)
# ---------------------------------------------------------------------------

# Test: blocks 'git log @{u}..HEAD' when upstream is not configured
run_test
# Create a repo with no upstream
"$real_git" -C "$tmpdir" init "no-upstream" >/dev/null 2>&1
"$real_git" -C "${tmpdir}/no-upstream" commit --allow-empty -m "init" >/dev/null 2>&1

result=$(cd "${tmpdir}/no-upstream" && run_wrapper_real_git_agent "log '@{u}..HEAD'" || true)
if [[ $result == *'"code":"git_upstream_not_configured"'* ]]
then
  pass "blocks 'git log @{u}..HEAD' when no upstream"
else
  fail "blocks @{u} without upstream: got '${result}'"
fi

# Test: allows 'git log @{u}..HEAD' when upstream is configured
run_test
setup_tracking_repo "has-upstream" "feature2"

result=$(cd "${tmpdir}/has-upstream" && run_wrapper_real_git_agent "log '@{u}..HEAD'" || true)
if [[ $result != *'"level":"error"'* ]] && [[ $result != *'"level":"warning"'* ]]
then
