# ---------------------------------------------------------------------------
# Upstream guard integration tests (using real git repos)
# ---------------------------------------------------------------------------

real_git=/opt/homebrew/bin/git

# For upstream guard tests, the wrapper needs the real git binary (not the
# echo mock) because it calls rev-parse/config internally. Build a parallel
# PATH that points at real git instead of the echo mock.
mkdir -p "$tmpdir/real-prefix/bin"
ln -sf "$real_git" "$tmpdir/real-prefix/bin/git"

test_path_real_git="$tmpdir/selflink:$tmpdir/real-prefix/bin:$tmpdir/mockbin:/opt/homebrew/bin:/usr/bin:/bin"

run_wrapper_real_git() {
  TIMVISHER_AGENT= CLAUDECODE= TIMVISHER_CODEX= \
  PATH="$test_path_real_git" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

run_wrapper_real_git_agent() {
  TIMVISHER_AGENT=true \
  PATH="$test_path_real_git" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

# Helper: create a minimal repo with a branch tracking a remote
setup_tracking_repo() {
  local repo_dir=$1 branch_name=$2

  "$real_git" -C "$tmpdir" init --bare "remote-${branch_name}.git" >/dev/null 2>&1
  "$real_git" -C "$tmpdir" clone "remote-${branch_name}.git" "$repo_dir" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" commit --allow-empty -m "init" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" push origin HEAD >/dev/null 2>&1
  if [[ $branch_name != main ]]
  then
    "$real_git" -C "${tmpdir}/${repo_dir}" checkout -b "$branch_name" >/dev/null 2>&1
    "$real_git" -C "${tmpdir}/${repo_dir}" push -u origin "$branch_name" >/dev/null 2>&1
  fi
}

# Test 8: upstream guard fires when tracking is dropped (pre-check)
run_test
setup_tracking_repo "guard-pre-test" "feature"
# Create cookie to indicate tracking was previously observed
touch "${tmpdir}/guard-pre-test/x.upstream-configured"
# Strip tracking to simulate the broken state
"$real_git" -C "${tmpdir}/guard-pre-test" config --unset branch.feature.remote
"$real_git" -C "${tmpdir}/guard-pre-test" config --unset branch.feature.merge

result=$(cd "${tmpdir}/guard-pre-test" && run_wrapper_real_git status 2>&1 || true)
if [[ $result == *"UPSTREAM TRACKING DROPPED"* ]]
then
  pass "upstream guard fires when tracking is dropped"
else
  fail "upstream guard should fire when tracking dropped: got '${result}'"
fi

# Test 9: upstream guard uses -C target, not CWD
run_test
setup_tracking_repo "guard-C-target" "mybranch"
# Create a second repo with detached HEAD (like a cache)
"$real_git" -C "$tmpdir" init "detached-cache" >/dev/null 2>&1
"$real_git" -C "${tmpdir}/detached-cache" commit --allow-empty -m "init" >/dev/null 2>&1
"$real_git" -C "${tmpdir}/detached-cache" checkout --detach HEAD >/dev/null 2>&1

# Make guard-C-target have broken tracking (cookie + no remote)
touch "${tmpdir}/guard-C-target/x.upstream-configured"
"$real_git" -C "${tmpdir}/guard-C-target" config --unset branch.mybranch.remote
"$real_git" -C "${tmpdir}/guard-C-target" config --unset branch.mybranch.merge

# Run git -C <detached-cache> status FROM the broken worktree dir.
# With the fix, the guard should check the detached cache (and skip),
# NOT the CWD (which is broken).
result=$(cd "${tmpdir}/guard-C-target" && run_wrapper_real_git "-C '${tmpdir}/detached-cache' status" 2>&1 || true)
if [[ $result != *"UPSTREAM TRACKING DROPPED"* ]]
then
  pass "upstream guard uses -C target, not CWD"
else
  fail "upstream guard should not fire for -C target with detached HEAD: got '${result}'"
fi

