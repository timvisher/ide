# ---------------------------------------------------------------------------
# Upstream guard integration tests (using real git repos)
# ---------------------------------------------------------------------------

real_git=/opt/homebrew/bin/git

# For upstream guard tests, the wrapper needs the real git binary (not the
# echo mock) because it calls rev-parse/config internally. Build a parallel
# PATH that points at real git instead of the echo mock.
mkdir -p "$tmpdir/real-prefix/bin"
ln -sf "$real_git" "$tmpdir/real-prefix/bin/git"

test_path_real_git="$tmpdir/selflink:$tmpdir/real-prefix/bin:$tmpdir/mockbin:/opt/homebrew/bin:/usr/bin:/bin"

run_wrapper_real_git() {
  TIMVISHER_AGENT= CLAUDECODE= TIMVISHER_CODEX= \
  PATH="$test_path_real_git" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

run_wrapper_real_git_agent() {
  TIMVISHER_AGENT=true \
  PATH="$test_path_real_git" \
  bash -c "source '${funcs_dir}/logging.bash'; '$script' $*" 2>&1
}

# Helper: create a minimal repo with a branch tracking a remote
setup_tracking_repo() {
  local repo_dir=$1 branch_name=$2

  "$real_git" -C "$tmpdir" init --bare "remote-${branch_name}.git" >/dev/null 2>&1
  "$real_git" -C "$tmpdir" clone "remote-${branch_name}.git" "$repo_dir" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" commit --allow-empty -m "init" >/dev/null 2>&1
  "$real_git" -C "${tmpdir}/${repo_dir}" push origin HEAD >/dev/null 2>&1
  if [[ $branch_name != main ]]
  then
    "$real_git" -C "${tmpdir}/${repo_dir}" checkout -b "$branch_name" >/dev/null 2>&1
    "$real_git" -C "${tmpdir}/${repo_dir}" push -u origin "$branch_name" >/dev/null 2>&1
  fi
}

