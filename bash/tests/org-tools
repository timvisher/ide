#!/usr/bin/env bash

# Tests for org-outline, org-extract, org-todos, org-add-heading
# Static validation tests (emacs batch with init.el is too slow for CI).

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

bin_dir="$(cd "$(dirname "$0")/.." && pwd)/bin"

# Test 1: no datadog references in any script
run_test
found_dd=false
for tool in org-outline org-extract org-todos org-add-heading
do
  if grep -qi 'datadog\|dd-source' "$bin_dir/$tool"
  then
    found_dd=true
    break
  fi
done
if [[ $found_dd == false ]]
then
  pass "no datadog references in any org tool"
else
  fail "found datadog reference"
fi

# Test 2: all tools show usage on missing args
run_test
all_usage=true
for tool in org-outline org-extract org-todos org-add-heading
do
  result=$("$bin_dir/$tool" 2>&1 || true)
  if [[ $result != *"Usage"* ]]
  then
    all_usage=false
    fail "$tool does not show usage: got '${result}'"
    break
  fi
done
if [[ $all_usage == true ]]
then
  pass "all tools show usage on missing args"
fi

# Test 3: all tools error on missing file
run_test
all_error=true
for tool in org-outline org-extract org-todos org-add-heading
do
  result=$("$bin_dir/$tool" /nonexistent/file.org 2>&1 || true)
  if [[ $result != *"not found"* ]]
  then
    # org-extract and org-add-heading need 2+ args; provide a dummy
    if [[ $tool == org-extract || $tool == org-add-heading ]]
    then
      result=$("$bin_dir/$tool" /nonexistent/file.org "heading" 2>&1 || true)
    fi
    if [[ $result != *"not found"* ]]
    then
      all_error=false
      fail "$tool does not error on missing file: got '${result}'"
      break
    fi
  fi
done
if [[ $all_error == true ]]
then
  pass "all tools error on missing file"
fi

# Test 4: all tools are executable
run_test
all_exec=true
for tool in org-outline org-extract org-todos org-add-heading
do
  if ! [[ -x $bin_dir/$tool ]]
  then
    all_exec=false
    fail "$tool is not executable"
    break
  fi
done
if [[ $all_exec == true ]]
then
  pass "all tools are executable"
fi

# Test 5: all tools use emacs --batch
run_test
all_batch=true
for tool in org-outline org-extract org-todos org-add-heading
do
  if ! grep -q 'emacs --batch' "$bin_dir/$tool"
  then
    all_batch=false
    fail "$tool does not use emacs --batch"
    break
  fi
done
if [[ $all_batch == true ]]
then
  pass "all tools use emacs --batch"
fi

echo ""
echo "Results: $((tests - failures))/${tests} passed"

if (( 0 < failures ))
then
  exit 1
fi
