#!/usr/bin/env bash

# Tests for bd wrapper.
# The wrapper chmods .beads to 0700 before exec'ing real bd.
# BD_BINARY overrides the real-bd path so tests don't need homebrew bd installed.

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

script="$(cd "$(dirname "$0")/.." && pwd)/bin/bd"

tmpdir=$(mktemp -d)
# Canonicalize: macOS /var → /private/var, and the bd wrapper does
# `pwd -P` so the BEADS_DIR it sets uses the resolved path.
tmpdir=$(cd "$tmpdir" && pwd -P)
trap 'rm -rf "$tmpdir"' EXIT

# Fake bd: just echoes its args so we can confirm exec reached it.
cat > "$tmpdir/fake-bd" <<'MOCK'
#!/usr/bin/env bash
echo "fake-bd $*"
MOCK
chmod +x "$tmpdir/fake-bd"

# --- Test 1: chmods .beads from 0755 to 0700 inside a repo ---
run_test
mkdir -p "$tmpdir/repo1/.beads"
git -C "$tmpdir/repo1" init -q
chmod 0755 "$tmpdir/repo1/.beads"
(
  cd "$tmpdir/repo1"
  BD_BINARY="$tmpdir/fake-bd" "$script" hello >/dev/null
)
perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/repo1/.beads")
if [[ $perms == 700 ]]
then
  pass "chmods .beads from 0755 to 0700 in repo root"
else
  fail "expected .beads perms=700, got ${perms}"
fi

# --- Test 2: also chmods the redirect target if configured ---
run_test
mkdir -p "$tmpdir/repo2/.beads" "$tmpdir/target2"
git -C "$tmpdir/repo2" init -q
printf '%s\n' "$tmpdir/target2" > "$tmpdir/repo2/.beads/redirect"
chmod 0755 "$tmpdir/repo2/.beads" "$tmpdir/target2"
(
  cd "$tmpdir/repo2"
  BD_BINARY="$tmpdir/fake-bd" "$script" >/dev/null
)
local_perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/repo2/.beads")
target_perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/target2")
if [[ $local_perms == 700 && $target_perms == 700 ]]
then
  pass "chmods both .beads and the redirect target to 0700"
else
  fail "expected both=700, got local=${local_perms} target=${target_perms}"
fi

# --- Test 3: no-op when outside any git repo (no error, still exec's bd) ---
run_test
result=$(
  cd "$tmpdir"
  BD_BINARY="$tmpdir/fake-bd" "$script" status 2>&1
)
if [[ $result == "fake-bd status" ]]
then
  pass "no-op outside a git repo; still exec's bd with args"
else
  fail "expected 'fake-bd status', got '${result}'"
fi

# --- Test 4: no-op when repo has no .beads dir (still exec's bd) ---
run_test
mkdir -p "$tmpdir/repo4"
git -C "$tmpdir/repo4" init -q
result=$(
  cd "$tmpdir/repo4"
  BD_BINARY="$tmpdir/fake-bd" "$script" list 2>&1
)
if [[ $result == "fake-bd list" ]]
then
  pass "no-op in repo without .beads; still exec's bd"
else
  fail "expected 'fake-bd list', got '${result}'"
fi

# --- Test 5: tolerates a missing redirect target (no error) ---
run_test
mkdir -p "$tmpdir/repo5/.beads"
git -C "$tmpdir/repo5" init -q
printf '%s\n' "$tmpdir/does-not-exist" > "$tmpdir/repo5/.beads/redirect"
chmod 0755 "$tmpdir/repo5/.beads"
result=$(
  cd "$tmpdir/repo5"
  BD_BINARY="$tmpdir/fake-bd" "$script" note 2>&1
)
local_perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/repo5/.beads")
if [[ $result == "fake-bd note" && $local_perms == 700 ]]
then
  pass "tolerates missing redirect target; still chmods local and exec's bd"
else
  fail "expected clean exec + local perms=700; got result='${result}' perms=${local_perms}"
fi

# --- Test 6: CRLF line endings in redirect file don't break path resolution ---
run_test
mkdir -p "$tmpdir/repo6/.beads" "$tmpdir/target6"
git -C "$tmpdir/repo6" init -q
printf '%s\r\n' "$tmpdir/target6" > "$tmpdir/repo6/.beads/redirect"
chmod 0755 "$tmpdir/repo6/.beads" "$tmpdir/target6"
(
  cd "$tmpdir/repo6"
  BD_BINARY="$tmpdir/fake-bd" "$script" >/dev/null
)
target_perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/target6")
if [[ $target_perms == 700 ]]
then
  pass "strips CRLF from redirect target so chmod reaches the real dir"
else
  fail "expected target perms=700 with CRLF redirect, got ${target_perms}"
fi

# --- Test 7: trailing spaces/tabs in redirect file are stripped ---
run_test
mkdir -p "$tmpdir/repo7/.beads" "$tmpdir/target7"
git -C "$tmpdir/repo7" init -q
printf '%s  \t\n' "$tmpdir/target7" > "$tmpdir/repo7/.beads/redirect"
chmod 0755 "$tmpdir/repo7/.beads" "$tmpdir/target7"
(
  cd "$tmpdir/repo7"
  BD_BINARY="$tmpdir/fake-bd" "$script" >/dev/null
)
target_perms=$(/usr/bin/stat -f '%Lp' "$tmpdir/target7")
if [[ $target_perms == 700 ]]
then
  pass "strips trailing spaces/tabs from redirect target"
else
  fail "expected target perms=700 with trailing whitespace, got ${target_perms}"
fi

# Fake bd that prints whether BEADS_DIR was set by the caller.
cat > "$tmpdir/echo-bd" <<'MOCK'
#!/usr/bin/env bash
echo "BEADS_DIR=${BEADS_DIR:-}"
MOCK
chmod +x "$tmpdir/echo-bd"

# --- Test 8: anchors BEADS_DIR at a topic dir below the git toplevel ---
# Mirrors the user's drift case: topics root is a git repo, the actual
# topic lives in a subdirectory. Without BEADS_DIR, bd's auto-discovery
# walks up to the topics-root .beads/redirect and uses the wrong topic.
run_test
mkdir -p "$tmpdir/repo8/Incidents/53555/.beads" "$tmpdir/repo8/.beads" "$tmpdir/wrong-target"
git -C "$tmpdir/repo8" init -q
printf '%s\n' "$tmpdir/wrong-target/.beads" > "$tmpdir/repo8/.beads/redirect"
result=$(
  cd "$tmpdir/repo8/Incidents/53555"
  BD_BINARY="$tmpdir/echo-bd" "$script"
)
if [[ $result == "BEADS_DIR=$tmpdir/repo8/Incidents/53555/.beads" ]]
then
  pass "anchors BEADS_DIR at the topic dir, not the surrounding repo's redirect"
else
  fail "expected BEADS_DIR at topic dir; got '${result}'"
fi

# --- Test 9: at-or-above git toplevel, leaves BEADS_DIR unset so the
#     existing redirect-following discovery still applies ---
run_test
mkdir -p "$tmpdir/repo9/.beads" "$tmpdir/target9"
git -C "$tmpdir/repo9" init -q
printf '%s\n' "$tmpdir/target9" > "$tmpdir/repo9/.beads/redirect"
result=$(
  cd "$tmpdir/repo9"
  BD_BINARY="$tmpdir/echo-bd" "$script"
)
if [[ $result == "BEADS_DIR=" ]]
then
  pass "does not override BEADS_DIR when at the git toplevel with a redirect"
else
  fail "expected BEADS_DIR unset; got '${result}'"
fi

# --- Test 10: a caller-supplied BEADS_DIR is preserved as-is ---
# `timvisher_bd_topics bd <topic> -- …` exports BEADS_DIR to point at
# an explicit topic. The wrapper must not clobber it with a CWD walk,
# even when CWD lives inside a different topic dir below a git repo.
run_test
mkdir -p "$tmpdir/repo10/Incidents/53555/.beads" "$tmpdir/repo10/.beads" "$tmpdir/explicit-target/.beads"
git -C "$tmpdir/repo10" init -q
printf '%s\n' "$tmpdir/repo10/.beads/redirect-target" > "$tmpdir/repo10/.beads/redirect"
result=$(
  cd "$tmpdir/repo10/Incidents/53555"
  BEADS_DIR="$tmpdir/explicit-target/.beads" \
    BD_BINARY="$tmpdir/echo-bd" "$script"
)
if [[ $result == "BEADS_DIR=$tmpdir/explicit-target/.beads" ]]
then
  pass "preserves a caller-supplied BEADS_DIR (timvisher_bd_topics bd <topic>)"
else
  fail "expected explicit BEADS_DIR preserved; got '${result}'"
fi

echo ""
echo "Results: $((tests - failures))/${tests} passed"

if (( 0 < failures ))
then
  exit 1
fi
