run_test
result=$(pr_head_repo_spec "https://github.com/upstream/repo/pull/2" 2>/dev/null) && rc=0 || rc=$?
if (( 0 < rc ))
then
  pass "pr_head_repo_spec fails when headRepository is null (deleted fork)"
else
  fail "pr_head_repo_spec should fail for null headRepository, got rc=${rc} result='${result}'"
fi

# Test: pr_head_repo_spec fails when headRepository.name is empty string
run_test
result=$(pr_head_repo_spec "https://github.com/upstream/repo/pull/3" 2>/dev/null) && rc=0 || rc=$?
if (( 0 < rc ))
then
  pass "pr_head_repo_spec fails when headRepository.name is empty"
else
  fail "pr_head_repo_spec should fail for empty repo name, got rc=${rc} result='${result}'"
fi

# Test: pr_head_repo_spec works with PR URL that has trailing path junk
