# Regression (ide-gct): ensure_worktree must heal the NEWLY-created worktree
# when the cache has extensions.worktreeConfig=true + core.bare=true.  Without
# the post-add heal, `git worktree add` propagates core.bare=true into the new
# worktree and the subsequent `git checkout --track -b <branch>` fails with
# "fatal: this operation must be run in a work tree".
run_test
ewp_org="ewporg"
ewp_repo="ewprepo"
ewp_cache="$cache_dir/repo_trunks/${ewp_org}/${ewp_repo}"
