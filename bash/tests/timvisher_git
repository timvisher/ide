# Test: idempotent — already-healed worktree stays at core.bare=false
# and a second heal pass is a no-op (no rewrite of the file).
run_test
poisoned_idem=$(setup_poisoned_cache "wfp_idem" true)
idem_cache=${poisoned_idem%%;*}
idem_wt=${poisoned_idem#*;}

