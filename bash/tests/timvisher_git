first_mtime=$(/usr/bin/stat -f '%m' "$idem_wt_gitdir/config.worktree" 2>/dev/null) || first_mtime=""

# Wait one second so a re-write would produce a distinct mtime.
sleep 1
migrate_cache_to_bare_if_needed "$idem_cache" >/dev/null 2>&1
second_mtime=$(/usr/bin/stat -f '%m' "$idem_wt_gitdir/config.worktree" 2>/dev/null) || second_mtime=""
second_value=$("$test_git" -C "$idem_wt" config --worktree --get core.bare 2>/dev/null) || second_value=""

if [[ -n $first_mtime ]] && [[ $first_mtime == "$second_mtime" ]] && [[ $second_value == false ]]
then
  pass "ensure_worktrees_not_poisoned_by_bare: idempotent on already-healed worktree (ide-wfp)"
else
  fail "idempotent heal: first_mtime='${first_mtime}' second_mtime='${second_mtime}' second_value='${second_value}'"
fi

