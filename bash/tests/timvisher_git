# ---------------------------------------------------------------------------
# Setup for is_branch_ish and clone_stacked integration tests
# ---------------------------------------------------------------------------

# Use the real git binary directly to avoid the agent-safety wrapper
# (~/bin/git) which requires Co-authored-by trailers on commits.
test_git="$(brew --prefix)/bin/git"

# Create a source repo to serve as the remote
source_repo="$tmpdir/remote"
"$test_git" init "$source_repo" >/dev/null 2>&1
"$test_git" -C "$source_repo" -c user.email=test@test.com -c user.name=Test \
  -c core.hooksPath=/dev/null commit --allow-empty -m "initial" >/dev/null 2>&1
default_branch=$("$test_git" -C "$source_repo" rev-parse --abbrev-ref HEAD)

# Add a feature/base branch with a unique commit
"$test_git" -C "$source_repo" checkout -b feature/base >/dev/null 2>&1
"$test_git" -C "$source_repo" -c user.email=test@test.com -c user.name=Test \
  -c core.hooksPath=/dev/null commit --allow-empty -m "base commit" >/dev/null 2>&1
base_commit=$("$test_git" -C "$source_repo" rev-parse HEAD)
"$test_git" -C "$source_repo" checkout "$default_branch" >/dev/null 2>&1

# Initialize a bare cache (simulating what cache_trunk creates)
mkdir -p "$cache_dir/repo_trunks/testorg"
"$test_git" init --bare "$cache_dir/repo_trunks/testorg/testrepo" >/dev/null 2>&1
"$test_git" -C "$cache_dir/repo_trunks/testorg/testrepo" remote add origin "$source_repo"
"$test_git" -C "$cache_dir/repo_trunks/testorg/testrepo" fetch origin >/dev/null 2>&1
"$test_git" -C "$cache_dir/repo_trunks/testorg/testrepo" remote set-head origin -a >/dev/null 2>&1

# Add org alias: to → testorg, and re-source to pick it up
echo 'to=testorg' > "$tmpdir/timvisher/ide/git_org_aliases"
source_timvisher_git

# Override cache/live dirs to use test paths
repo_trunks_dir="$cache_dir/repo_trunks"
live_repo_dir="$live_dir"
# Re-add alias (source_timvisher_git re-reads the file, but the script
# also sources from XDG_CONFIG_HOME which points to $tmpdir — however
# the source function blanks the file.  Set it directly.)
org_aliases[to]=testorg

