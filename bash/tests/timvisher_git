noext_wt_gitdir=$(cd "$noext_wt" && cd "$noext_wt_gitdir" && pwd -P)

if [[ ! -e "$noext_wt_gitdir/config.worktree" ]]
then
  pass "ensure_worktrees_not_poisoned_by_bare: no-op when extensions.worktreeConfig is off (ide-wfp)"
else
  fail "no-extension heal: config.worktree should not exist at '${noext_wt_gitdir}'"
