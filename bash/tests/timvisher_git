# ---------------------------------------------------------------------------
# ensure_worktrees_not_poisoned_by_bare tests (ide-wfp)
# ---------------------------------------------------------------------------
#
# Build a small helper that creates an already-bare cache whose linked
# worktrees lack the per-worktree `core.bare = false` override — the
# state the buggy migration leaves caches in.

setup_poisoned_cache() {
  local label=$1
  local with_extension=$2  # true|false

  local src="$tmpdir/poison_${label}_src"
  "$test_git" init "$src" >/dev/null 2>&1
  "$test_git" -C "$src" -c user.email=t@t -c user.name=t \
    -c core.hooksPath=/dev/null commit --allow-empty -m init >/dev/null 2>&1

  local cache="$tmpdir/poison_${label}_cache"
  "$test_git" init --bare "$cache" >/dev/null 2>&1
  "$test_git" -C "$cache" remote add origin "$src" >/dev/null 2>&1
  "$test_git" -C "$cache" fetch origin >/dev/null 2>&1
  "$test_git" -C "$cache" remote set-head origin -a >/dev/null 2>&1

  if [[ $with_extension == true ]]
  then
    "$test_git" -C "$cache" config extensions.worktreeConfig true
  fi

  local wt="$tmpdir/poison_${label}_wt"
  "$test_git" -C "$cache" worktree add --detach "$wt" \
    "origin/$default_branch" >/dev/null 2>&1

  printf '%s;%s' "$cache" "$wt"
}

# Test: heal pass writes per-worktree core.bare=false on a worktree that
# is poisoned by core.bare=true on the common config + worktreeConfig
# extension enabled.
run_test
poisoned=$(setup_poisoned_cache "wfp_heal" true)
heal_cache=${poisoned%%;*}
heal_wt=${poisoned#*;}

# Confirm pre-state: no per-worktree override yet.
pre_override=$("$test_git" -C "$heal_wt" config --worktree --get core.bare 2>/dev/null) || pre_override=""

migrate_cache_to_bare_if_needed "$heal_cache" >/dev/null 2>&1

post_override=$("$test_git" -C "$heal_wt" config --worktree --get core.bare 2>/dev/null) || post_override=""
post_inside=$("$test_git" -C "$heal_wt" rev-parse --is-inside-work-tree 2>/dev/null) || post_inside=""

if [[ -z $pre_override ]] && [[ $post_override == false ]] && [[ $post_inside == true ]]
then
  pass "ensure_worktrees_not_poisoned_by_bare: writes per-worktree core.bare=false (ide-wfp)"
else
  fail "heal pass: pre_override='${pre_override}' post_override='${post_override}' post_inside='${post_inside}'"
fi

# Test: no-op when extensions.worktreeConfig is not enabled. Without the
