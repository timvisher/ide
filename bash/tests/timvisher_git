ensure_worktree "${ewp_org}/${ewp_repo}/${ewp_branch}" >/dev/null 2>&1 && ewp_rc=0 || ewp_rc=$?

ewp_override=$("$test_git" -C "$ewp_wt" config --worktree --get core.bare 2>/dev/null) || ewp_override=""
ewp_inside=$("$test_git" -C "$ewp_wt" rev-parse --is-inside-work-tree 2>/dev/null) || ewp_inside=""
ewp_head=$("$test_git" -C "$ewp_wt" rev-parse --abbrev-ref HEAD 2>/dev/null) || ewp_head=""

if (( ewp_rc == 0 )) \
   && [[ $ewp_override == false ]] \
   && [[ $ewp_inside == true ]] \
   && [[ $ewp_head == "$ewp_branch" ]]
then
  pass "ensure_worktree: heals newly-created worktree when cache has extensions.worktreeConfig+core.bare (ide-gct)"
else
  fail "ensure_worktree post-add heal: rc=${ewp_rc} override='${ewp_override}' inside='${ewp_inside}' head='${ewp_head}'"
fi

