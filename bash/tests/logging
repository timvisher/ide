#!/usr/bin/env bash

# Tests for structured JSON logging (TIMVISHER_AGENT mode)

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

funcs_dir="$(cd "$(dirname "$0")/../functions" && pwd)"

# Helper: run a logging call in agent mode
run_agent_log() {
  TIMVISHER_AGENT=1 \
  bash -c "source '${funcs_dir}/logging.bash'; timvisher_logging_log_level=TRACE; $1" 2>&1
}

# Helper: run a logging call in agent mode without jq
run_agent_log_no_jq() {
  TIMVISHER_AGENT=1 \
  bash -c "
    source '${funcs_dir}/logging.bash'
    timvisher_logging_log_level=TRACE
    timvisher_logging__has_jq=false
    $1
  " 2>&1
}

# ---------------------------------------------------------------------------
# Basic structured output
# ---------------------------------------------------------------------------

# Test: info emits valid JSON with correct fields
run_test
result=$(run_agent_log 'info "hello %s" "world"')
if printf '%s' "$result" | jq -e '.type == "log" and .level == "INFO" and .message == "hello world"' >/dev/null 2>&1
then
  pass "info emits valid JSON with correct fields"
else
  fail "info JSON output: got '${result}'"
fi

# Test: error emits ERROR level
run_test
result=$(run_agent_log 'error "bad %s" "thing"')
if printf '%s' "$result" | jq -e '.level == "ERROR"' >/dev/null 2>&1
then
  pass "error emits ERROR level"
else
  fail "error level: got '${result}'"
fi

# Test: warn emits WARN level
run_test
result=$(run_agent_log 'warn "caution"')
if printf '%s' "$result" | jq -e '.level == "WARN"' >/dev/null 2>&1
then
  pass "warn emits WARN level"
else
  fail "warn level: got '${result}'"
fi

# Test: trace emits TRACE level
run_test
result=$(run_agent_log 'trace "detail"')
if printf '%s' "$result" | jq -e '.level == "TRACE"' >/dev/null 2>&1
then
  pass "trace emits TRACE level"
else
  fail "trace level: got '${result}'"
fi

# Test: die emits DIE level and exits non-zero
run_test
rc=0
result=$(run_agent_log 'die "fatal"') || rc=$?
if (( 0 < rc )) && printf '%s' "$result" | jq -e '.level == "DIE"' >/dev/null 2>&1
then
  pass "die emits DIE level and exits non-zero"
else
  fail "die: rc=$rc, got '${result}'"
fi

# Test: caller field reflects calling function
run_test
result=$(run_agent_log 'my_func() { info "from func"; }; my_func')
if printf '%s' "$result" | jq -e '.caller == "my_func"' >/dev/null 2>&1
then
  pass "caller field reflects calling function"
else
  fail "caller field: got '${result}'"
fi

# ---------------------------------------------------------------------------
# JSON escaping
# ---------------------------------------------------------------------------

# Test: handles double quotes in message
run_test
result=$(run_agent_log 'error "say %s" "\"hello\""')
if printf '%s' "$result" | jq -e '.message == "say \"hello\""' >/dev/null 2>&1
then
  pass "handles double quotes in message"
else
  fail "quote escaping: got '${result}'"
fi

# Test: handles newlines in message
run_test
result=$(run_agent_log 'error "line1\nline2"')
if printf '%s' "$result" | jq -e '.message == "line1\nline2"' >/dev/null 2>&1
then
  pass "handles newlines in message"
else
  fail "newline escaping: got '${result}'"
fi

# Test: handles backslashes in %s argument
run_test
result=$(run_agent_log 'error "path: %s" "C:\\Users\\me"')
if printf '%s' "$result" | jq -e '.message == "path: C:\\Users\\me"' >/dev/null 2>&1
then
  pass "handles backslashes in message"
else
  fail "backslash escaping: got '${result}'"
fi

# ---------------------------------------------------------------------------
# Tagged data (timvisher_logging_data)
# ---------------------------------------------------------------------------

# Test: tagged data appears in data sub-object
run_test
result=$(run_agent_log 'timvisher_logging_data[rid]=abc123; error "boom"')
if printf '%s' "$result" | jq -e '.data.rid == "abc123"' >/dev/null 2>&1
then
  pass "tagged data appears in data sub-object"
else
  fail "tagged data: got '${result}'"
fi

# Test: multiple data keys
run_test
result=$(run_agent_log 'timvisher_logging_data[a]=one; timvisher_logging_data[b]=two; error "x"')
if printf '%s' "$result" | jq -e '.data.a == "one" and .data.b == "two"' >/dev/null 2>&1
then
  pass "multiple data keys"
else
  fail "multiple data keys: got '${result}'"
fi

# Test: data with special characters
run_test
result=$(run_agent_log 'timvisher_logging_data[key]="val with \"quotes\""; error "x"')
if printf '%s' "$result" | jq -e '.data.key == "val with \"quotes\""' >/dev/null 2>&1
then
  pass "data with special characters"
else
  fail "data special chars: got '${result}'"
fi

# Test: no data field when timvisher_logging_data is empty
run_test
result=$(run_agent_log 'error "clean"')
if printf '%s' "$result" | jq -e 'has("data") | not' >/dev/null 2>&1
then
  pass "no data field when empty"
else
  fail "should not have data field: got '${result}'"
fi

# ---------------------------------------------------------------------------
# printf fallback (no jq)
# ---------------------------------------------------------------------------

# Test: fallback produces valid JSON
run_test
result=$(run_agent_log_no_jq 'info "fallback %s" "test"')
if printf '%s' "$result" | jq -e '.type == "log" and .level == "INFO" and .message == "fallback test"' >/dev/null 2>&1
then
  pass "printf fallback produces valid JSON"
else
  fail "printf fallback: got '${result}'"
fi

# Test: fallback handles quotes
run_test
result=$(run_agent_log_no_jq 'error "say %s" "\"hi\""')
if printf '%s' "$result" | jq -e '.message == "say \"hi\""' >/dev/null 2>&1
then
  pass "printf fallback handles quotes"
else
  fail "printf fallback quotes: got '${result}'"
fi

# Test: fallback handles tagged data
run_test
result=$(run_agent_log_no_jq 'timvisher_logging_data[x]=y; error "fb"')
if printf '%s' "$result" | jq -e '.data.x == "y"' >/dev/null 2>&1
then
  pass "printf fallback handles tagged data"
else
  fail "printf fallback data: got '${result}'"
fi

# ---------------------------------------------------------------------------
# Human mode unchanged
# ---------------------------------------------------------------------------

# Test: human mode does not emit JSON
run_test
result=$(bash -c "unset TIMVISHER_AGENT; source '${funcs_dir}/logging.bash'; timvisher_logging_log_level=INFO; info 'human mode'" 2>&1)
if [[ $result == *"INFO"* ]] && [[ $result == *"human mode"* ]] && ! printf '%s' "$result" | jq -e . >/dev/null 2>&1
then
  pass "human mode does not emit JSON"
else
  fail "human mode: got '${result}'"
fi

echo ""
echo "Results: $((tests - failures))/${tests} passed"

if (( 0 < failures ))
then
  exit 1
fi
