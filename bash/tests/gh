# be examined. This was the bypass aishot review caught.
run_test
result=$(run_agent -R owner/repo pr create --title foo --body bar)
if [[ $result == *'"code":"gh_mutation_blocked"'* ]]
then
  pass "blocks 'gh -R OWNER/REPO pr create' (value-taking global flag)"
else
  fail "value-taking global flag '-R': got '${result}'"
fi

