cat > "$tmpdir/spoof-bin/spoofscript" <<'SPOOF'
#!/usr/bin/env bash
shift  # discard the 'timvisher_gh' decoy; run the rest
"$@"
SPOOF
chmod +x "$tmpdir/spoof-bin/spoofscript"
result=$(TIMVISHER_AGENT=true PATH="$test_path" \
  "$tmpdir/spoof-bin/spoofscript" timvisher_gh bash -c \
  "source '${funcs_dir}/logging.bash'; '$script' pr create --title x --body y" 2>&1 || true)
if [[ $result == *'"code":"gh_mutation_blocked"'* ]]
then
  pass "spoof: 'timvisher_gh' as later argv token does NOT satisfy ancestor gate"
else
  fail "spoof should block: got '${result}'"
fi

