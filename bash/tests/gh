#!/usr/bin/env bash

# Tests for gh wrapper

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

script="$(cd "$(dirname "$0")/.." && pwd)/bin/gh"
funcs_dir="$(cd "$(dirname "$0")/../functions" && pwd)"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# Create a mock brew prefix with gh inside it
mkdir -p "$tmpdir/prefix/bin"
cat > "$tmpdir/prefix/bin/gh" <<'MOCK'
#!/usr/bin/env bash
echo "real-gh $*"
MOCK
chmod +x "$tmpdir/prefix/bin/gh"

# Mock brew to return our prefix
mkdir -p "$tmpdir/mockbin"
cat > "$tmpdir/mockbin/brew" <<MOCK
#!/usr/bin/env bash
echo "$tmpdir/prefix"
MOCK
chmod +x "$tmpdir/mockbin/brew"

test_path="$tmpdir/mockbin:$PATH"

# Fake timvisher_gh: a shell script that runs its args as a subprocess
# (no exec) so it sits in the ancestor chain when the wrapper is invoked
# underneath. Used to exercise the ancestor-gate allow-path.
mkdir -p "$tmpdir/faketgh-bin"
cat > "$tmpdir/faketgh-bin/timvisher_gh" <<'FAKE_TGH'
#!/usr/bin/env bash
"$@"
FAKE_TGH
chmod +x "$tmpdir/faketgh-bin/timvisher_gh"

run_agent() {
  # Pass args via positional parameters so values with spaces or shell
  # metacharacters survive intact. `bash -c '... "$@"' _ "$@"` binds the
  # first extra arg ($_) to $0 inside the child and the rest to $1, $2, …
  TIMVISHER_AGENT=true PATH="$test_path" \
    bash -c "source '${funcs_dir}/logging.bash'; '$script' \"\$@\"" _ "$@" 2>&1 || true
}

run_agent_under_tgh() {
  TIMVISHER_AGENT=true PATH="$test_path" \
    "$tmpdir/faketgh-bin/timvisher_gh" bash -c \
    "source '${funcs_dir}/logging.bash'; '$script' \"\$@\"" _ "$@" 2>&1 || true
}

