touch "$MOCK_LOG"
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true)
if [[ $result == *"not readable"* ]]
then
  pass "pr exits if pr.md doesn't exist"
else
  fail "pr exits if pr.md doesn't exist: got '${result}'"
fi

# Test: pr opens existing pr.md.url if present
