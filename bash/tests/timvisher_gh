#!/usr/bin/env bash

# Tests for timvisher_gh
# Heavy mocking since this interacts with git, gh, and macOS open.

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

script="$(cd "$(dirname "$0")/.." && pwd)/bin/timvisher_gh"
funcs_dir="$(cd "$(dirname "$0")/../functions" && pwd)"
real_git="$(brew --prefix)/bin/git"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

# Set up a fake git repo
mkdir -p "$tmpdir/repo"
cd "$tmpdir/repo"
"$real_git" init -q .
"$real_git" config user.email "test@test.com"
"$real_git" config user.name "Test"
"$real_git" remote add origin https://github.com/testuser/testrepo.git
echo "init" > README.md
"$real_git" add README.md
"$real_git" commit -q -m "init"

# Create mock commands
mkdir -p "$tmpdir/mockbin"

cat > "$tmpdir/mockbin/git" <<MOCK
#!/usr/bin/env bash
if [[ \$1 == rev-parse || \$1 == status || \$1 == remote ]]
then
  "$real_git" "\$@"
elif [[ \$1 == push ]]
then
  echo "mock-git-push \$*" >> "\$MOCK_LOG"
else
  "$real_git" "\$@"
fi
MOCK
chmod +x "$tmpdir/mockbin/git"

cat > "$tmpdir/mockbin/gh" <<'MOCK'
#!/usr/bin/env bash
echo "mock-gh $*" >> "$MOCK_LOG"
if [[ $1 == repo && $2 == view ]]
then
  echo "main"
elif [[ $1 == pr && $2 == create ]]
then
  echo "https://github.com/testuser/testrepo/pull/1"
elif [[ $1 == pr && $2 == edit ]]
then
  echo "mock-pr-edit"
elif [[ $1 == pr && $2 == checks ]]
then
  # Return contents of MOCK_CHECKS_FILE if set, otherwise empty array
  if [[ -r ${MOCK_CHECKS_FILE:-} ]]
  then
    cat "$MOCK_CHECKS_FILE"
  else
    echo '[]'
  fi
elif [[ $1 == pr && $2 == ready ]]
then
  echo "mock-pr-ready"
elif [[ $1 == issue && $2 == create ]]
then
  echo "https://github.com/testuser/testrepo/issues/1"
elif [[ $1 == issue && $2 == edit ]]
then
  echo "mock-issue-edit"
elif [[ $1 == pr && $2 == comment ]]
then
  echo "https://github.com/testuser/testrepo/pull/1#issuecomment-12345"
elif [[ $1 == api && $2 == --method && $3 == PATCH ]]
then
  echo '{"html_url":"https://github.com/testuser/testrepo/pull/1#issuecomment-12345"}'
elif [[ $1 == api && $2 == --method && $3 == HEAD ]]
then
  # Simulate comment exists (HEAD check)
  true
elif [[ $1 == api && $2 == --method && $3 == DELETE ]]
then
  # Successful DELETE returns empty body
  true
fi
MOCK
chmod +x "$tmpdir/mockbin/gh"

cat > "$tmpdir/mockbin/open" <<'MOCK'
#!/usr/bin/env bash
echo "mock-open $*" >> "$MOCK_LOG"
MOCK
chmod +x "$tmpdir/mockbin/open"

test_path="$tmpdir/mockbin:$PATH"

# --- dispatch tests ---

# Test: no args prints usage and exits nonzero
run_test
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script'" 2>&1 || true)
if [[ $result == *"Usage:"* ]]
then
  pass "no args prints usage"
else
  fail "no args prints usage: got '${result}'"
fi

# Test: --help prints usage and exits zero
run_test
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' --help" 2>&1)
if [[ $result == *"Usage:"* ]]
then
  pass "--help prints usage"
else
  fail "--help prints usage: got '${result}'"
fi

# Test: unknown subcommand prints usage and exits nonzero
run_test
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' bogus" 2>&1 || true)
if [[ $result == *"Usage:"* ]]
then
  pass "unknown subcommand prints usage"
else
  fail "unknown subcommand prints usage: got '${result}'"
fi

# --- pr tests ---

# Test: pr exits if pr.md doesn't exist and pr.md.url doesn't exist
run_test
export MOCK_LOG="$tmpdir/log_pr_nofile"
touch "$MOCK_LOG"
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true)
if [[ $result == *"not readable"* ]]
then
  pass "pr exits if pr.md doesn't exist"
else
  fail "pr exits if pr.md doesn't exist: got '${result}'"
fi

# Test: pr opens existing pr.md.url if present
run_test
echo "https://github.com/testuser/testrepo/pull/42" > "$tmpdir/repo/pr.md.url"
export MOCK_LOG="$tmpdir/log_pr_existing"
touch "$MOCK_LOG"
PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true
if grep -q 'mock-open.*https://github.com/testuser/testrepo/pull/42' "$MOCK_LOG"
then
  pass "pr opens existing pr.md.url"
else
  fail "pr opens existing pr.md.url: got $(cat "$MOCK_LOG")"
fi
rm -f "$tmpdir/repo/pr.md.url"

# Test: pr creates PR from pr.md when git status is clean
run_test
cat > "$tmpdir/repo/pr.md" <<'PR'
My PR Title

This is the body of the PR.
PR
export MOCK_LOG="$tmpdir/log_pr_create"
touch "$MOCK_LOG"
PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true
if grep -q 'mock-git-push' "$MOCK_LOG" && grep -q 'mock-gh pr create' "$MOCK_LOG"
then
  pass "pr creates PR from pr.md"
else
  fail "pr creates PR from pr.md: got $(cat "$MOCK_LOG")"
fi
rm -f "$tmpdir/repo/pr.md.url"

# Test: pr exits if git status is dirty
run_test
echo "dirty" > "$tmpdir/repo/untracked.txt"
"$real_git" add "$tmpdir/repo/untracked.txt"
export MOCK_LOG="$tmpdir/log_pr_dirty"
touch "$MOCK_LOG"
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true)
if [[ $result == *"not clean"* ]]
then
  pass "pr exits if git status is dirty"
else
  fail "pr exits if git status dirty: got '${result}'"
fi
"$real_git" reset -q HEAD "$tmpdir/repo/untracked.txt"
rm -f "$tmpdir/repo/untracked.txt"
rm -f "$tmpdir/repo/pr.md"

# --- issue tests ---

# Test: issue exits if issue.md doesn't exist and issue.md.url doesn't exist
