export MOCK_LOG="$tmpdir/log_pr_ready_fail"
touch "$MOCK_LOG"
export MOCK_CHECKS_FILE="$tmpdir/checks_with_fail.json"
cat > "$MOCK_CHECKS_FILE" <<'JSON'
[{"name":"ci/build","bucket":"pass"},{"name":"ci/test","bucket":"fail"}]
JSON
result=$(TIMVISHER_GH_PR_READY_POLL_INTERVAL=0 PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr ready" 2>&1 || true)
if [[ $result == *"CI checks failed"* ]]
then
  pass "pr ready: dies on failed checks"
else
  fail "pr ready: dies on failed checks: got '${result}'"
fi
# Should NOT have called gh pr ready
if grep -q 'mock-gh pr ready' "$MOCK_LOG"
then
  fail "pr ready: should not call gh pr ready on failure"
else
  pass "pr ready: does not call gh pr ready on failure"
  ((tests++)) || true
fi
rm -f "$tmpdir/repo/pr.md.url"
unset MOCK_CHECKS_FILE

# Test: pr ready - exclude patterns filter out matching checks
