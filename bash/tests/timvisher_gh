# --- pr merge tests ---

# Test: pr merge - no hardcoded employer-specific references
# Patterns to guard against are read from system extensions config.
run_test
employer_patterns_file="${XDG_CONFIG_HOME:-${HOME}/.config}/timvisher/ide/guard_patterns"
found_leak=false
if [[ -r $employer_patterns_file ]]
then
  patterns=$(paste -sd '|' "$employer_patterns_file")
  if grep -qiE "$patterns" "$script"
  then
    found_leak=true
  fi
fi
if [[ $found_leak == false ]]
then
  pass "pr merge: no employer-specific references in script"
else
  fail "pr merge: found employer-specific references in script"
fi

# Test: pr merge - uses configurable gh-pr-merge-comment-repos file
run_test
if grep -q 'gh-pr-merge-comment-repos' "$script"
then
  pass "pr merge: uses configurable comment-repos config file"
else
  fail "pr merge: does not reference gh-pr-merge-comment-repos config"
fi

# Test: pr merge - config-based comment-merge routing
run_test
config_tmpdir=$(mktemp -d)
mkdir -p "$config_tmpdir/.config/timvisher/ide"
echo "myorg/special-repo" > "$config_tmpdir/.config/timvisher/ide/gh-pr-merge-comment-repos"

comment_merge_config="$config_tmpdir/.config/timvisher/ide/gh-pr-merge-comment-repos"
repo_slug_lc="myorg/special-repo"
if [[ -r $comment_merge_config ]] && grep -qix "$repo_slug_lc" "$comment_merge_config"
then
  pass "pr merge: config matches repo slug case-insensitively"
else
  fail "pr merge: config did not match repo slug"
fi

# Test: pr merge - config does not match non-listed repos
run_test
repo_slug_lc="myorg/normal-repo"
if [[ -r $comment_merge_config ]] && grep -qix "$repo_slug_lc" "$comment_merge_config"
then
  fail "pr merge: config incorrectly matched unlisted repo"
else
  pass "pr merge: config does not match unlisted repos"
fi
rm -rf "$config_tmpdir"

# Test: pr merge - exits if pr.md.url is missing
run_test
rm -f "$tmpdir/repo/pr.md.url"
export MOCK_LOG="$tmpdir/log_pr_merge_nourl"
touch "$MOCK_LOG"
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr merge" 2>&1 || true)
if [[ $result == *"pr_url unset"* || $result == *"pr.md.url"* ]]
then
  pass "pr merge: exits if pr.md.url is missing"
