run_test
cat > "$tmpdir/repo/issue.md" <<'ISSUE'
My Issue Title

This is the body of the issue.
ISSUE
export MOCK_LOG="$tmpdir/log_issue_create"
touch "$MOCK_LOG"
PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' issue" 2>&1 || true
if grep -q 'mock-gh issue create' "$MOCK_LOG"
then
  pass "issue creates issue from issue.md"
else
  fail "issue creates issue from issue.md: got $(cat "$MOCK_LOG")"
fi
# Verify no git push happened (issues don't need push)
if grep -q 'mock-git-push' "$MOCK_LOG"
then
  fail "issue should not git push"
else
  pass "issue does not git push"
  ((tests++)) || true
fi
rm -f "$tmpdir/repo/issue.md.url"
rm -f "$tmpdir/repo/issue.md"

