# --- pr ready tests ---

# Test: pr ready - exits if pr.md.url is missing
run_test
rm -f "$tmpdir/repo/pr.md.url"
export MOCK_LOG="$tmpdir/log_pr_ready_nourl"
touch "$MOCK_LOG"
result=$(TIMVISHER_GH_PR_READY_POLL_INTERVAL=0 PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr ready" 2>&1 || true)
if [[ $result == *"pr_url unset"* || $result == *"pr.md.url"* ]]
then
  pass "pr ready: exits if pr.md.url is missing"
else
  fail "pr ready: exits if pr.md.url missing: got '${result}'"
fi

# Test: pr ready - all checks passing calls gh pr ready
run_test
echo "https://github.com/testuser/testrepo/pull/42" > "$tmpdir/repo/pr.md.url"
export MOCK_LOG="$tmpdir/log_pr_ready_pass"
touch "$MOCK_LOG"
export MOCK_CHECKS_FILE="$tmpdir/checks_all_pass.json"
cat > "$MOCK_CHECKS_FILE" <<'JSON'
[{"name":"ci/build","bucket":"pass"},{"name":"ci/test","bucket":"pass"}]
JSON
TIMVISHER_GH_PR_READY_POLL_INTERVAL=0 PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr ready" 2>&1 || true
if grep -q 'mock-gh pr ready' "$MOCK_LOG"
then
  pass "pr ready: calls gh pr ready when all checks pass"
else
  fail "pr ready: calls gh pr ready when all checks pass: got $(cat "$MOCK_LOG")"
fi
rm -f "$tmpdir/repo/pr.md.url"
unset MOCK_CHECKS_FILE

# Test: pr ready - fails fast on failed checks
run_test
