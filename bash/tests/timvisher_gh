"$real_git" add "$tmpdir/repo/untracked.txt"
export MOCK_LOG="$tmpdir/log_pr_dirty"
touch "$MOCK_LOG"
result=$(PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true)
if [[ $result == *"not clean"* ]]
then
  pass "pr exits if git status is dirty"
else
  fail "pr exits if git status dirty: got '${result}'"
