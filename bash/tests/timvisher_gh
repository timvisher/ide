echo "https://github.com/testuser/testrepo/pull/42" > "$tmpdir/repo/pr.md.url"
export MOCK_LOG="$tmpdir/log_pr_ready_exclude"
touch "$MOCK_LOG"
# Set up fake HOME with .functions symlink and exclude config
exclude_home="$tmpdir/exclude_home1"
mkdir -p "$exclude_home/.config/timvisher/ide/bash/bin/timvisher_gh.config/repos/testuser/testrepo/pr/ready"
ln -s "$funcs_dir" "$exclude_home/.functions"
printf 'mergegate\n' > "$exclude_home/.config/timvisher/ide/bash/bin/timvisher_gh.config/repos/testuser/testrepo/pr/ready/exclude-checks.txt"
# mergegate is pending but should be excluded; other checks pass
export MOCK_CHECKS_FILE="$tmpdir/checks_with_excluded.json"
cat > "$MOCK_CHECKS_FILE" <<'JSON'
[{"name":"ci/build","bucket":"pass"},{"name":"ci/test","bucket":"pass"},{"name":"mergegate","bucket":"pending"}]
JSON
HOME="$exclude_home" TIMVISHER_GH_PR_READY_POLL_INTERVAL=0 PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr ready" 2>&1 || true
if grep -q 'mock-gh pr ready' "$MOCK_LOG"
then
  pass "pr ready: exclude patterns allow ignoring pending checks"
else
  fail "pr ready: exclude patterns allow ignoring pending checks: got $(cat "$MOCK_LOG")"
fi
rm -f "$tmpdir/repo/pr.md.url"
rm -rf "$exclude_home"
unset MOCK_CHECKS_FILE

# Test: pr ready - exclude patterns with comments and blank lines
