run_test
cat > "$tmpdir/repo/pr.md" <<'PR'
My PR Title

This is the body of the PR.
PR
export MOCK_LOG="$tmpdir/log_pr_create"
touch "$MOCK_LOG"
PATH="$test_path" bash -c "source '${funcs_dir}/logging.bash'; '$script' pr" 2>&1 || true
if grep -q 'mock-git-push' "$MOCK_LOG" && grep -q 'mock-gh pr create' "$MOCK_LOG"
then
