#!/usr/bin/env bash

# Tests for aictl structured messaging functions

set -euo pipefail

failures=0
tests=0

fail() {
  echo "FAIL: $1" >&2
  ((failures++)) || true
}

pass() {
  echo "PASS: $1"
}

run_test() {
  ((tests++)) || true
}

funcs_dir="$(cd "$(dirname "$0")/../functions" && pwd)"

# ---------------------------------------------------------------------------
# Schema structure tests
# ---------------------------------------------------------------------------

# Test: type is always "instruction"
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_die test_code 'msg'" 2>&1 || true)
if [[ $result == *'"type":"instruction"'* ]]
then
  pass "type is 'instruction'"
else
  fail "type field: got '${result}'"
fi

# ---------------------------------------------------------------------------
# aictl_die tests
# ---------------------------------------------------------------------------

# Test: aictl_die outputs level:error with code and message
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_die test_code 'test message'" 2>&1 || true)
if [[ $result == *'"level":"error"'* ]] && [[ $result == *'"code":"test_code"'* ]] && [[ $result == *'test message'* ]]
then
  pass "aictl_die outputs level:error with code and message"
else
  fail "aictl_die output: got '${result}'"
fi

# Test: aictl_die exits non-zero
run_test
rc=0
bash -c "source '${funcs_dir}/aictl.bash'; aictl_die test_code 'msg'" >/dev/null 2>&1 || rc=$?
if (( 0 < rc ))
then
  pass "aictl_die exits non-zero"
else
  fail "aictl_die should exit non-zero, got rc=$rc"
fi

# Test: aictl_die includes retryable:false
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_die test_code 'msg'" 2>&1 || true)
if [[ $result == *'"retryable":false'* ]]
then
  pass "aictl_die includes retryable:false"
else
  fail "aictl_die retryable: got '${result}'"
fi

# Test: aictl_die with --flag syntax
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_die --code test_flag --message 'flag msg' --reason 'because' --doc 'docs.md' --suggestion 'fix it'" 2>&1 || true)
if [[ $result == *'"code":"test_flag"'* ]] && [[ $result == *'"reason":"because"'* ]] && [[ $result == *'"doc":"docs.md"'* ]] && [[ $result == *'"fix it"'* ]]
then
  pass "aictl_die with --flag syntax"
else
  fail "aictl_die --flags: got '${result}'"
fi

# Test: aictl_die includes suggestions array
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_die --code tc --message m --suggestion 'fix one' --suggestion 'fix two'" 2>&1 || true)
if [[ $result == *'"suggestions":'* ]] && [[ $result == *'"fix one"'* ]] && [[ $result == *'"fix two"'* ]]
then
  pass "aictl_die includes multiple suggestions"
else
  fail "aictl_die suggestions: got '${result}'"
fi

# Test: aictl_die is NOT bypassed by NIRMI
run_test
result=$(TIMVISHER_AGENT_NIRMI=1 bash -c "source '${funcs_dir}/aictl.bash'; aictl_die test_code 'msg'" 2>&1 || true)
if [[ $result == *'"level":"error"'* ]]
then
  pass "aictl_die not bypassed by NIRMI"
else
  fail "aictl_die NIRMI: got '${result}'"
fi

# ---------------------------------------------------------------------------
# aictl_warn tests
# ---------------------------------------------------------------------------

# Test: aictl_warn outputs level:warning
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'warn msg'" 2>&1 || true)
if [[ $result == *'"level":"warning"'* ]] && [[ $result == *'"code":"test_warn"'* ]]
then
  pass "aictl_warn outputs level:warning"
else
  fail "aictl_warn output: got '${result}'"
fi

# Test: aictl_warn exits non-zero without NIRMI
run_test
rc=0
bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'msg'" >/dev/null 2>&1 || rc=$?
if (( 0 < rc ))
then
  pass "aictl_warn exits non-zero without NIRMI"
else
  fail "aictl_warn should exit non-zero, got rc=$rc"
fi

# Test: aictl_warn does NOT include a bypass object (agents had been
# copying the ready-to-paste bypass command rather than reconsidering)
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'msg'" 2>&1 || true)
if [[ $result != *'"bypass":'* ]] && [[ $result != *'"mechanism"'* ]]
then
  pass "aictl_warn omits bypass object"
else
  fail "aictl_warn should omit bypass object: got '${result}'"
fi

# Test: aictl_warn does NOT leak TIMVISHER_AGENT_NIRMI into output
# when --command is passed (used to be emitted as ready-to-paste)
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn --code tc --message m --command 'git log abc..HEAD'" 2>&1 || true)
if [[ $result != *'"command":"TIMVISHER_AGENT_NIRMI=1'* ]] && [[ $result != *'TIMVISHER_AGENT_NIRMI=1 git log'* ]]
then
  pass "aictl_warn does not emit ready-to-paste bypass command"
else
  fail "aictl_warn leaks bypass command: got '${result}'"
fi

# Test: aictl_warn with NIRMI only (no REASON) emits aictl_bypass_missing_reason
run_test
result=$(TIMVISHER_AGENT_NIRMI=1 bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'msg'; echo 'continued'" 2>&1 || true)
if [[ $result == *'"code":"aictl_bypass_missing_reason"'* ]] && [[ $result != *"continued"* ]]
then
  pass "aictl_warn with NIRMI only requires REASON"
else
  fail "aictl_warn NIRMI-only: got '${result}'"
fi

# Test: aictl_warn with NIRMI + REASON bypasses and continues
run_test
result=$(TIMVISHER_AGENT_NIRMI=1 TIMVISHER_AGENT_NIRMI_REASON="testing bypass" bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'msg'; echo 'continued'" 2>&1)
if [[ $result == *'"level":"bypass"'* ]] && [[ $result == *"continued"* ]]
then
  pass "aictl_warn NIRMI+REASON bypasses and continues"
else
  fail "aictl_warn NIRMI+REASON: got '${result}'"
fi

# Test: aictl_warn NIRMI+REASON bypass does NOT emit level:warning
run_test
result=$(TIMVISHER_AGENT_NIRMI=1 TIMVISHER_AGENT_NIRMI_REASON="r" bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn test_warn 'msg'" 2>&1)
if [[ $result != *'"level":"warning"'* ]]
then
  pass "aictl_warn bypass path does not emit warning"
else
  fail "aictl_warn bypass should not emit warning: got '${result}'"
fi

# Test: aictl_warn NIRMI+REASON appends a log event (ts, code, reason, cwd)
run_test
tmp_state=$(mktemp -d)
trap 'rm -rf "$tmp_state"' EXIT
XDG_STATE_HOME="$tmp_state" TIMVISHER_AGENT_NIRMI=1 TIMVISHER_AGENT_NIRMI_REASON="why we bypassed" \
  bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn --code test_logged --message m --command 'git log main..HEAD'" 2>/dev/null
log_file="$tmp_state/timvisher/wrappers/aictl-bypass/log.jsonl"
if [[ -f $log_file ]] && \
   grep -q '"code":"test_logged"' "$log_file" && \
   grep -q '"reason":"why we bypassed"' "$log_file" && \
   grep -q '"command":"git log main..HEAD"' "$log_file"
then
  pass "aictl_warn bypass writes JSONL log event"
else
  fail "aictl_warn bypass log: log='$(cat "$log_file" 2>/dev/null)'"
fi

# Test: aictl_warn with --flag syntax including reason and doc
run_test
result=$(bash -c "source '${funcs_dir}/aictl.bash'; aictl_warn --code tc --message m --reason 'why' --doc 'ref.md' --suggestion 's'" 2>&1 || true)
if [[ $result == *'"reason":"why"'* ]] && [[ $result == *'"doc":"ref.md"'* ]]
then
  pass "aictl_warn with reason and doc"
else
  fail "aictl_warn reason/doc: got '${result}'"
fi

echo ""
echo "Results: $((tests - failures))/${tests} passed"

if (( 0 < failures ))
then
  exit 1
fi
