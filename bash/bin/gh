#!/usr/bin/env bash

source ~/.functions/logging.bash ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

# Source aictl for structured agent messaging (with inline stubs fallback)
if [[ -f ~/.functions/aictl.bash ]]
then
  source ~/.functions/aictl.bash ||
    {
      echo "Unable to source aictl functions" >&2
      exit 1
    }
elif [[ -z ${_aictl_loaded:-} ]]
then
  aictl_die() {
    printf '{"type":"instruction","level":"error","code":"%s","message":"%s","retryable":false}\n' "$1" "$2" >&2
    exit 1
  }
fi

if [[ -n $TIMVISHER_AGENT ]]
then
  args=("$@")
  for ((i=0; i<${#args[@]}-1; i++))
  do
    if [[ ${args[i]} == repo && ${args[i+1]} == create ]]
    then
      aictl_die \
        --code "gh_repo_create_blocked" \
        --message "Agents must NEVER create repositories." \
        --reason "Repository creation is a human-only operation." \
        --suggestion "Ask the human to create the repository"
    fi
  done
fi

"$(brew --prefix)"/bin/gh "$@"
