#!/usr/bin/env bash

# Run claude one-shot with streaming progress output.
#
# Usage: claudeshot <prompt>
#        echo "prompt" | claudeshot
#        claudeshot review

set -o pipefail

SELF_DIR=$(cd "$(dirname "$0")" && pwd -P)
JQ_FILTER="${SELF_DIR}/../lib/format_stream_json.jq"

# shellcheck source=../lib/aishot_help.bash
source "${SELF_DIR}/../lib/aishot_help.bash"

# Reads prompt from stdin (caller is responsible for preamble via
# aishot make-prompt).
run_shot() {
    claude --verbose --dangerously-skip-permissions --output-format stream-json -p |
        jq --unbuffered -r --arg tz_offset "$(date +%z)" -f "$JQ_FILTER"
}

case "$1" in
    review)
        shift
        if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]
        then
            aishot_show_review_help claudeshot Claude
            exit 0
        fi
        aishot review make-prompt | run_shot
        ;;
    --help|-h)
        aishot_show_help claudeshot Claude
        exit 0
        ;;
    "")
        # No arg — read from stdin if piped, otherwise show help
        if [[ -t 0 ]]
        then
            aishot_show_help claudeshot Claude >&2
            exit 1
        fi
        aishot make-prompt | run_shot
        ;;
    *)
        echo "$1" | aishot make-prompt | run_shot
        ;;
esac
