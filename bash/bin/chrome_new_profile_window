#!/usr/bin/env bash

source "${HOME}/git/ide/bash/functions/logging.bash" ||
  {
    echo "Unable to source logging functins" >&2
    exit 1
  }

default_profile_email=tim.visher@gmail.com

profile_email=${1:-${default_profile_email}}

if [[ -z $profile_email ]]
then
  die "profile_email isn't set which is impossible"
fi

info 'Searching for Profile with Email ‘%s’' "$profile_email"

profile_directory=$(
  jq -r --arg email "$profile_email" '
       (.account_info // [])[].email
       | select($email == .)
       | input_filename
       | split("/")[-2]
     ' ~/Library/Application\ Support/Google/Chrome/*/Preferences
                 )

if [[ -z $profile_directory ]]
then
  die 'Unable to determine profile_directory'
fi

info 'Using profile_directory ‘%s’' "$profile_directory"

if ! [[ -d ~/Library/'Application Support'/Google/Chrome/"${profile_directory}" ]]
then
  die "Profile isn\'t a directory which is impossible? ‘%s’" "${profile_directory}"
fi

open -a 'Google Chrome' -n --args --profile-directory="$profile_directory"
