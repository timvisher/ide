#!/usr/bin/env bash

find "${TIMVISHER_GIT_HOME:-${HOME}/git}" -maxdepth 7 -type d -name '.git' -mtime "${1:--1w}" -exec stat --printf='%Y\0%n\0' '{}' \+ |
  while read -rd '' timestamp
        read -rd '' name
  do
    printf '%s\t%s\0' "$(date --date "@${timestamp}" '+%FT%T%z')" "$name"
  done |
  sort -zr |
  while read -rd '' x
  do
    printf '%s\n' "$x"
  done
