#!/usr/bin/env bash

# Install agent skills and configuration from source directories into
# ~/.agents/, then resolve symlinks for ~/.claude and ~/.codex.
#
# Usage:
#   timvisher_agents_install <dir>...
#
# Each <dir> is an "agent home root" — its contents mirror what should
# end up under $HOME for some agent. Recognized subpaths:
#
#   <dir>/.agents/skills/<name>     → ~/.agents/skills/<name>
#   <dir>/.agents/languages/<name>  → ~/.agents/languages/<name>
#   <dir>/.claude/hooks/<name>      → ~/.claude/hooks/<name>
#
# Typical layout in a config repo:
#   <repo>/ai/HOME/        — cross-agent home (skills, languages)
#   <repo>/ai/claude/HOME/ — Claude-specific home (hooks, etc.)
# Pass both as separate args.
#
# After installing, the following symlinks are created/verified:
#   - ~/AGENTS.md            → ~/git/ide/ai/HOME/AGENTS.md
#   - ~/.claude/CLAUDE.md    → ~/AGENTS.md
#   - ~/.claude/skills       → ~/.agents/skills
#   - ~/.codex/AGENTS.md     → ~/AGENTS.md
#   - ~/.codex/skills/<name> → ~/.agents/skills/<name>  (for each skill,
#                               preserving .system/)
#
# ~/.agents/ must be a real directory (not a symlink). If it is a symlink,
# the script will error and tell you to convert it first.

# shellcheck disable=SC1090
. ~/.functions/logging.bash

# Canonicalize a path without requiring it to exist.
# Uses Python as a portable fallback since macOS realpath lacks -m.
canon_path() {
  python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1"
}

# Preferred prefixes for symlink targets. When a target's canonical path
# lies under one of these prefixes (after resolving symlinks), rewrite the
# link to use the preferred form instead. This keeps installed symlinks
# stable across worktrees — e.g. `~/.config/timvisher/ide/...` rather than
# `~/git/DataDog/timvisher-ide-datadog-system-extensions/main/...`.
preferred_prefixes=(
  "${HOME}/.config/timvisher/ide"
  "${HOME}/git/ide"
)

# Given a path, return the preferred form if its canonical form lies under
# a preferred prefix; otherwise return the canonical form.
prefer_path() {
  local path=$1
  local canon
  canon=$(canon_path "$path")
  local pref
  for pref in "${preferred_prefixes[@]}"
  do
    [[ -d $pref ]] || continue
    local pref_canon
    pref_canon=$(canon_path "$pref")
    if [[ $canon == "$pref_canon" ]]
    then
      printf '%s\n' "$pref"
      return
    fi
    if [[ $canon == "${pref_canon}"/* ]]
    then
      printf '%s%s\n' "$pref" "${canon#"$pref_canon"}"
      return
    fi
  done
  printf '%s\n' "$canon"
}

require_python3() {
  if ! command -v python3 &>/dev/null
  then
    error 'python3 is required but not found in PATH'
    exit 1
  fi
}

errors=()

found_error() {
  errors+=("$1")
}

assert_not_symlink() {
  local path=$1
  if [[ -L $path ]]
  then
    found_error "'${path}' is a symlink (to '$(readlink "$path")'). Remove it and create a real directory first."
  fi
}

ensure_dir() {
  local path=$1
  if [[ ! -d $path ]]
  then
    mkdir -p "$path"
  fi
}

# Create or verify a symlink. Errors if target exists and points elsewhere.
# If the existing symlink resolves to the same file but its literal text
# differs from the desired text, the link is rewritten so it matches.
ensure_symlink() {
  local link=$1
  local target=$2

  if [[ -L $link ]]
  then
    local existing_resolved target_resolved
    local existing_raw link_dir
    existing_raw=$(readlink "$link")
    link_dir=$(dirname "$link")
    # Resolve the existing target relative to the link's parent directory
    if [[ $existing_raw == /* ]]
    then
      existing_resolved=$(canon_path "$existing_raw")
    else
      existing_resolved=$(canon_path "${link_dir}/${existing_raw}")
    fi
    # Resolve the desired target (may be relative to CWD)
    target_resolved=$(canon_path "$target")
    if [[ $existing_resolved == "$target_resolved" ]]
    then
      # Same underlying file. Update the literal text if it differs from
      # the desired (e.g., raw worktree path → preferred prefix).
      if [[ $existing_raw != "$target" ]]
      then
        rm "$link"
        ln -s "$target" "$link"
        info "Updated symlink '%s' → '%s' (was → '%s')" "$link" "$target" "$existing_raw"
      fi
    elif [[ ! -e $link ]]
    then
      # Dangling symlink — safe to replace
      rm "$link"
      ln -s "$target" "$link"
      info "Replaced dangling symlink '%s' → '%s'" "$link" "$target"
    else
      found_error "'${link}' resolves to '${existing_resolved}', not '${target_resolved}'"
    fi
  elif [[ -e $link ]]
  then
    found_error "'${link}' exists and is not a symlink"
  else
    ln -s "$target" "$link"
    info "Created symlink '%s' → '%s'" "$link" "$target"
  fi
}

do_install_from() {
  local dir=$1
  local found_something=false

  local skills_dir="${dir}/.agents/skills"
  if [[ -d $skills_dir ]]
  then
    found_something=true
    local skill
    for skill in "${skills_dir}"/*/
    do
      [[ -d $skill ]] || continue
      local name
      name=$(basename "$skill")
      # Remove trailing slash and canonicalize to absolute path so the
      # symlink target resolves correctly from ~/.agents/skills/
      skill=${skill%/}
      ensure_symlink "${HOME}/.agents/skills/${name}" "$(prefer_path "$skill")"
    done
  fi

  local languages_dir="${dir}/.agents/languages"
  if [[ -d $languages_dir ]]
  then
    found_something=true
    local lang
    for lang in "${languages_dir}"/*
    do
      [[ -f $lang ]] || continue
      local name
      name=$(basename "$lang")
      ensure_symlink "${HOME}/.agents/languages/${name}" "$(prefer_path "$lang")"
    done
  fi

  local claude_hooks_dir="${dir}/.claude/hooks"
  if [[ -d $claude_hooks_dir ]]
  then
    found_something=true
    if [[ ! -d ${HOME}/.claude ]]
    then
      # shellcheck disable=SC2088 # ~ is intentional in log message
      warn '~/.claude does not exist; skipping Claude hooks from %s' "$dir"
    else
      ensure_dir "${HOME}/.claude/hooks"
      local hook
      for hook in "${claude_hooks_dir}"/*
      do
        [[ -f $hook ]] || continue
        local name
        name=$(basename "$hook")
        ensure_symlink "${HOME}/.claude/hooks/${name}" "$(prefer_path "$hook")"
      done
    fi
  fi

  if [[ $found_something == false ]]
  then
    found_error "No .agents/skills/, .agents/languages/, or .claude/hooks/ directory found in '${dir}'"
  fi
}

do_resolve() {
  # ~/AGENTS.md → ~/git/ide/ai/HOME/AGENTS.md
  ensure_symlink "${HOME}/AGENTS.md" "$(prefer_path "${HOME}/git/ide/ai/HOME/AGENTS.md")"

  # ~/.claude/CLAUDE.md → ~/AGENTS.md
  if [[ -d ${HOME}/.claude ]]
  then
    ensure_symlink "${HOME}/.claude/CLAUDE.md" "$(prefer_path "${HOME}/AGENTS.md")"
    ensure_symlink "${HOME}/.claude/skills" "$(prefer_path "${HOME}/.agents/skills")"
  else
    # shellcheck disable=SC2088 # ~ is intentional in log message
    warn '~/.claude does not exist; skipping Claude symlinks'
  fi

  # ~/.codex/AGENTS.md → ~/AGENTS.md
  # ~/.codex/skills/<name> → ~/.agents/skills/<name> (preserving .system/)
  if [[ -d ${HOME}/.codex ]]
  then
    ensure_symlink "${HOME}/.codex/AGENTS.md" "$(prefer_path "${HOME}/AGENTS.md")"

    if [[ -d ${HOME}/.codex/skills ]]
    then
      local skill
      for skill in "${HOME}"/.agents/skills/*/
      do
        [[ -d $skill ]] || continue
        local name
        name=$(basename "$skill")
        # Remove trailing slash
        skill=${skill%/}
        ensure_symlink "${HOME}/.codex/skills/${name}" "$(prefer_path "${HOME}/.agents/skills/${name}")"
      done
    else
      # shellcheck disable=SC2088 # ~ is intentional in log message
      warn '~/.codex/skills does not exist; skipping Codex skill symlinks'
    fi
  else
    # shellcheck disable=SC2088 # ~ is intentional in log message
    warn '~/.codex does not exist; skipping Codex symlinks'
  fi
}

# --- main ---

if (( ${#} < 1 ))
then
  error 'Usage: timvisher_agents_install <dir>...'
  exit 1
fi

# Pre-flight: python3 is required for path canonicalization
require_python3

# Pre-flight: ~/.agents must be a real directory
assert_not_symlink "${HOME}/.agents"
assert_not_symlink "${HOME}/.agents/skills"
assert_not_symlink "${HOME}/.agents/languages"

if (( 0 < ${#errors[@]} ))
then
  for msg in "${errors[@]}"
  do
    error '%s' "$msg"
  done
  exit 1
fi

ensure_dir "${HOME}/.agents"
ensure_dir "${HOME}/.agents/skills"
ensure_dir "${HOME}/.agents/languages"

for dir in "$@"
do
  do_install_from "$dir"
done

do_resolve

if (( 0 < ${#errors[@]} ))
then
  error 'Errors encountered:'
  for msg in "${errors[@]}"
  do
    error '  %s' "$msg"
  done
  exit 1
fi

info 'Done'
