#!/usr/bin/env bash

# Run gemini one-shot with streaming progress output.
#
# Usage: geminishot <prompt>
#        echo "prompt" | geminishot
#        geminishot review

set -o pipefail

SELF_DIR=$(cd "$(dirname "$0")" && pwd -P)
JQ_FILTER="${SELF_DIR}/../lib/format_gemini_stream_json.jq"

# shellcheck source=../lib/aishot_help.bash
source "${SELF_DIR}/../lib/aishot_help.bash"

# Reads prompt from stdin.
run_shot() {
    gemini -y -p "" -o stream-json |
        jq --unbuffered -r --arg tz_offset "$(date +%z)" -f "$JQ_FILTER"
}

case "$1" in
    review)
        shift
        if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]
        then
            aishot_show_review_help geminishot Gemini
            exit 0
        fi
        aishot make-review-prompt | run_shot
        ;;
    --help|-h)
        aishot_show_help geminishot Gemini
        exit 0
        ;;
    "")
        # No arg — read from stdin if piped, otherwise show help
        if [[ -t 0 ]]
        then
            aishot_show_help geminishot Gemini >&2
            exit 1
        fi
        run_shot
        ;;
    *)
        echo "$1" | run_shot
        ;;
esac
