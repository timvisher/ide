#!/usr/bin/env bash

# Run codex one-shot with streaming progress output.
#
# Usage: codexshot <prompt>
#        echo "prompt" | codexshot
#        codexshot review

set -o pipefail

SELF_DIR=$(cd "$(dirname "$0")" && pwd -P)
JQ_FILTER="${SELF_DIR}/../lib/format_codex_stream_json.jq"

# shellcheck source=../lib/aishot_help.bash
source "${SELF_DIR}/../lib/aishot_help.bash"

# Reads prompt from stdin (caller is responsible for preamble via
# aishot make-prompt).
#
# Strips invalid UTF-8 sequences before handing to codex, which rejects
# non-UTF-8 stdin with "Failed to read prompt from stdin: input is not
# valid UTF-8". Diff hunks for files in legacy encodings trip this —
# notably AppleScript files saved as MacRoman, where the line-
# continuation glyph `¬` is the single byte 0xC2 (a UTF-8 lead byte
# expecting a continuation that never comes).
run_shot() {
    iconv -c -f UTF-8 -t UTF-8 |
        codex exec --full-auto --sandbox read-only --json - |
        jq --unbuffered -r --arg tz_offset "$(date +%z)" -f "$JQ_FILTER"
}

case "$1" in
    review)
        shift
        if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]
        then
            aishot_show_review_help codexshot Codex
            exit 0
        fi
        aishot review make-prompt | run_shot
        ;;
    --help|-h)
        aishot_show_help codexshot Codex
        exit 0
        ;;
    "")
        # No arg — read from stdin if piped, otherwise show help
        if [[ -t 0 ]]
        then
            aishot_show_help codexshot Codex >&2
            exit 1
        fi
        aishot make-prompt | run_shot
        ;;
    *)
        echo "$1" | aishot make-prompt | run_shot
        ;;
esac
