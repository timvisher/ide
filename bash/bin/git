#!/usr/bin/env bash

source ~/.functions/logging.bash ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

source ~/.functions/git.bash ||
  {
    echo "Unable to source git functions" >&2
    exit 1
  }

# Source aictl for structured agent messaging. If not installed yet
# (e.g. running from a worktree before install), define inline stubs.
if [[ -f ~/.functions/aictl.bash ]]
then
  source ~/.functions/aictl.bash ||
    {
      echo "Unable to source aictl functions" >&2
      exit 1
    }
fi
# Always define stubs if the function isn't available (handles missing
# file, exported _aictl_loaded without exported function, etc.)
if ! declare -F aictl_die &>/dev/null
then
  # Minimal stubs — parse --code/--message flags with positional fallback.
  aictl__stub_parse() {
    _sc="" _sm=""
    while (( 0 < $# )); do
      case "$1" in
        --code) _sc=$2; shift 2 ;;
        --message) _sm=$2; shift 2 ;;
        --*) shift 2 ;;
        *) if [[ -z $_sc ]]; then _sc=$1; elif [[ -z $_sm ]]; then _sm=$1; fi; shift ;;
      esac
    done
  }
  aictl_die() {
    aictl__stub_parse "$@"
    printf '{"type":"instruction","level":"error","code":"%s","message":"%s","retryable":false}\n' "$_sc" "$_sm" >&2
    exit 1
  }
  aictl_warn() {
    aictl__stub_parse "$@"
    if [[ -n ${TIMVISHER_AGENT_NIRMI:-} ]]
    then
      if [[ -z ${TIMVISHER_AGENT_NIRMI_REASON:-} ]]
      then
        printf '{"type":"instruction","level":"error","code":"aictl_bypass_missing_reason","message":"NIRMI=1 without TIMVISHER_AGENT_NIRMI_REASON. Bypass requires both.","retryable":false}\n' >&2
        exit 1
      fi
      printf '{"type":"instruction","level":"bypass","code":"%s","message":"Guardrail bypassed with logged reason."}\n' "$_sc" >&2
      return 0
    fi
    printf '{"type":"instruction","level":"warning","code":"%s","message":"%s","retryable":true}\n' "$_sc" "$_sm" >&2
    exit 1
  }
fi

real_git=$(resolve_next_git "${BASH_SOURCE[0]}") ||
  {
    echo "Unable to resolve next git binary in PATH" >&2
    exit 1
  }

if [[ -n $TIMVISHER_AGENT ]]
then
  subcommand=""
  skip_next=false
  end_of_opts=false

  for x in "$@"
  do
    if [[ -n $subcommand ]]
    then
      break
    fi

    if [[ $skip_next == true ]]
    then
      skip_next=false
      continue
    fi

    if [[ $end_of_opts == true ]]
    then
      subcommand=$x
      break
    fi

    if [[ $x == -- ]]
    then
      end_of_opts=true
      continue
    fi

    if [[ $x == -* ]]
    then
      case "$x" in
        -c|-C|--git-dir|--work-tree|--namespace|--super-prefix|--exec-path|--config-env)
          skip_next=true
          ;;
        --git-dir=*|--work-tree=*|--namespace=*|--super-prefix=*|--exec-path=*|--config-env=*)
          ;;
      esac
      continue
    fi

    subcommand=$x
  done

  if [[ $subcommand == commit ]]
  then
    commit_message=""
    commit_message_file=""
    skip_next=false
    last_opt=""

    for x in "$@"
    do
      if [[ $skip_next == true ]]
      then
        skip_next=false
        case "$last_opt" in
          -m|--message)
            commit_message+="${x}"$'\n'
            ;;
          -F|--file|-t|--template)
            commit_message_file="$x"
            ;;
        esac
        continue
      fi

      case "$x" in
        -m|--message|-F|--file|-t|--template)
          last_opt=$x
          skip_next=true
          ;;
        -m=*|--message=*)
          commit_message+="${x#*=}"$'\n'
          ;;
        -F=*|--file=*|-t=*|--template=*)
          commit_message_file="${x#*=}"
          ;;
      esac
    done

    if [[ -z $commit_message && -n $commit_message_file ]]
    then
      if [[ $commit_message_file == "-" ]]
      then
        aictl_die \
          --code "git_commit_stdin_unsupported" \
          --message "Agent git commit from stdin is not supported." \
          --doc "ai/HOME/.agents/skills/git/SKILL.md" \
          --suggestion "Use -m/--message or -F/--file with a real file path"
      fi
      if [[ -r $commit_message_file ]]
      then
        commit_message=$(cat "$commit_message_file")
      fi
    fi

    if [[ -z $commit_message ]]
    then
      aictl_die \
        --code "git_commit_no_message" \
        --message "Agent git commit must include a commit message with Co-authored-by trailer." \
        --doc "ai/HOME/.agents/skills/git/SKILL.md" \
        --suggestion "Use -m/--message or -F/--file to provide the message"
    fi

    required_trailer=""
    if [[ -n $TIMVISHER_CODEX ]]
    then
      required_trailer='Codex <codex@openai.com>'
    elif [[ -n $TIMVISHER_CLAUDE || -n $CLAUDECODE ]]
    then
      required_trailer='<noreply@anthropic.com>'
    elif [[ -n $TIMVISHER_GEMINI ]]
    then
      required_trailer='<noreply@google.com>'
    fi

    if [[ -n $required_trailer ]] &&
         ! printf '%s\n' "$commit_message" | grep -E -i -q "^Co-authored-by:[[:space:]].*${required_trailer}\$"
    then
      aictl_die \
        --code "git_commit_missing_trailer" \
        --message "Missing required Co-authored-by trailer matching: ${required_trailer}" \
        --reason "Agent commits must be attributed for auditability." \
        --doc "ai/HOME/.agents/skills/git/SKILL.md" \
        --suggestion "Add the trailer to your commit message"
    fi
  fi

  if [[ $subcommand == diff || $subcommand == log || $subcommand == rev-list ]]
  then
    range_guard__upstream_re='@\{u(pstream)?\}'
    range_guard__head_or_empty='^(HEAD)?$'

    # --- Per-arg range check: A..B / A...B embedded in a single arg ---
    #
    # Only inspects positional (non-flag) args, and stops at `--`. Flag
    # VALUES like `--format="%H..%s"` must not trigger the guard (they
    # contain `..` for benign reasons). Paths after `--` aren't refs.
    range_guard__single_arg_range_seen=false
    range_guard__past_double_dash=false
    for x in "$@"
    do
      if [[ $range_guard__past_double_dash == true ]]
      then
        continue
      fi
      if [[ $x == -- ]]
      then
        range_guard__past_double_dash=true
        continue
      fi
      if [[ $x == -* ]]
      then
        continue
      fi
      if [[ $x == *..* ]]
      then
        range_guard__single_arg_range_seen=true
        # Split on ... first (three-dot), then .. (two-dot)
        if [[ $x == *...* ]]
        then
          range_guard__lhs=${x%%...*}
          range_guard__rhs=${x#*...}
        else
          range_guard__lhs=${x%%..*}
          range_guard__rhs=${x#*..}
        fi

        # Valid range form: one side is @{u}/@{upstream}, the other is
        # empty (implied HEAD) or literal HEAD. Anything else is almost
        # certainly wrong for agents.
        range_guard__lhs_is_upstream=false
        range_guard__rhs_is_upstream=false
        [[ $range_guard__lhs =~ $range_guard__upstream_re ]] && range_guard__lhs_is_upstream=true
        [[ $range_guard__rhs =~ $range_guard__upstream_re ]] && range_guard__rhs_is_upstream=true

        if { [[ $range_guard__lhs_is_upstream == true ]] && [[ $range_guard__rhs =~ $range_guard__head_or_empty ]]; } ||
           { [[ $range_guard__rhs_is_upstream == true ]] && [[ $range_guard__lhs =~ $range_guard__head_or_empty ]]; }
        then
          # Valid form — verify @{u} actually resolves
          if ! "$real_git" rev-parse --verify '@{u}' >/dev/null 2>&1
          then
            aictl_die \
              --code "git_upstream_not_configured" \
              --message "@{u} does not resolve — this branch has no upstream tracking configured." \
              --suggestion "Ask the human what the upstream should be set to" \
              --suggestion "Once told, run: git branch --set-upstream-to=<remote>/<branch>"
          fi
        else
          aictl_die \
            --code "git_range_no_upstream_ref" \
            --message "You almost certainly didn't mean to use '${x}' if what you were looking for is this branch's diff." \
            --reason "Hardcoded refs break across rebases and branch renames. @{u} always resolves to the correct upstream. This form is common enough as an agent mistake that it's been promoted to a hard error." \
            --doc "ai/HOME/.agents/skills/git/references/git.md" \
            --suggestion "git diff @{u}...     (three-dot: changes on this branch only)" \
            --suggestion "git log @{u}...      (three-dot: commits on this branch only)"
        fi
      fi
    done

    # --- Multi-positional check: `diff A B`, `log X Y`, `rev-list A B` ---
    #
    # Only runs when no single-arg `..` range was already caught, so we
    # don't double-warn on `diff A..B C` (already handled above).
    #
    # Collects positional (non-flag) args after the subcommand, up to `--`.
    # A small set of common value-taking flags is handled; uncurated ones
    # in space-separated form (e.g., `--author Tim`) may cause a false
    # positive. Agents can bypass by switching to `--flag=value`.
    if [[ $range_guard__single_arg_range_seen == false ]]
    then
      range_guard__positionals=()
      range_guard__past_subcommand=false
      range_guard__past_double_dash=false
      range_guard__skip_next=false
      for x in "$@"
      do
        if [[ $range_guard__skip_next == true ]]
        then
          range_guard__skip_next=false
          continue
        fi
        if [[ $range_guard__past_double_dash == true ]]
        then
          continue
        fi
        if [[ $range_guard__past_subcommand == false ]]
        then
          case "$x" in
            -c|-C|--git-dir|--work-tree|--namespace|--super-prefix|--exec-path|--config-env)
              range_guard__skip_next=true
              ;;
          esac
          if [[ $x == "$subcommand" ]]
          then
            range_guard__past_subcommand=true
          fi
          continue
        fi
        if [[ $x == -- ]]
        then
          range_guard__past_double_dash=true
          continue
        fi
        case "$x" in
          # Common value-taking flags in space-separated form. Attached
          # `--flag=value` form is safe — it's a single token starting
          # with `-`, so the `-*` catch below handles it.
          #
          # -S/-G are pickaxe flags (git log -S some_func HEAD). -O is
          # --orderfile. Missing one here means its value gets counted as
          # a positional and the guard fires a false positive.
          -n|-L|-S|-G|-O|--max-count|--skip|--since|--after|--until|--before|\
          --author|--committer|--grep|--format|--pretty|--date|--encoding)
            range_guard__skip_next=true
            continue
            ;;
          -*)
            continue
            ;;
        esac
        range_guard__positionals+=("$x")
      done

      if (( 2 <= ${#range_guard__positionals[@]} ))
      then
        range_guard__has_upstream=false
        for range_guard__p in "${range_guard__positionals[@]}"
        do
          if [[ $range_guard__p =~ $range_guard__upstream_re ]]
          then
            range_guard__has_upstream=true
            break
          fi
        done

        if [[ $range_guard__has_upstream == false ]]
        then
          aictl_die \
            --code "git_range_no_upstream_ref" \
            --message "You almost certainly didn't mean to use '${range_guard__positionals[*]}' as a revision range if what you were looking for is this branch's diff." \
            --reason "Hardcoded refs break across rebases and branch renames. @{u} always resolves to the correct upstream. 'git diff A B' and 'git log A B' are the space-separated equivalents of 'A..B' — use @{u} instead. This form is common enough as an agent mistake that it's been promoted to a hard error." \
            --doc "ai/HOME/.agents/skills/git/references/git.md" \
            --suggestion "git diff @{u}...     (three-dot: changes on this branch only)" \
            --suggestion "git log @{u}...      (three-dot: commits on this branch only)" \
            --suggestion "If these were meant to be file paths, put them after '--'"
        fi
      fi
    fi
  fi

  if [[ $subcommand == add ]]
  then
    for x in "$@"
    do
      if [[ $x == -f || $x == --force ]]
      then
        aictl_die \
          --code "git_add_force_blocked" \
          --message "Agents must NEVER use 'git add -f'. Files ignored by .gitignore are ignored for a reason." \
          --suggestion "Ask the human to add the file manually if it should be tracked"
      fi
    done
  fi

  if [[ $subcommand == worktree ]]
  then
    # Detect `git worktree add` — check only the sub-subcommand position
    # (the first non-flag arg after "worktree"), not all args, to avoid
    # false positives on branches/paths literally named "add".
    wt_subcmd=""
    wt_past_worktree=false
    for x in "$@"
    do
      if [[ $wt_past_worktree == true ]]
      then
        if [[ $x != -* ]]
        then
          wt_subcmd=$x
          break
        fi
        continue
      fi
      if [[ $x == worktree ]]
      then
        wt_past_worktree=true
      fi
    done

    if [[ $wt_subcmd == add && -z ${TIMVISHER_NTMUX:-} ]]
    then
      wt_suggestions=()
      wt_suggestions+=(--suggestion "source ~/.bashrc && ntmux3 -d org/repo/branch-name")

      org_repo=""
      if command -v timvisher_git &>/dev/null
      then
        wt_org=$(timvisher_git info .org 2>/dev/null) || true
        wt_repo=$(timvisher_git info .repo 2>/dev/null) || true
        if [[ -n ${wt_org:-} && -n ${wt_repo:-} ]]
        then
          org_repo="${wt_org}/${wt_repo}"
          wt_suggestions+=(--suggestion "Current repo is ${org_repo} — example: source ~/.bashrc && ntmux3 -d ${org_repo}/your-branch-name")
        fi
      fi

      wt_suggestions+=(--suggestion "Use timvisher_git info .org and timvisher_git info .repo to derive the org/repo prefix")

      aictl_die \
        --code "git_worktree_add_blocked" \
        --message "Agents must use ntmux3 for worktree creation, not 'git worktree add'." \
        --reason "ntmux3 handles cache management, tmux session setup, and worktree directory layout. Raw git worktree add bypasses all of this." \
        --doc "ai/HOME/.agents/skills/worktree/SKILL.md" \
        "${wt_suggestions[@]}"
    fi
  fi

  if [[ $subcommand == push || $subcommand == send-pack ]]
  then
    # Narrow allow-path: bd auto-syncs its issue database to a Dolt remote
    # by shelling out to `git push refs/dolt/...`. Every bd command (create,
    # update, close, …) can trigger this, so we need to permit it without
    # opening the door to general pushes.
    #
    # Two conditions, both required:
    #   1. A refs/dolt/ token in the push args (so the push is to Dolt
    #      refs, not a regular branch).
    #   2. A 'bd' process in the ancestor chain (so the push originated
    #      inside bd, not from an agent typing refs/dolt/ at random).
    push_guard__is_bd_dolt() {
      # --- Refspec gate ---
      # Parse push args as git would: skip flags (incl. the one value-taking
      # flag `-o` in space form; the rest use attached `--flag=value`).
      # First positional is the remote; every other positional must be a
      # refspec containing refs/dolt/. refs/dolt/ appearing ONLY inside a
      # flag value (e.g. `--force-with-lease=refs/dolt/data:abc`) is not
      # sufficient — a real refspec positional must be present.
      local arg
      local past_subcommand=false
      local past_double_dash=false
      local skip_next=false
      local -a positionals=()
      for arg in "$@"
      do
        if [[ $skip_next == true ]]
        then
          skip_next=false
          continue
        fi
        if [[ $past_double_dash == true ]]
        then
          continue
        fi
        if [[ $past_subcommand == false ]]
        then
          if [[ $arg == "$subcommand" ]]
          then
            past_subcommand=true
          fi
          continue
        fi
        if [[ $arg == -- ]]
        then
          past_double_dash=true
          continue
        fi
        case "$arg" in
          -o)
            skip_next=true
            continue
            ;;
          -*)
            continue
            ;;
        esac
        positionals+=("$arg")
      done

      # Need remote + ≥1 refspec. Bare `git push` (no refspec) cannot be
      # scoped to dolt — deny.
      if (( ${#positionals[@]} < 2 ))
      then
        return 1
      fi

      # positionals[0] is the remote (could be a URL, file path, or nickname);
      # not inspected. Every remaining positional must mention refs/dolt/ —
      # this catches mixed-refspec pushes like `push origin main refs/dolt/x:y`.
      local i
      for (( i=1; i<${#positionals[@]}; i++ ))
      do
        if [[ ${positionals[$i]} != *"refs/dolt/"* ]]
        then
          return 1
        fi
      done

      # --- Ancestor gate ---
      # One `ps -axww` — per-hop `ps -p` would fork per ancestor (3–10ms
      # each on macOS); single call is ~10–30ms regardless of depth. `-ww`
      # disables column-width truncation so long command lines don't mask
      # a real `bd` token.
      local -A parent_of args_of
      local pid ppid cmd
      while read -r pid ppid cmd
      do
        parent_of[$pid]=$ppid
        args_of[$pid]=$cmd
      done < <(ps -o pid=,ppid=,args= -axww 2>/dev/null)

      # Walk from $PPID up to depth 20 (login→tmux→bash→bd→git is 5 deep;
      # 20 is ample and caps pathological cycles from pid reuse).
      local depth=0
      pid=$PPID
      while (( depth < 20 )) && [[ -n ${pid:-} && $pid != 0 && $pid != 1 ]]
      do
        # Only argv positions 0 and 1 count — position 0 for native binaries
        # (real bd: `/opt/homebrew/bin/bd …`) and position 1 for shebang
        # scripts (macOS `ps` renders these as `interpreter /path/to/script …`,
        # putting the script path at argv[1]). Restricting to these two
        # positions rejects false positives from `bd` appearing as a regular
        # argument further along the command line.
        local -a toks=()
        read -ra toks <<< "${args_of[$pid]:-}"
        local j
        for (( j=0; j<${#toks[@]} && j<2; j++ ))
        do
          if [[ ${toks[$j]##*/} == bd ]]
          then
            return 0
          fi
        done
        pid=${parent_of[$pid]:-}
        (( depth++ ))
      done
      return 1
    }

    if ! push_guard__is_bd_dolt "$@"
    then
      aictl_die \
        --code "git_push_blocked" \
        --message "Agents must NEVER push to remotes. This is a non-negotiable safety rule." \
        --reason "Remote mutations are human-only operations." \
        --doc "ai/HOME/.agents/skills/git/SKILL.md" \
        --suggestion "Ask the human to run 'git push'"
    fi
  fi
fi

# --- Upstream tracking guard ---
# Detect when a branch's upstream config is unexpectedly dropped.
# A cookie file (x.upstream-configured) latches the fact that an upstream
# was once observed. If the cookie exists but upstream is gone, something
# broke it — die loudly.

upstream_guard__toplevel=""
upstream_guard__branch=""
upstream_guard__cookie=""
upstream_guard__had_upstream=""

# Extract leading git global flags (-C, --git-dir, --work-tree) so the
# guard checks the TARGETED repo, not the CWD, when these flags are present.
upstream_guard__global_flags=()

upstream_guard__extract_global_flags() {
  upstream_guard__global_flags=()
  local skip_next=false
  for arg in "$@"
  do
    if [[ $skip_next == true ]]
    then
      upstream_guard__global_flags+=("$arg")
      skip_next=false
      continue
    fi
    case "$arg" in
      -C|--git-dir|--work-tree)
        upstream_guard__global_flags+=("$arg")
        skip_next=true
        ;;
      --git-dir=*|--work-tree=*)
        upstream_guard__global_flags+=("$arg")
        ;;
      -*)
        ;;
      *)
        # First non-flag argument is the subcommand; stop scanning
        break
        ;;
    esac
  done
}

upstream_guard__pre() {
  upstream_guard__extract_global_flags "$@"

  upstream_guard__toplevel=$("$real_git" "${upstream_guard__global_flags[@]}" rev-parse --show-toplevel 2>/dev/null) || return 0
  upstream_guard__branch=$("$real_git" "${upstream_guard__global_flags[@]}" rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0

  # Detached HEAD — nothing to guard
  if [[ $upstream_guard__branch == "HEAD" ]]
  then
    upstream_guard__toplevel=""
    return 0
  fi

  upstream_guard__cookie="${upstream_guard__toplevel}/x.upstream-configured"
  upstream_guard__had_upstream=$("$real_git" "${upstream_guard__global_flags[@]}" config "branch.${upstream_guard__branch}.remote" 2>/dev/null) || true

  if [[ -n $upstream_guard__had_upstream ]]
  then
    # Upstream is set — ensure cookie exists
    if [[ ! -e $upstream_guard__cookie ]]
    then
      touch "$upstream_guard__cookie"
    fi
  elif [[ -e $upstream_guard__cookie ]]
  then
    # Cookie exists but upstream is gone — something already broke it
    local agent_msg=""
    if [[ -n ${TIMVISHER_AGENT:-} ]]
    then
      agent_msg="

AGENT: STOP what you are doing immediately. Report to the human what
actions you were just taking that resulted in this branch losing its
upstream tracking configuration. Do NOT attempt to fix this yourself."
    fi

    warn "UPSTREAM TRACKING DROPPED!

Branch '%s' in '%s' previously had an upstream configured
(x.upstream-configured cookie exists) but branch.%s.remote is now unset.

Investigate what removed it. To reset, delete:
  %s

git command that triggered this check: git %s%s" \
      "$upstream_guard__branch" \
      "$upstream_guard__toplevel" \
      "$upstream_guard__branch" \
      "$upstream_guard__cookie" \
      "$*" \
      "$agent_msg"
  fi
}

upstream_guard__post() {
  # Only check if we had a toplevel and branch to guard
  if [[ -z $upstream_guard__toplevel ]]
  then
    return 0
  fi

  local upstream_after
  upstream_after=$("$real_git" "${upstream_guard__global_flags[@]}" config "branch.${upstream_guard__branch}.remote" 2>/dev/null) || true

  if [[ -n $upstream_guard__had_upstream ]] && [[ -z $upstream_after ]]
  then
    local log_file="${HOME}/.local/state/git-upstream-dropped.log"
    mkdir -p "$(dirname "$log_file")"
    printf '%s ppid=%s branch=%s toplevel=%s command: git %s\n' \
      "$(date -u '+%FT%T%z')" \
      "$$/$PPID" \
      "$upstream_guard__branch" \
      "$upstream_guard__toplevel" \
      "$*" >> "$log_file"

    local agent_msg=""
    if [[ -n ${TIMVISHER_AGENT:-} ]]
    then
      agent_msg="

AGENT: STOP what you are doing immediately. Report to the human what
actions you were just taking that resulted in this branch losing its
upstream tracking configuration. Do NOT attempt to fix this yourself."
    fi

    warn "UPSTREAM TRACKING DROPPED by this command!

Branch '%s' in '%s' had upstream '%s' before this command ran,
but branch.%s.remote is now unset.

Offending command: git %s

Logged to: %s%s" \
      "$upstream_guard__branch" \
      "$upstream_guard__toplevel" \
      "$upstream_guard__had_upstream" \
      "$upstream_guard__branch" \
      "$*" \
      "$log_file" \
      "$agent_msg"
  fi
}

upstream_guard__pre "$@"

"$real_git" "$@"
upstream_guard__rc=$?

upstream_guard__post "$@"

exit $upstream_guard__rc
