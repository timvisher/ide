#!/usr/bin/env bash

sources=(
  https://github.com/octocat/hello-world/pull/1
  https://github.com/octocat/hello-world/tree/test/never-close
  https://github.com/octocat/hello-world
  https://github.com/Octocat/hello-world
  octocat/hello-world
  octocat/hello-world/test/never-close
  octocat/hello-world/test/always-only-local
)

source "${HOME}/.functions/logging.bash" ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

for source in "${sources[@]}"
do
  printf 'test: '%s'\n' "$source"
  printf 'result: '%s'\n' "$(timvisher_git clone "$source")" ||
    die "Unable to clone '${source}'"
done
