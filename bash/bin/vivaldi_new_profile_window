#!/usr/bin/env bash

source "${HOME}/.functions/logging.bash" ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

config_file="${HOME}/.config/timvisher/ide/vivaldi-profile-name"

if [[ -n $1 ]] && [[ $1 != -* ]]
then
  profile_name=${1}
  shift
elif [[ -r $config_file ]]
then
  profile_name=$(< "$config_file")
fi

if [[ -z $profile_name ]]
then
  die 'No profile name: pass as argument or set in '%s'' "$config_file"
fi

info 'Searching for Profile with Name '%s'' "$profile_name"

profile_directory=$(
  jq -r --arg name "$profile_name" '
       .profile.info_cache | to_entries[]
       | select(.value.name == $name)
       | .key
     ' ~/Library/Application\ Support/Vivaldi/Local\ State |
    head -1
                 )

if [[ -z $profile_directory ]]
then
  die 'Unable to determine profile_directory'
fi

info 'Using profile_directory '%s'' "$profile_directory"

if ! [[ -d ~/Library/'Application Support'/Vivaldi/"${profile_directory}" ]]
then
  die 'Profile is not a directory which is impossible? '%s'' "${profile_directory}"
fi

open -a Vivaldi -n --args --profile-directory="$profile_directory" "$@"
