#!/usr/bin/env bash

# Worktree-based git clone/worktree manager.
# Uses separate cache/live roots.

# shellcheck source=/dev/null
source ~/.functions/logging.bash ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

SELF_DIR=$(cd "$(dirname "$0")" && pwd -P)
config_dir=${XDG_CONFIG_HOME:-${HOME}/.config}/timvisher/ide

# Migrate old cache root on first use
old_cache_root=${HOME}/.cache/timvisher_EXP_git_worktrees
new_cache_root=${HOME}/.cache/timvisher_git_worktrees
if [[ -d $old_cache_root && ! -d $new_cache_root ]]
then
  warn "Migrating cache '%s' → '%s'" "$old_cache_root" "$new_cache_root"
  mv "$old_cache_root" "$new_cache_root" ||
    die "Unable to migrate cache '%s' → '%s'" "$old_cache_root" "$new_cache_root"

  # Rewrite worktree .git files that reference the old cache path
  live_dir=${TIMVISHER_GIT_HOME:-${HOME}/git}
  shopt -s globstar nullglob
  for gitfile in "$live_dir"/**/.git
  do
    [[ -f $gitfile ]] || continue
    contents=$(< "$gitfile")
    case $contents in
      *"$old_cache_root"*)
        new_contents=${contents//$old_cache_root/$new_cache_root}
        printf '%s\n' "$new_contents" > "$gitfile"
        warn "  Rewrote '%s'" "$gitfile"
        ;;
    esac
  done
  shopt -u globstar nullglob
elif [[ -d $new_cache_root && ! -d $old_cache_root ]]
then
  # Cache already migrated but worktree .git files may still reference old path.
  # Run a one-shot repair: check a sentinel file to avoid re-scanning every time.
  sentinel=${new_cache_root}/.gitfile_migration_done
  if [[ ! -f $sentinel ]]
  then
    live_dir=${TIMVISHER_GIT_HOME:-${HOME}/git}
    repaired=0
    shopt -s globstar nullglob
    for gitfile in "$live_dir"/**/.git
    do
      [[ -f $gitfile ]] || continue
      contents=$(< "$gitfile")
      case $contents in
        *"$old_cache_root"*)
          new_contents=${contents//$old_cache_root/$new_cache_root}
          printf '%s\n' "$new_contents" > "$gitfile"
          warn "Repaired stale path in '%s'" "$gitfile"
          repaired=1
          ;;
      esac
    done
    shopt -u globstar nullglob
    if (( repaired ))
    then
      warn "Worktree .git files repaired after cache migration"
    fi
    : > "$sentinel"
  fi
fi

repo_trunks_dir=${new_cache_root}/repo_trunks
live_repo_dir=${TIMVISHER_GIT_HOME:-${HOME}/git}
hooks_dir=${config_dir}/bash/bin/timvisher_git_hooks

# Load org aliases from config file
typeset -A org_aliases
org_aliases_file=${config_dir}/git_org_aliases
if [[ -r $org_aliases_file ]]
then
  while IFS= read -r line || [[ -n $line ]]
  do
    [[ -z $line ]] && continue
    [[ $line == \#* ]] && continue
    key=${line%%=*}
    value=${line#*=}
    org_aliases[$key]=$value
  done < "$org_aliases_file"
fi

# Load GitHub user aliases (one per line).  The first entry is the
# primary user; others are alternates (e.g. work accounts).
# Replaces the old single-value git_fork_user file.
github_user_aliases=()
github_user_aliases_file=${SELF_DIR}/timvisher_git.config/github_user_aliases
if [[ -r $github_user_aliases_file ]]
then
  while IFS= read -r line || [[ -n $line ]]
  do
    [[ -z $line ]] && continue
    [[ $line == \#* ]] && continue
    github_user_aliases+=("$line")
  done < "$github_user_aliases_file"
fi
# Backwards compat: fall back to git_fork_user if aliases file is absent.
if (( ${#github_user_aliases[@]} < 1 ))
then
  fork_user_file=${config_dir}/git_fork_user
  if [[ -r $fork_user_file ]]
  then
    local_fork_user=$(< "$fork_user_file")
    local_fork_user=${local_fork_user%$'\n'}
    [[ -n $local_fork_user ]] && github_user_aliases+=("$local_fork_user")
  fi
fi

is_savannah_source() {
  [[ $1 == *git.savannah.gnu.org* ]]
}

savannah_repo_name() {
  local source=$1

  is_savannah_source "$source" || return 1

  local repo=${source##*/}
  repo=${repo%/}
  repo=${repo%.git}

  [[ -n $repo ]] || return 1

  printf '%s' "$repo"
}

normalize_savannah_url() {
  local source=$1
  local url=${source%/}

  if [[ $url != *.git ]]; then
    url="${url}.git"
  fi

  printf '%s' "$url"
}

mkdir -p "$repo_trunks_dir" "$live_repo_dir" ||
  die "Unable to create cache/live roots"

get_org() {
  local source=$1 org

  case $source in
    *git.savannah.gnu.org*)
      org=gnu
      ;;
    https://github.com/*/*)
      org=${source#https://github.com/}
      org=${org%%/*}
      ;;
    git@github.com:*/*)
      org=${source#git@github.com:}
      org=${org%%/*}
      ;;
    */*)
      org=${source%%/*}
      ;;
    *)
      die "get_org: Unsupported source ‘${source}’"
      ;;
  esac

  if [[ -z $org ]]
  then
    die "get_org: Unable to extract org from '${source}'"
  fi

  printf '%s' "${org_aliases[${org}]:-${org}}"
}

get_repo() {
  local source=$1 repo

  case $source in
    *git.savannah.gnu.org*)
      repo=$(savannah_repo_name "$source") ||
        die "get_repo: Unable to parse repo from '${source}'"
      ;;
    https://github.com/*/*)
      repo=${source#https://github.com/*/}
      repo=${repo%%/*}
      ;;
    git@github.com:*/*)
      repo=${source#git@github.com:*/}
      repo=${repo%%/*}
      repo=${repo%%.git}
      ;;
    */*)
      repo=${source#*/}
      repo=${repo%%/*}
      ;;
    *)
      die "get_repo: Unsupported source ‘${source}’"
      ;;
  esac

  printf '%s' "$repo"
}

normalize_pr_url() {
  local source=$1

  if [[ $source =~ ^(https://github.com/[^/]+/[^/]+/pull/[0-9]+) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi

  printf '%s' "$source"
}

pr_head_ref_name() {
  local source=$1 head_ref

  command -v gh >/dev/null 2>&1 || return 1

  source=$(normalize_pr_url "$source")
  head_ref=$(gh pr view "$source" --json headRefName --jq .headRefName 2>/dev/null) ||
    return 1

  [[ -n $head_ref ]] || return 1

  printf '%s' "$head_ref"
}

pr_number_from_url() {
  local source=$1

  source=$(normalize_pr_url "$source")

  if [[ $source =~ /pull/([0-9]+)$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

pr_base_repo_spec() {
  local source=$1

  source=$(normalize_pr_url "$source")

  if [[ $source =~ ^https://github.com/([^/]+/[^/]+)/pull/[0-9]+$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

pr_head_repo_spec() {
  local source=$1 head_repo_spec

  command -v gh >/dev/null 2>&1 || return 1

  source=$(normalize_pr_url "$source")
  head_repo_spec=$(gh pr view "$source" --json headRepository,headRepositoryOwner \
    --jq '.headRepositoryOwner.login + "/" + .headRepository.name' 2>/dev/null) ||
    return 1

  # GitHub returns null for headRepository.name when the fork has been
  # deleted.  jq renders "owner/" + null as "owner/" — reject that.
  [[ -n $head_repo_spec && $head_repo_spec != */ ]] || return 1

  printf '%s' "$head_repo_spec"
}

# Look up the preferred fork user for a given parent org/repo.
# Returns the preferred user on stdout, or fails silently.
preferred_fork_user_for() {
  local parent_spec=$1
  local parent_org=${parent_spec%%/*}
  local parent_repo=${parent_spec#*/}
  local pref_file="${SELF_DIR}/timvisher_git.config/${parent_org}/${parent_repo}/preferred_fork_user"
  if [[ -r $pref_file ]]
  then
    local user
    user=$(< "$pref_file")
    user=${user%$'\n'}
    [[ -n $user ]] && printf '%s' "$user"
  fi
}

# Find a fork of parent_spec owned by one of our github_user_aliases
# that we have push access to.  Checks preferred_fork_user first,
# then remaining aliases in order.  Prints the fork spec on stdout.
find_pushable_fork() {
  local parent_spec=$1
  local repo_name=${parent_spec#*/}

  # Build ordered alias list: preferred first, then the rest.
  local ordered_aliases=()
  local preferred
  preferred=$(preferred_fork_user_for "$parent_spec") || true
  if [[ -n $preferred ]]
  then
    ordered_aliases+=("$preferred")
  fi
  local alias
  for alias in "${github_user_aliases[@]}"
  do
    [[ $alias == "$preferred" ]] && continue
    ordered_aliases+=("$alias")
  done

  local candidate
  for candidate in "${ordered_aliases[@]}"
  do
    local candidate_spec="${candidate}/${repo_name}"
    local candidate_info
    candidate_info=$(gh api "/repos/${candidate_spec}" --jq '{
      push: .permissions.push,
      parent: (if .fork then .parent.full_name else "" end)
    }' 2>/dev/null) || continue
    local push_access candidate_parent
    push_access=$(printf '%s' "$candidate_info" | jq -r '.push // false') || continue
    candidate_parent=$(printf '%s' "$candidate_info" | jq -r '.parent // empty') || continue
    if [[ $push_access == true && $candidate_parent == "$parent_spec" ]]
    then
      printf '%s' "$candidate_spec"
      return 0
    fi
  done

  return 1
}

# Probe GitHub for a repo's parent fork.  Prints the parent spec on
# stdout (e.g. "gastownhall/beads") if `<spec>` is a fork; prints
# nothing for non-forks or when `gh` is unavailable / unauthenticated.
# Always exits 0 — callers treat empty output as "not a fork".
probe_fork_parent() {
  local spec=$1
  command -v gh >/dev/null 2>&1 || return 0
  command gh api "/repos/${spec}" --jq '.parent.full_name // empty' 2>/dev/null || true
}

# Safely remove the upstream remote only when no branches track it.
# In a worktree setup all worktrees share remotes; removing upstream
# would strip branch.*.remote=upstream from branches in other worktrees.
safe_remove_upstream() {
  local real_git
  real_git="$(brew --prefix)"/bin/git

  local branches_tracking_upstream
  branches_tracking_upstream=$("$real_git" config --get-regexp '^branch\..*\.remote$' 2>/dev/null | grep ' upstream$' || true)
  if [[ -z $branches_tracking_upstream ]]
  then
    git remote remove upstream 2>/dev/null || true
  else
    info "Keeping 'upstream' remote: other branches still track it"
  fi
}

upstream_override_for_repo() {
  local repo_spec=$1 repo_name override_file line key value override

  repo_name=${repo_spec##*/}

  if [[ -r .upstream.repo ]]; then
    while IFS= read -r line || [[ -n $line ]]; do
      [[ -z $line ]] && continue
      [[ $line == \#* ]] && continue
      override=$line
      break
    done < .upstream.repo
  fi

  if [[ -z $override ]]; then
    override_file=${XDG_CONFIG_HOME:-${HOME}/.config}/timvisher/ide/upstream_overrides
    if [[ -r $override_file ]]; then
      while IFS= read -r line || [[ -n $line ]]; do
        [[ -z $line ]] && continue
        [[ $line == \#* ]] && continue
        key=${line%%=*}
        value=${line#*=}
        if [[ $key == "$repo_spec" || $key == "$repo_name" ]]; then
          override=$value
          break
        fi
      done < "$override_file"
    fi
  fi

  [[ -n $override ]] || return 1
  printf '%s' "$override"
}

maybe_execute_hook() {
  local org=$1 repo=$2 hook=$3

  [[ -n $org ]] || die 'org is unset'
  [[ -n $repo ]] || die 'repo is unset'
  [[ -n $hook ]] || die 'hook is inset'

  local full_hook=${hooks_dir}/${org}/${repo}/${hook}

  if [[ -x $full_hook ]]; then
    "$full_hook" >&2
  fi
}

# Die if a `/`-separated path or shorthand contains `.git` or `_git`
# as a path component.  Used to catch internal bugs that leak `.git`
# into otherwise-clean worktree paths (see main-57o, main-68h); in
# those regressions sanitize_branch_name silently turned the leaked
# `.git` into `_git` and spawned spurious worktrees.  This guard
# makes the next such regression fail loudly instead.
#
# `_git` is rejected because it's a sanitization artifact, not a
# legitimate branch component.  sanitize_branch_name converts a
# leading `.` in any path component to `_`, so `.git/<anything>`
# becomes `_git/<anything>` — the only way `_git/` legitimately
# appears.  Enforcing this invariant here lets sweep_bogus_worktrees
# safely delete any `_git/...` branches/worktrees it finds without
# risk of removing user data.
#
# Callers that genuinely accept user-supplied `.git` in branch names
# (e.g. tree URLs) should NOT use this — it's for internal-derived
# paths only.
#
# Known constraint: ensure_worktree applies this guard to its source
# argument, so user-supplied source paths whose parent contains a
# literal `.git` component (unusual but possible: e.g.
# `~/proj/.git/foo`) will be rejected. There is no escape hatch — the
# rationale is that any `.git` component in an internal-derived path
# indicates a bug, and refusing such inputs at the boundary is safer
# than letting them flow into worktree creation. Users with this
# layout should symlink to a clean path or restructure.
die_if_git_component() {
  local context=$1
  local path=$2
  case $path in
    .git|.git/*|*/.git|*/.git/*|_git|_git/*|*/_git|*/_git/*)
      die "%s: refusing to proceed — '.git' or '_git' appeared as a path component in '%s'. This is an internal bug; see main-6x3." \
        "$context" "$path"
      ;;
  esac
}

# Sweep worktrees registered in the given cache whose paths contain
# `/_git/` or `/.git/` as a path component — always bogus (remnants of
# the main-57o regression's sanitize_branch_name laundering, or live
# worktrees created under a non-bare cache's `.git/` dir before the
# main-68h migration).  Also deletes any local `_git/...` branches,
# which can only exist as the laundered form of `.git/...`.
#
# Safe to delete unconditionally: die_if_git_component now rejects
# `_git` as a path component at branch/worktree creation, so any
# `_git/...` branch present in a cache is residue from the regression
# and cannot be live legitimate work.
#
# Cheap: ~40ms per cache on a typical setup.  Safe to call eagerly.
sweep_bogus_worktrees_in_cache() {
  local cache_dir=$1

  [[ -d $cache_dir ]] || return 0

  local worktrees
  worktrees=$(command git -C "$cache_dir" worktree list --porcelain 2>/dev/null) || return 0

  local wt_path
  while IFS= read -r wt_path
  do
    [[ -n $wt_path ]] || continue
    info "sweep_bogus_worktrees_in_cache: removing bogus worktree '%s' from cache '%s'" \
      "$wt_path" "$cache_dir"
    command git -C "$cache_dir" worktree remove --force "$wt_path" >&2 2>/dev/null ||
      command git -C "$cache_dir" worktree prune >&2 2>/dev/null || true
  # Pattern requires `/` before the `_git`/`.git` component because
  # `worktree list --porcelain` always emits absolute paths (per git docs)
  # — so relative paths starting with `_git/` cannot occur here.
  done < <(grep -E '^worktree .*/(_git|\.git)(/|$)' <<<"$worktrees" | sed 's/^worktree //')

  local branch
  while IFS= read -r branch
  do
    [[ -n $branch ]] || continue
    info "sweep_bogus_worktrees_in_cache: deleting bogus local branch '%s'" "$branch"
    command git -C "$cache_dir" branch -D "$branch" >&2 2>/dev/null || true
  done < <(command git -C "$cache_dir" for-each-ref --format='%(refname:short)' 'refs/heads/_git/**' 2>/dev/null)
}

# Sweep bogus worktrees across every trunk cache under repo_trunks_dir.
# Used as a cross-cache self-heal at entry points that care about
# global state (e.g. timvisher_dev_ci startup).
#
# The `*/*` glob hardcodes the documented `<org>/<repo>` layout under
# repo_trunks_dir.  If that layout ever grows additional nesting,
# generalize via `find -mindepth 2 -maxdepth N -type d` rather than
# extending the glob — globbing arbitrary depth in bash is awkward.
sweep_bogus_worktrees_in_all_caches() {
  local cache_dir
  for cache_dir in "${repo_trunks_dir}"/*/*
  do
    [[ -d $cache_dir ]] || continue
    sweep_bogus_worktrees_in_cache "$cache_dir"
  done
}

# Migrate an existing non-bare trunk cache in-place to a bare layout.
#
# Trunk caches are supposed to be bare.  A past regression in cache_trunk
# (see main-57o) created them via `git clone`, leaving a non-bare layout
# with a `.git` subdir and a checked-out working tree.  This function
# brings such caches back into the expected shape:
#
#   1. remove the cache's own working tree files (not .git/)
#   2. flatten <cache>/.git/* into <cache>/
#   3. set core.bare=true
#   4. `git worktree repair` to re-point live linked worktrees at the
#      new gitdir layout (<cache>/worktrees/<name> instead of
#      <cache>/.git/worktrees/<name>)
#
# Idempotent: if the cache is already bare, the conversion path is a
# no-op, but the heal pass (ensure_worktrees_not_poisoned_by_bare) still
# runs so that caches an earlier buggy migration left in a poisoned
# state self-heal on next access.
migrate_cache_to_bare_if_needed() {
  local cache_dir=$1

  [[ -d $cache_dir ]] || return 0

  local is_bare
  is_bare=$(command git -C "$cache_dir" rev-parse --is-bare-repository 2>/dev/null) || return 0

  if [[ $is_bare != true ]]
  then
    [[ -d ${cache_dir}/.git ]] ||
      die "migrate_cache_to_bare_if_needed: cache ‘${cache_dir}’ is not bare and has no .git subdir; refusing to guess"

    info "migrate_cache_to_bare_if_needed: converting non-bare trunk cache ‘${cache_dir}’ to bare layout"

    local item
    for item in "$cache_dir"/* "$cache_dir"/.[!.]* "$cache_dir"/..?*
    do
      [[ -e $item ]] || continue
      [[ ${item##*/} == ".git" ]] && continue
      rm -rf "$item" ||
        die "migrate_cache_to_bare_if_needed: unable to remove ‘${item}’"
    done

    # The mv loop runs in a subshell to scope `shopt -s dotglob nullglob`.
    # die() inside that subshell only exits the subshell, so an mv failure
    # would silently leave the cache half-flattened.  Use plain `exit 1`
    # to propagate failure to the parent and die from there.  mv prints
    # its own per-file error to stderr.
    (
      shopt -s dotglob nullglob
      for gitfile in "${cache_dir}/.git"/*
      do
        mv "$gitfile" "$cache_dir/" || exit 1
      done
    ) ||
      die "migrate_cache_to_bare_if_needed: failed to flatten ‘${cache_dir}/.git’ into ‘${cache_dir}’"
    rmdir "${cache_dir}/.git" ||
      die "migrate_cache_to_bare_if_needed: .git dir not empty after flatten; manual inspection required"

    command git -C "$cache_dir" config core.bare true ||
      die "migrate_cache_to_bare_if_needed: unable to set core.bare=true in ‘${cache_dir}’"

    command git -C "$cache_dir" worktree repair >&2 ||
      warn "migrate_cache_to_bare_if_needed: worktree repair reported issues; live worktrees may need manual fixing"
  fi

  ensure_worktrees_not_poisoned_by_bare "$cache_dir"
}

# When a bare cache has `extensions.worktreeConfig = true`, `core.bare`
# becomes per-worktree-overridable.  Without an explicit per-worktree
# `core.bare = false`, every linked worktree inherits `true` from the
# common config and git refuses to recognise the working tree
# (`fatal: this operation must be run in a work tree`).
#
# Walk the cache's linked worktrees and write the override where
# missing.  Runs unconditionally from migrate_cache_to_bare_if_needed
# (including the already-bare path) so caches that an earlier buggy
# migration left in this state self-heal on next access.  No-op when
# the extension is off — `git config --worktree` would fail there and
# we have no evidence of poisoning in that case.
ensure_worktrees_not_poisoned_by_bare() {
  local cache_dir=$1

  local worktree_config
  # --type=bool normalizes git's truthy variants (true/yes/on/1) to
  # "true" so we don't have to enumerate them ourselves.
  worktree_config=$(command git -C "$cache_dir" config --type=bool --get extensions.worktreeConfig 2>/dev/null) || worktree_config=""
  [[ $worktree_config == true ]] || return 0

  local cache_dir_real
  cache_dir_real=$(cd "$cache_dir" && pwd -P) || cache_dir_real=$cache_dir

  local line wt_path wt_real current
  while IFS= read -r line
  do
    [[ $line == "worktree "* ]] || continue
    wt_path=${line#worktree }
    [[ -d $wt_path ]] || continue

    wt_real=$(cd "$wt_path" && pwd -P) || wt_real=$wt_path
    # The bare cache's own entry really IS bare — leave it alone.
    [[ $wt_real == "$cache_dir_real" ]] && continue

    current=$(command git -C "$wt_path" config --worktree --get core.bare 2>/dev/null) || current=""
    [[ $current == false ]] && continue

    info "ensure_worktrees_not_poisoned_by_bare: setting per-worktree core.bare=false in ‘${wt_path}’"
    command git -C "$wt_path" config --worktree core.bare false ||
      warn "ensure_worktrees_not_poisoned_by_bare: failed to set per-worktree core.bare in ‘${wt_path}’"
  done < <(command git -C "$cache_dir" worktree list --porcelain 2>/dev/null)
}

# Initialize a bare cache repository.  Optional `alternates_objects_dir`
# (path to another bare repo's objects/) is written into
# `objects/info/alternates` BEFORE remote-add + fetch, so the initial
# fetch only downloads objects unique to this repo.  Used by cache_trunk
# to share object storage across forks of the same upstream.
init_bare_cache() {
  local repo_dir=$1 origin_url=$2 alternates_objects_dir=${3:-}

  command git init --bare "$repo_dir" >&2 ||
    die "init_bare_cache: Unable to init bare cache at ‘${repo_dir}’"

  if [[ -n $alternates_objects_dir ]]
  then
    printf '%s\n' "$alternates_objects_dir" > "${repo_dir}/objects/info/alternates" ||
      die "init_bare_cache: Unable to write alternates for ‘${repo_dir}’"
  fi

  command git -C "$repo_dir" remote add origin "$origin_url" >&2 ||
    die "init_bare_cache: Unable to add origin remote for ‘${repo_dir}’"
  command git -C "$repo_dir" fetch --prune origin >&2 ||
    die "init_bare_cache: Unable to fetch origin for ‘${repo_dir}’"
  command git -C "$repo_dir" remote set-head origin -a >&2 ||
    die "init_bare_cache: Unable to set origin HEAD for ‘${repo_dir}’"
}

cache_trunk() {
  local source=$1
  local org repo
  org=$(get_org "$source") ||
    die "Unable to get org from ‘${source}’"
  repo=$(get_repo "$source") ||
    die "Unable to get repo from ‘${source}’"
  local org_dir="${repo_trunks_dir}/${org}"
  local repo_dir="${org_dir}/${repo}"

  mkdir -p "$org_dir" ||
    die "cache_trunk: Unable to create directory ‘${org_dir}’"

  local org_repo="${org}/${repo}"
  local clone_source
  if is_savannah_source "$source"; then
    clone_source=$(normalize_savannah_url "$source")
  elif [[ $source == git@* ]]; then
    clone_source="git@github.com:${org_repo}.git"
  else
    clone_source="https://github.com/${org_repo}"
  fi

  if [[ -d $repo_dir ]]; then
    migrate_cache_to_bare_if_needed "$repo_dir"
    sweep_bogus_worktrees_in_cache "$repo_dir"
    info "${org_repo} is already cached"

    # First-touch migration: if this cache predates the shared-objects
    # work and has no x.fork-parent cookie yet, probe the parent and
    # wire alternates retroactively.  We don't repack ourselves —
    # `git gc` (auto or manual) hardcodes `repack -d -l`, so the next
    # natural gc on this bare repo will collapse the local pack against
    # the alternates and reclaim duplicated objects on its own schedule.
    if [[ ! -e ${repo_dir}/x.fork-parent ]]
    then
      local existing_parent_spec=""
      existing_parent_spec=$(probe_fork_parent "${org_repo}") || existing_parent_spec=""

      if [[ -n $existing_parent_spec ]]
      then
        info "${org_repo} is a fork of ${existing_parent_spec}; wiring alternates retroactively"
        local existing_parent_cache
        existing_parent_cache=$(cache_trunk "$existing_parent_spec") ||
          die "cache_trunk: Unable to cache parent ‘${existing_parent_spec}’ for fork ‘${org_repo}’"

        local alt_file="${repo_dir}/objects/info/alternates"
        if [[ ! -e $alt_file ]]
        then
          printf '%s\n' "${existing_parent_cache}/objects" > "$alt_file" ||
            die "cache_trunk: Unable to write alternates for ‘${org_repo}’"
        fi
      fi

      printf '%s' "$existing_parent_spec" > "${repo_dir}/x.fork-parent" || true
    fi

    local fetch_output
    if fetch_output=$(command git -C "${repo_dir}" fetch --prune origin 2>&1)
    then
      printf '%s\n' "$fetch_output" >&2
    else
      printf '%s\n' "$fetch_output" >&2
      if [[ $fetch_output == *"case-insensitive filesystem"* ]]
      then
        warn "cache_trunk: Case-insensitive ref collision in ${org_repo}; migrating to reftable"
        if command git -C "${repo_dir}" refs migrate --ref-format=reftable >&2
        then
          info "cache_trunk: Reftable migration succeeded; retrying fetch"
          command git -C "${repo_dir}" fetch --prune origin >&2 ||
            warn "cache_trunk: Fetch still failed after reftable migration for ${org_repo}; continuing with stale cache"
        else
          warn "cache_trunk: Reftable migration failed for ${org_repo}; continuing with stale cache"
        fi
      else
        warn "cache_trunk: Unable to fetch ${org_repo}; continuing with stale cache"
      fi
    fi
    command git -C "${repo_dir}" remote set-head origin -a >&2 ||
      warn "cache_trunk: Unable to update origin/HEAD for ${org_repo}; continuing with stale cache"
  else
    info "${org_repo} is not cached"

    # Probe whether this is a fork on GitHub.  If so, recursively cache
    # the parent first and wire this cache's objects/info/alternates to
    # the parent's objects/, so the initial fetch only downloads
    # fork-unique objects.  Empty parent_spec means "not a fork" (or
    # `gh` unavailable) — falls through to a standard self-contained
    # bare cache.
    local parent_spec=""
    parent_spec=$(probe_fork_parent "${org_repo}") || parent_spec=""

    local alternates_objects_dir=""
    if [[ -n $parent_spec ]]
    then
      info "${org_repo} is a fork of ${parent_spec}; sharing objects via alternates"
      local parent_cache
      parent_cache=$(cache_trunk "$parent_spec") ||
        die "cache_trunk: Unable to cache parent ‘${parent_spec}’ for fork ‘${org_repo}’"
      alternates_objects_dir="${parent_cache}/objects"
    fi

    init_bare_cache "$repo_dir" "$clone_source" "$alternates_objects_dir"

    # Record the probe result so future cache_trunk runs on this repo
    # don't have to re-query GitHub.  Empty file = "checked, not a fork".
    printf '%s' "$parent_spec" > "${repo_dir}/x.fork-parent" || true

    maybe_execute_hook "${org}" "${repo}" post-cache
  fi

  printf '%s' "${repo_dir}"
}

get_trunk_branch_name_from_cache() {
  local trunk_cache=$1

  [[ -n $trunk_cache ]] ||
    die "Passed an empty trunk_cache which should be impossible"

  local origin_head
  origin_head=$(command git -C "$trunk_cache" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) ||
    origin_head=$(command git -C "$trunk_cache" rev-parse --abbrev-ref origin/HEAD 2>/dev/null) ||
    {
      command git -C "$trunk_cache" remote set-head origin -a >&2 ||
        die "Unable to set origin HEAD in cache ‘${trunk_cache}’"
      origin_head=$(command git -C "$trunk_cache" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) ||
        die "Unable to resolve origin HEAD in cache ‘${trunk_cache}’"
    }

  printf '%s' "${origin_head#refs/remotes/origin/}"
}

# Rewrite a branch name like "<trunk>/<subpath>" into "<prefix>/<subpath>"
# when (1) the first segment is the repo's trunk branch and (2) the user
# has a configured branch prefix.  Lets callers point at a subpath of the
# trunk worktree and get back their own prefixed branch for that subpath.
# Prints the (possibly rewritten) branch name on stdout; never fails.
maybe_rewrite_trunk_subpath() {
  local branch=$1 trunk_cache=$2

  case $branch in
    */*) ;;
    *) printf '%s' "$branch"; return ;;
  esac

  [[ -n $trunk_cache && -d $trunk_cache ]] ||
    { printf '%s' "$branch"; return; }

  # Only the non-mutating symbolic-ref probe — don't trigger
  # `remote set-head` (network) from this path.
  local origin_head
  origin_head=$(command git -C "$trunk_cache" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) ||
    { printf '%s' "$branch"; return; }

  local trunk_name=${origin_head#refs/remotes/origin/}
  [[ -n $trunk_name ]] ||
    { printf '%s' "$branch"; return; }

  local first=${branch%%/*}
  [[ $first == "$trunk_name" ]] ||
    { printf '%s' "$branch"; return; }

  # Preserve real branches named '<trunk>/<rest>'. If the ref exists on
  # origin in the trunk cache, the user is pointing at an actual branch
  # (e.g. `origin/main/experimental`) and the rewrite would hide it.
  if command git -C "$trunk_cache" rev-parse --verify --quiet \
       "refs/remotes/origin/${branch}" >/dev/null 2>&1
  then
    printf '%s' "$branch"
    return
  fi

  local config_dir=${XDG_CONFIG_HOME:-${HOME}/.config}/timvisher/ide
  local prefix_file=${config_dir}/branch_prefix
  [[ -r $prefix_file ]] ||
    { printf '%s' "$branch"; return; }

  local prefix
  prefix=$(< "$prefix_file")
  prefix=${prefix//$'\n'/}
  prefix=${prefix//[[:space:]]/}
  [[ -n $prefix ]] ||
    { printf '%s' "$branch"; return; }

  local rest=${branch#*/}
  local rewritten="${prefix}/${rest}"

  info 'rewriting trunk subpath: %s -> %s' "$branch" "$rewritten"
  printf '%s' "$rewritten"
}

configure_remotes_and_tracking() {
  local trunk_cache=$1 source=$2
  local repo_spec parent default_branch pr_url override_repo
  local origin_url
  origin_url=$(git remote get-url origin 2>/dev/null) || true
  if [[ $origin_url == *git.savannah.gnu.org* ]]; then
    info "Origin is Savannah; skipping GitHub remote configuration."
    return
  fi


  if [[ $source == https://github.com/*/*/pull/* ]]; then
    configure_remotes_for_pr "$source"
    return
  fi

  if [[ -r pr.md.url ]]; then
    pr_url=$(< pr.md.url)
    pr_url=$(normalize_pr_url "$pr_url")
    if [[ $pr_url == https://github.com/*/*/pull/* ]]; then
      local pr_base pr_head
      pr_base=$(pr_base_repo_spec "$pr_url") || true
      pr_head=$(pr_head_repo_spec "$pr_url") || true
      if [[ -n $pr_base && -n $pr_head && $pr_base != "$pr_head" ]]; then
        # Cross-repo PR (e.g. fork → parent): let the PR helper set
        # both origin and upstream from the PR metadata.
        configure_remotes_for_pr "$pr_url"
        return
      fi
      # Same-repo PR (or unable to resolve head): fall through to the
      # regular fork-detection logic so soft forks still get an upstream.
    fi
  fi

  repo_spec=$(printf '%s' "$origin_url" | sed -E 's#^https?://github.com/|git@github.com:##; s#\.git$##')

  if [[ -z "$repo_spec" ]]; then
    info "No origin remote URL found; assuming local-only repository. Skipping remote configuration."
    return
  fi

  if override_repo=$(upstream_override_for_repo "$repo_spec"); then
    if [[ $override_repo != "$repo_spec" ]]; then
      info "Using upstream override '${override_repo}' for '${repo_spec}'"
      if git remote get-url upstream >/dev/null 2>&1; then
        git remote set-url upstream "https://github.com/${override_repo}.git"
      else
        git remote add upstream "https://github.com/${override_repo}.git"
      fi
      git fetch upstream >&2 || die "Unable to fetch from upstream remote"
      default_branch=$(gh repo view "$override_repo" --json defaultBranchRef --jq .defaultBranchRef.name 2>/dev/null) || default_branch=main
      info "Setting tracking to 'upstream/${default_branch}'"
      git branch -u "upstream/${default_branch}" >&2 || die "Unable to track upstream/${default_branch}"
      return
    fi
  fi

  # Always query fork status and push permissions via API.
  info "Checking fork status and permissions for '%s'..." "$repo_spec"

  if ! gh repo set-default "$repo_spec" >&2; then
    warn "Failed to set default gh repo, fork detection might fail."
  fi

  local repo_info
  repo_info=$(gh api "/repos/${repo_spec}" --jq '{
    is_fork: .fork,
    parent: (if .fork then .parent.full_name else "" end),
    push: .permissions.push,
    soft_fork: ([(.topics // [])[]] | any(. == "soft-fork"))
  }' 2>/dev/null) || true

  local is_fork can_push soft_fork
  is_fork=$(printf '%s' "$repo_info" | jq -r '.is_fork // false' 2>/dev/null) || true
  parent=$(printf '%s' "$repo_info" | jq -r '.parent // empty' 2>/dev/null) || true
  can_push=$(printf '%s' "$repo_info" | jq -r '.push // false' 2>/dev/null) || true
  soft_fork=$(printf '%s' "$repo_info" | jq -r '.soft_fork // false' 2>/dev/null) || true

  if [[ $is_fork == true && -n $parent ]]; then
    # Origin is already a fork.  Set up upstream → parent.
    info "Repository is a fork of '${parent}'. Configuring 'upstream' remote."
    if git remote get-url upstream >/dev/null 2>&1; then
      git remote set-url upstream "https://github.com/${parent}.git"
    else
      git remote add upstream "https://github.com/${parent}.git"
    fi
    git fetch upstream >&2 || die "Unable to fetch from upstream remote"

    if [[ $soft_fork == true ]]; then
      local origin_default
      origin_default=$(gh repo view "$repo_spec" --json defaultBranchRef --jq .defaultBranchRef.name 2>/dev/null) || origin_default=main
      info "Soft fork detected (topic 'soft-fork'). Setting tracking to 'origin/${origin_default}'"
      git branch -u "origin/${origin_default}" >&2 || die "Unable to track origin/${origin_default}"
      touch x.timvisher_git.soft-fork
    else
      default_branch=$(gh repo view "$parent" --json defaultBranchRef --jq .defaultBranchRef.name 2>/dev/null) || default_branch=main
      info "Setting tracking to 'upstream/${default_branch}'"
      git branch -u "upstream/${default_branch}" >&2 || die "Unable to track upstream/${default_branch}"
      rm -f x.timvisher_git.soft-fork
    fi
  elif [[ $can_push == true ]]; then
    # Not a fork and we can push — straightforward origin tracking.
    info "Repository is not a fork. Ensuring 'origin' is tracked."
    local trunk_branch_name
    trunk_branch_name=$(get_trunk_branch_name_from_cache "$trunk_cache")
    info "Setting tracking to 'origin/${trunk_branch_name}'"
    git branch -u "origin/${trunk_branch_name}" >&2 || die "Unable to track origin/${trunk_branch_name}"
    safe_remove_upstream
    rm -f x.timvisher_git.soft-fork
  else
    # Not a fork and no push rights — this is an upstream repo.
    # Find a fork we can push to via github_user_aliases.
    info "No push rights to '%s'. Searching for a pushable fork..." "$repo_spec"
    local fork_spec
    fork_spec=$(find_pushable_fork "$repo_spec") || true

    if [[ -n $fork_spec ]]; then
      info "Found pushable fork: '%s'. Reconfiguring remotes." "$fork_spec"
      # Current origin becomes upstream
      if git remote get-url upstream >/dev/null 2>&1; then
        git remote set-url upstream "$origin_url"
      else
        git remote add upstream "$origin_url"
      fi
      # Fork becomes origin
      git remote set-url origin "https://github.com/${fork_spec}.git"
      git fetch origin >&2 || die "Unable to fetch from new origin '${fork_spec}'"
      git fetch upstream >&2 || die "Unable to fetch from upstream"

      default_branch=$(gh api "/repos/${repo_spec}" --jq '.default_branch // "main"' 2>/dev/null) || default_branch=main
      info "Setting tracking to 'upstream/${default_branch}'"
      git branch -u "upstream/${default_branch}" >&2 || die "Unable to track upstream/${default_branch}"
      rm -f x.timvisher_git.soft-fork
    else
      # No fork found — track origin read-only.
      info "No pushable fork found. Tracking origin read-only."
      local trunk_branch_name
      trunk_branch_name=$(get_trunk_branch_name_from_cache "$trunk_cache")
      info "Setting tracking to 'origin/${trunk_branch_name}'"
      git branch -u "origin/${trunk_branch_name}" >&2 || die "Unable to track origin/${trunk_branch_name}"
      safe_remove_upstream
      rm -f x.timvisher_git.soft-fork
    fi
  fi
}

configure_remotes_for_pr() {
  local source=$1
  local base_repo_spec head_repo_spec

  base_repo_spec=$(pr_base_repo_spec "$source") ||
    die "Unable to parse PR base repo from '${source}'"

  head_repo_spec=$(pr_head_repo_spec "$source") ||
    die "Unable to resolve PR head repo for '${source}'; ensure gh is installed and authenticated"

  info "Configuring PR remotes: origin=${head_repo_spec} upstream=${base_repo_spec}"

  if git remote get-url origin >/dev/null 2>&1; then
    git remote set-url origin "https://github.com/${head_repo_spec}.git"
  else
    git remote add origin "https://github.com/${head_repo_spec}.git"
  fi
  git fetch origin >&2 || die "Unable to fetch from origin remote"

  if [[ $head_repo_spec != "$base_repo_spec" ]]; then
    if git remote get-url upstream >/dev/null 2>&1; then
      git remote set-url upstream "https://github.com/${base_repo_spec}.git"
    else
      git remote add upstream "https://github.com/${base_repo_spec}.git"
    fi
    git fetch upstream >&2 || die "Unable to fetch from upstream remote"
  else
    safe_remove_upstream
  fi
}

sanitize_branch_name() {
  local name=$1

  # Replace leading dots in each path component with underscores
  # (git check-ref-format rejects components starting with '.').
  name=$(printf '%s' "$name" | sed -E 's#(^|/)\.+#\1_#g')

  # Remove any resulting empty components (e.g. foo//bar → foo/bar)
  while [[ $name == *//* ]]
  do
    name=${name//\/\//\/}
  done

  # Strip leading/trailing slashes
  name=${name#/}
  name=${name%/}

  printf '%s' "$name"
}

branch_path_for_source() {
  local source=$1 trunk_cache=$2
  local branch_dir branch org repo head_repo_spec

  case $source in
    *git.savannah.gnu.org*)
      org=$(get_org "$source")
      repo=$(get_repo "$source")
      branch=$(get_trunk_branch_name_from_cache "$trunk_cache")
      branch_dir="${org}/${repo}/${branch}"
      ;;
    https://github.com/*/*/pull/*)
      head_repo_spec=$(pr_head_repo_spec "$source") ||
        die "Unable to resolve PR head repo for '${source}'; ensure gh is installed and authenticated"
      org=$(get_org "$head_repo_spec")
      repo=$(get_repo "$head_repo_spec")
      branch=$(pr_head_ref_name "$source") ||
        die "Unable to resolve PR head branch for ‘${source}’; ensure gh is installed and authenticated"
      branch_dir="${org}/${repo}/${branch}"
      ;;
    https://github.com/*/*/tree/*)
      branch_dir=${source#https://github.com/}
      org=$(get_org "$branch_dir")
      repo=$(get_repo "$source")
      branch_dir=${branch_dir/tree\//}
      # branch is everything after 'org/repo/' — preserves multi-segment
      # branch names like 'main/foo/bar', which is what the rewrite needs.
      branch=${branch_dir#*/}
      branch=${branch#*/}
      branch=$(maybe_rewrite_trunk_subpath "$branch" "$trunk_cache")
      branch_dir="${org}/${repo}/${branch}"
      ;;
    https://github.com/*/*)
      local trunk_branch_name
      trunk_branch_name=$(get_trunk_branch_name_from_cache "$trunk_cache")
      org=$(get_org "$source")
      repo=$(get_repo "$source")
      branch_dir="${org}/${repo}/${trunk_branch_name}"
      branch=$trunk_branch_name
      ;;
    */*/*)
      org=$(get_org "$source")
      source=${source#*/}
      repo=${source%%/*}
      source=${source#*/}
      branch=${source}
      branch=$(maybe_rewrite_trunk_subpath "$branch" "$trunk_cache")
      branch_dir="${org}/${repo}/${branch}"
      ;;
    */*)
      org=$(get_org "$source")
      source=${source#*/}
      repo=${source%%/*}
      source=${source#*/}
      branch=$(get_trunk_branch_name_from_cache "$trunk_cache")
      branch_dir="${org}/${repo}/${branch}"
      ;;
    *)
      die "Unsupported source ‘${source}’"
      ;;
  esac

  # Guard before sanitize.  If branch or branch_dir contains `.git` as
  # a path component, something upstream handed us a path that leaked
  # cache-layout structure (main-57o regression).  Die loudly instead
  # of letting sanitize_branch_name quietly turn `.git` into `_git`.
  die_if_git_component "branch_path_for_source: branch" "$branch"
  die_if_git_component "branch_path_for_source: branch_dir" "$branch_dir"

  branch=$(sanitize_branch_name "$branch")
  branch_dir=$(sanitize_branch_name "$branch_dir")

  printf '%s;%s' "$branch_dir" "$branch"
}

ensure_worktree() {
  local source=$1
  die_if_git_component "ensure_worktree: source" "$source"
  local trunk_cache
  trunk_cache=$(cache_trunk "$source")

  local branch_dir_and_branch
  branch_dir_and_branch=$(branch_path_for_source "$source" "$trunk_cache")
  local branch_dir=${branch_dir_and_branch%%;*}
  local branch=${branch_dir_and_branch#*;}

  [[ -n $branch_dir ]] ||
    die "Unable to derive branch_dir"

  [[ -n $branch ]] ||
    die "Unable to derive branch"

  local branch_dir_abs="${live_repo_dir}/${branch_dir}"
  local branch_dir_parent=${branch_dir_abs%/*}
  local branch_dir_exists=0

  if [[ -d $branch_dir_abs ]]; then
    branch_dir_exists=1
  fi

  if [[ $source == https://github.com/*/*/pull/* ]] && (( branch_dir_exists )); then
    local existing_branch
    existing_branch=$(git -C "${branch_dir_abs}" rev-parse --abbrev-ref HEAD 2>/dev/null) || true

    if [[ -n $existing_branch && $existing_branch != "HEAD" ]]
    then
      # Worktree exists and has a real branch checked out — reuse it.
      info "Using existing worktree for PR head branch ‘${existing_branch}’ at ‘${branch_dir_abs}’"
      printf '%s' "$branch_dir_abs"
      return 0
    fi

    # Directory exists but is broken (detached HEAD from a failed prior
    # attempt, or not a valid git worktree).  Clean it up so we can
    # start fresh.
    warn "Removing broken PR worktree at ‘${branch_dir_abs}’"
    command git -C "${trunk_cache}" worktree remove --force "$branch_dir_abs" >&2 2>/dev/null || true
    rm -rf "$branch_dir_abs" 2>/dev/null || true
    branch_dir_exists=0
  fi

  # If this is a PR, check whether the branch is already checked out in a
  # worktree at a different path.  If so, move it to the expected location
  # rather than failing on the duplicate-branch error.
  if [[ $source == https://github.com/*/*/pull/* && $branch_dir_exists == 0 ]]; then
    local existing_wt=""
    local wt_line wt_path
    while IFS= read -r wt_line
    do
      case $wt_line in
        "worktree "*)  wt_path=${wt_line#worktree } ;;
        "branch refs/heads/${branch}") existing_wt=$wt_path ; break ;;
      esac
    done < <(command git -C "${trunk_cache}" worktree list --porcelain 2>/dev/null)

    if [[ -n $existing_wt && -d $existing_wt ]]
    then
      info "Branch ‘%s’ already checked out at ‘%s’; moving to ‘%s’" "$branch" "$existing_wt" "$branch_dir_abs"
      mkdir -p "$branch_dir_parent" ||
        die "Unable to create branch directory parent ‘${branch_dir_parent}’"
      command git -C "${trunk_cache}" worktree move "$existing_wt" "$branch_dir_abs" >&2 ||
        die "Unable to move worktree from ‘%s’ to ‘%s’" "$existing_wt" "$branch_dir_abs"
      branch_dir_exists=1
    fi
  fi

  mkdir -p "$branch_dir_parent" ||
    die "Unable to create branch directory parent ‘${branch_dir_parent}’"

  if ! [[ -d ${branch_dir_abs} ]]; then
    info "Creating worktree ‘${branch_dir_abs}’ from cache ‘${trunk_cache}’"
    command git -C "${trunk_cache}" worktree prune >&2
    command git -C "${trunk_cache}" worktree add --detach "${branch_dir_abs}" "origin/$(get_trunk_branch_name_from_cache "$trunk_cache")" >&2 ||
      die "Unable to add worktree ‘${branch_dir_abs}’"

    # Caches with extensions.worktreeConfig=true propagate core.bare=true
    # into every freshly-added worktree; without the per-worktree override
    # the next git op dies with "this operation must be run in a work tree".
    ensure_worktrees_not_poisoned_by_bare "$trunk_cache"

    maybe_execute_hook "$(get_org "$source")" "$(get_repo "$source")" post-initial-branch-dir-creation
  else
    info "Worktree already exists at ${branch_dir_abs}"
  fi

  (
    cd "$branch_dir_abs" ||
      die "Unable to cd to ‘${branch_dir_abs}’"

    local errors

    if [[ $source == https://github.com/*/*/pull/* ]]; then
      local current_branch
      current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || true

      if [[ $current_branch != "HEAD" ]]
      then
        # Branch is already checked out (existing worktree).  No need to
        # run gh pr checkout — it would try to fast-forward and fail if
        # the local branch has diverged from the remote PR tip.
        info "PR branch ‘%s’ already checked out; skipping gh pr checkout" "$current_branch"
      else
        local pr_url
        pr_url=$(normalize_pr_url "$source")
        gh pr checkout "$pr_url" >&2 ||
          {
            error "Failed to checkout PR source ‘${source}’"
            errors=1
          }
      fi
    else
      # The ide `bash/bin/git` wrapper handles selective-fetch branch
      # refspec setup before delegating to real git, so we can hand the
      # checkout straight off without pre-fetching here.
      if [[ -z $errors ]]
      then
        if git show-ref --verify --quiet "refs/heads/${branch}"
        then
          command git checkout "${branch}" >&2 ||
            warn "git checkout ${branch} exited non-zero (post-checkout hook failure?)"
        elif git show-ref --verify --quiet "refs/remotes/origin/${branch}"
        then
          command git checkout --track -b "${branch}" "origin/${branch}" >&2 ||
            warn "git checkout --track -b ${branch} origin/${branch} exited non-zero"
        else
          local trunk_branch
          trunk_branch=$(get_trunk_branch_name_from_cache "$trunk_cache")
          command git checkout --track -b "${branch}" "origin/${trunk_branch}" >&2 ||
            warn "git checkout --track -b ${branch} origin/${trunk_branch} exited non-zero"
        fi
      fi

      # Verify we actually landed on the right branch regardless of exit code
      # (post-checkout hooks can cause non-zero exit even on successful checkout).
      local actual_branch
      actual_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || true
      if [[ $actual_branch != "$branch" ]]
      then
        error "Expected branch '${branch}' but HEAD is on '${actual_branch}'"
        errors=1
      fi
    fi

    if [[ -z $errors ]]; then
      configure_remotes_and_tracking "$trunk_cache" "$source"
      maybe_execute_hook "$(get_org "$source")" "$(get_repo "$source")" post-make-branch-dir
      printf '%s' "$branch_dir_abs"
    else
      exit 1
    fi
  )
}

# ---------------------------------------------------------------------------
# Lightweight tracking setup for repos not managed by the worktree system.
# Only acts when tracking is unset — never overrides existing tracking.
# ---------------------------------------------------------------------------

ensure_tracking() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0
  [[ $branch != HEAD ]] || return 0

  # If tracking already resolves, leave it alone.
  if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1
  then
    return 0
  fi

  # Also bail if tracking is configured but the ref is temporarily missing
  # (e.g. another worktree removed the remote).
  local tracking_remote
  tracking_remote=$(git config "branch.${branch}.remote" 2>/dev/null) || true
  if [[ -n $tracking_remote ]]
  then
    return 0
  fi

  # No tracking at all.  Prefer upstream when available (regular fork),
  # otherwise origin.
  local target_remote=origin
  if git remote get-url upstream >/dev/null 2>&1
  then
    target_remote=upstream
  fi

  local target_ref
  target_ref=$(git symbolic-ref -q --short "refs/remotes/${target_remote}/HEAD" 2>/dev/null) || true
  if [[ -z $target_ref ]]
  then
    local name
    for name in main master
    do
      if git show-ref --verify --quiet "refs/remotes/${target_remote}/${name}"
      then
        target_ref="${target_remote}/${name}"
        break
      fi
    done
  fi

  [[ -n $target_ref ]] || return 0

  git branch --set-upstream-to="$target_ref" "$branch" >/dev/null 2>&1 ||
    warn 'Unable to set upstream for %s to %s' "$branch" "$target_ref"
}

# ---------------------------------------------------------------------------
# Ensure an existing repo (not managed by the worktree cache system) has
# correct tracking.  Best-effort fetch, then lightweight tracking setup.
# ---------------------------------------------------------------------------

ensure_existing_repo() {
  local repo_dir=$1
  repo_dir=$(cd "$repo_dir" && pwd -P) || die "Cannot resolve '%s'" "$repo_dir"

  (
    cd "$repo_dir" || die "Cannot cd to '%s'" "$repo_dir"

    # Best-effort fetch — tolerate network failures.
    git fetch origin >&2 || true
    if git remote get-url upstream >/dev/null 2>&1
    then
      git fetch upstream >&2 || true
    fi

    # Determine if this is a managed worktree (under our cache system).
    local common_dir
    common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || {
      printf '%s' "$repo_dir"
      return 0
    }
    common_dir=$(cd "$common_dir" && pwd -P 2>/dev/null) || {
      printf '%s' "$repo_dir"
      return 0
    }

    if [[ $common_dir == "${repo_trunks_dir}/"* ]]
    then
      # Managed worktree — run full remote/tracking configuration.
      local origin_url
      origin_url=$(git remote get-url origin 2>/dev/null) || true
      configure_remotes_and_tracking "$common_dir" "${origin_url:-}"
    else
      # External repo — lightweight tracking setup.
      ensure_tracking
    fi
  )

  printf '%s' "$repo_dir"
}

# ---------------------------------------------------------------------------
# Soft fork helpers
# ---------------------------------------------------------------------------

# Detect the trunk (default) branch name for a repo.
# Works from any worktree or the bare cache.
detect_trunk_branch() {
  local dir=${1:-.}

  local common_dir
  common_dir=$(git -C "$dir" rev-parse --git-common-dir 2>/dev/null) ||
    die "detect_trunk_branch: not a git repo: '%s'" "$dir"
  common_dir=$(cd "$dir" && cd "$common_dir" && pwd -P)

  get_trunk_branch_name_from_cache "$common_dir"
}

# Find an existing worktree checked out on the given branch.
# Prints the worktree path, or nothing if none exists.
find_worktree_for_branch() {
  local dir=${1:-.}
  local branch=$2

  [[ -n $branch ]] || die "find_worktree_for_branch: branch required"

  git -C "$dir" worktree list --porcelain |
    awk -v branch="refs/heads/${branch}" \
      '/^worktree /{wt=substr($0,10)} /^branch / && $2 == branch {print wt}'
}

# Derive the expected worktree path for a branch from the bare repo location.
derive_worktree_path() {
  local dir=${1:-.}
  local branch=$2

  [[ -n $branch ]] || die "derive_worktree_path: branch required"

  local common_dir
  common_dir=$(command git -C "$dir" rev-parse --git-common-dir 2>/dev/null) ||
    die "derive_worktree_path: not a git repo: '%s'" "$dir"
  common_dir=$(cd "$dir" && cd "$common_dir" && pwd -P)

  # Trunk caches must be bare.  If the common_dir ends in /.git the
  # cache is non-bare (likely a leftover from the main-57o regression)
  # and rel_path below would include ".git" as a path component,
  # producing bogus live paths.  Migrate in place, then re-resolve
  # common_dir against the now-bare cache.
  if [[ $common_dir == */.git ]]
  then
    migrate_cache_to_bare_if_needed "${common_dir%/.git}"
    common_dir=$(command git -C "$dir" rev-parse --git-common-dir 2>/dev/null) ||
      die "derive_worktree_path: not a git repo after migration: '%s'" "$dir"
    common_dir=$(cd "$dir" && cd "$common_dir" && pwd -P)
  fi

  # common_dir has been resolved via pwd -P; resolve repo_trunks_dir
  # the same way so the prefix strip is apples-to-apples on systems
  # (like macOS) where parent paths may contain symlinks.
  local repo_trunks_dir_real
  repo_trunks_dir_real=$(cd "$repo_trunks_dir" && pwd -P 2>/dev/null) || repo_trunks_dir_real=$repo_trunks_dir

  local rel_path="${common_dir#"${repo_trunks_dir_real}/"}"
  local result="${live_repo_dir}/${rel_path}/${branch}"

  # After migration, the output must never contain `.git` as a path
  # component.  If it does, the migration failed to take or something
  # upstream corrupted common_dir — die loudly rather than return a
  # path that would spawn a spurious `_git/...` worktree downstream.
  die_if_git_component "derive_worktree_path: result" "$result"

  printf '%s' "$result"
}

# ---------------------------------------------------------------------------
# sync-trunk: merge upstream/<trunk> into origin/<trunk> for soft forks
#
# Finds (or creates) the trunk worktree, fetches, merges upstream, and
# pushes.  Non-interactive: exits non-zero on merge conflicts so the
# caller can arrange for agent-driven resolution.  On conflict, prints
# the trunk worktree path to stdout.
# ---------------------------------------------------------------------------

sync_trunk() {
  local dir=${1:-.}
  dir=$(cd "$dir" && pwd -P) || die "sync_trunk: invalid path '%s'" "$dir"

  if ! git -C "$dir" remote get-url upstream >/dev/null 2>&1
  then
    info "sync_trunk: '%s' has no upstream remote; nothing to do" "$dir"
    return 0
  fi

  if [[ ! -f ${dir}/x.timvisher_git.soft-fork ]]
  then
    info "sync_trunk: '%s' is not a soft fork; nothing to do" "$dir"
    return 0
  fi

  local trunk_branch
  trunk_branch=$(detect_trunk_branch "$dir") ||
    die "sync_trunk: cannot detect trunk branch for '%s'" "$dir"

  # Clean out any bogus worktrees registered in the cache before we
  # start looking for existing trunk worktrees to reuse (see main-agj).
  # If the cache is non-bare its common_dir ends in `/.git`; migrate it
  # to bare first so the sweep targets the cache root proper, and the
  # downstream die_if_git_component guard doesn't hard-fail on what is
  # really self-healable cache shape (see main-q5u).
  local cache_common_dir
  cache_common_dir=$(command git -C "$dir" rev-parse --git-common-dir 2>/dev/null) || cache_common_dir=
  if [[ -n $cache_common_dir ]]
  then
    cache_common_dir=$(cd "$dir" && cd "$cache_common_dir" && pwd -P)
    if [[ $cache_common_dir == */.git ]]
    then
      migrate_cache_to_bare_if_needed "${cache_common_dir%/.git}"
      cache_common_dir=$(command git -C "$dir" rev-parse --git-common-dir 2>/dev/null) ||
        die "sync_trunk: not a git repo after cache migration: '%s'" "$dir"
      cache_common_dir=$(cd "$dir" && cd "$cache_common_dir" && pwd -P)
    fi
    sweep_bogus_worktrees_in_cache "$cache_common_dir"
  fi

  local trunk_wt
  trunk_wt=$(find_worktree_for_branch "$dir" "$trunk_branch")

  # Guard: refuse to return a bogus worktree path to the caller, who is
  # about to feed it into ensure_session / ntmux3 / clone.  Such a path
  # would re-launder through sanitize_branch_name and spawn a spurious
  # `_git/...` worktree (see main-57o).  If found, the cache's
  # worktree registry still references legacy paths that main-agj
  # cleanup should remove.
  if [[ -n $trunk_wt ]]
  then
    die_if_git_component "sync_trunk: existing worktree from cache" "$trunk_wt"
  fi

  if [[ -z $trunk_wt ]]
  then
    trunk_wt=$(derive_worktree_path "$dir" "$trunk_branch")
    info "sync_trunk: creating trunk worktree at '%s'" "$trunk_wt"
    local trunk_wt_parent=${trunk_wt%/*}
    mkdir -p "$trunk_wt_parent" ||
      die "sync_trunk: cannot create parent dir '%s'" "$trunk_wt_parent"

    local common_dir
    common_dir=$(git -C "$dir" rev-parse --git-common-dir 2>/dev/null)
    common_dir=$(cd "$dir" && cd "$common_dir" && pwd -P)
    command git -C "$common_dir" worktree prune >&2
    command git -C "$common_dir" worktree add "$trunk_wt" "$trunk_branch" >&2 ||
      die "sync_trunk: cannot create worktree at '%s'" "$trunk_wt"
  fi

  info "sync_trunk: trunk worktree at '%s' (branch '%s')" "$trunk_wt" "$trunk_branch"

  git -C "$trunk_wt" fetch --all --quiet >&2 ||
    warn "sync_trunk: fetch had warnings"

  local current_branch
  current_branch=$(git -C "$trunk_wt" rev-parse --abbrev-ref HEAD 2>/dev/null) || true
  if [[ $current_branch != "$trunk_branch" ]]
  then
    die "sync_trunk: expected branch '%s' but found '%s' in '%s'" \
      "$trunk_branch" "$current_branch" "$trunk_wt"
  fi

  if git -C "$trunk_wt" merge-base --is-ancestor "upstream/${trunk_branch}" HEAD 2>/dev/null
  then
    info "sync_trunk: origin/%s is already up to date with upstream/%s" \
      "$trunk_branch" "$trunk_branch"
    return 0
  fi

  info "sync_trunk: merging upstream/%s into %s" "$trunk_branch" "$trunk_branch"
  if ! git -C "$trunk_wt" merge "upstream/${trunk_branch}" \
    -m "Merge upstream/${trunk_branch} into ${trunk_branch}" >&2
  then
    warn "sync_trunk: merge conflicts in '%s'; aborting" "$trunk_wt"
    git -C "$trunk_wt" merge --abort >&2 2>/dev/null || true
    printf '%s' "$trunk_wt"
    return 1
  fi

  info "sync_trunk: pushing %s to origin" "$trunk_branch"
  git -C "$trunk_wt" push origin "$trunk_branch" >&2 ||
    die "sync_trunk: push to origin failed for '%s'" "$trunk_wt"

  info "sync_trunk: done — origin/%s updated" "$trunk_branch"
}

# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------

clone_usage() {
  cat >&2 <<'EOF'
Usage: timvisher_git clone <target> [stack-on-base]

Idempotently produce a worktree for <target> with correct remotes and
tracking.  Prints the worktree path to stdout.  Safe to call repeatedly
on the same target — existing worktrees are verified and repaired.

When [stack-on-base] is provided, the target worktree is "stacked" on
the base: the base worktree is cloned first (ensuring it exists), then
the target is reset --hard to the base branch's HEAD.  Both arguments
must resolve to the same org/repo.  An x.stack-pending marker provides
idempotent recovery from partial failures.

Resolution order
----------------

  clone resolves targets in preference order:

  1. Local directory that already exists on disk — checked first so
     that local-only repos (no GitHub remote) work even when
     strip_live_prefix produces a valid-looking org/repo shorthand:
     a. Bare repo — managed caches (under ~/.cache/timvisher_git_worktrees)
        are translated to a trunk checkout; others get best-effort tracking.
     b. Git working tree → ensure_existing_repo.
  2. Remote match — URL, or org/repo shorthand that resolves via aliases
     and the GitHub trunk cache → ensure_worktree.  When stack_on_base
     is provided, both args must resolve as branch-ishes for
     clone_stacked.
  3. Error — if none of the above match.

  Relative paths without ./ prefix (e.g. "myrepo") are resolved against
  the current directory for step 1.  ~/git/ paths are stripped to
  org/repo/branch shorthands for step 2 (via strip_live_prefix).

Targets
-------

  Local path (existing git repo)
    timvisher_git clone /path/to/repo
    timvisher_git clone ~/projects/my-app
    timvisher_git clone myrepo          # relative dir in CWD

    Best-effort fetch, then:
    - Managed worktree (bare cache under ~/.cache/timvisher_git_worktrees):
      full remote/tracking reconfiguration via configure_remotes_and_tracking.
    - External repo: lightweight tracking setup (only acts when tracking is
      completely unset; never overrides existing tracking).

  GitHub repo URL
    timvisher_git clone https://github.com/org/repo

    Clones into ~/git/<org>/<repo>/<trunk-branch>/.
    Configures remotes and tracking based on fork status.

  GitHub repo URL with branch
    timvisher_git clone https://github.com/org/repo/tree/branch-name

    Clones into ~/git/<org>/<repo>/<branch-name>/.

  GitHub PR URL
    timvisher_git clone https://github.com/org/repo/pull/123

    Checks out the PR's head branch into ~/git/<head-org>/<repo>/<branch>/.
    Configures origin → head repo, upstream → base repo (if cross-fork).

  SSH URL
    timvisher_git clone git@github.com:org/repo.git

    Same as HTTPS repo URL.

  Savannah URL
    timvisher_git clone https://git.savannah.gnu.org/git/project.git

    Clones into ~/git/gnu/<project>/<trunk-branch>/.

  Shorthand: org/repo
    timvisher_git clone octocat/hello-world

    Clones into ~/git/<org>/<repo>/<trunk-branch>/.
    Org aliases are expanded (e.g. "oc" → "octocat" if configured in
    ~/.config/timvisher/ide/git_org_aliases).

  Shorthand: org/repo/branch[/parts...]
    timvisher_git clone octocat/hello-world/timvisher/scratch/_trunk_

    Clones into ~/git/<org>/<repo>/<branch/parts>/.
    Creates the branch from origin/<trunk> if it doesn't exist yet.

Remote & tracking configuration
--------------------------------

After creating (or verifying) the worktree, clone configures remotes
and tracking based on the relationship between the repo and the
configured fork_user (~/.config/timvisher/ide/git_fork_user):

  Not a fork (or owner != fork_user)
    origin  → the repo itself
    tracks  → origin/<trunk>

  Regular fork (owner == fork_user, GitHub says isFork, no "soft-fork" topic)
    origin  → the fork (e.g. timvisher-dd/beads)
    upstream → the parent (e.g. steveyegge/beads)
    tracks  → upstream/<trunk>

  Soft fork (owner == fork_user, has "soft-fork" GitHub topic)
    origin  → the fork (e.g. timvisher-dd/acp.el-plus)
    upstream → the parent (e.g. xenodium/acp.el)
    tracks  → origin/<trunk>    (upstream changes are merged into
              origin/<trunk> via `timvisher_git sync-trunk`, not rebased)
    cookie  → x.timvisher_git.soft-fork written to worktree root

  Upstream override (.upstream.repo file or ~/.config/.../upstream_overrides)
    origin  → the repo itself
    upstream → the override target
    tracks  → upstream/<trunk>

  PR (cross-fork)
    origin  → PR head repo
    upstream → PR base repo
    tracks  → determined by PR head repo's fork status

Other subcommands
-----------------

  timvisher_git info <field>
    Query metadata about the current worktree.
    Fields: .org, .repo, .branch, .absPath, .prefixPath

  timvisher_git sync-trunk <path>
    For soft fork repos only (detected by x.timvisher_git.soft-fork cookie).
    Finds or creates the trunk worktree, merges upstream/<trunk> into
    <trunk>, and pushes to origin.  Non-interactive; exits non-zero on
    merge conflicts and prints the trunk worktree path to stdout so the
    caller can arrange for agent-driven resolution.

  timvisher_git <git-args...>
    Passes through to git (with agent safety wrappers).
EOF
}

# ---------------------------------------------------------------------------
# info subcommand — expose worktree metadata
# ---------------------------------------------------------------------------

info__usage() {
  cat <<'EOF'
Usage: timvisher_git info <field>

Query metadata about the current worktree.

Fields:
  .org           Organisation component of the worktree path
  .repo          Repository name from the worktree path
  .branch        Current branch name (git symbolic-ref)
  .absPath       Absolute path to the worktree root
  .prefixPath    Path relative to TIMVISHER_GIT_HOME (org/repo/branch/…)
EOF
}

info__cmd() {
  local field=${1:-}

  if [[ -z $field ]]
  then
    info__usage >&2
    return 1
  fi

  local toplevel
  toplevel=$(git rev-parse --show-toplevel 2>/dev/null) ||
    die "info: not inside a git worktree"

  local prefix_path
  prefix_path=$(strip_live_prefix "$toplevel")

  # If strip_live_prefix returned the path unchanged, we're not under
  # the managed worktree root.
  if [[ $prefix_path == "$toplevel" ]]
  then
    die "info: worktree '%s' is not under TIMVISHER_GIT_HOME (%s)" \
        "$toplevel" "$live_repo_dir"
  fi

  case $field in
    .org)
      get_org "$prefix_path"
      printf '\n'
      ;;
    .repo)
      get_repo "$prefix_path"
      printf '\n'
      ;;
    .branch)
      local branch
      branch=$(git symbolic-ref --short HEAD 2>/dev/null) ||
        die "info .branch: HEAD is detached"
      printf '%s\n' "$branch"
      ;;
    .absPath)
      printf '%s\n' "$toplevel"
      ;;
    .prefixPath)
      printf '%s\n' "$prefix_path"
      ;;
    *)
      die "info: unknown field '%s'" "$field"
      ;;
  esac
}

# Strip live_repo_dir prefix from a local path, yielding an
# org/repo/branch shorthand that ensure_worktree can parse.
# Same stripping ntmux3 does for paths under ~/git/.
strip_live_prefix() {
  local path=$1
  [[ -n $path ]] || return 0

  # shellcheck disable=SC2088  # case patterns match literal '~', not expansion
  case $path in
    '~')   path="$HOME" ;;
    '~/'*) path="${HOME}/${path#'~'/}" ;;
  esac
  path="${path%/}"

  # Only strip from absolute paths
  case $path in
    /*)
      # Try direct prefix match first
      local live_prefix="${live_repo_dir}/"
      if [[ $path == "${live_prefix}"* ]]
      then
        printf '%s' "${path#"${live_prefix}"}"
        return
      fi
      # Fallback: strip up to the first /git/ path component.
      # Handles cases where HOME differs from the path's origin
      # (e.g., test harness with fake HOME).
      if [[ $path == */git/* ]]
      then
        printf '%s' "${path#*/git/}"
        return
      fi
      ;;
  esac

  printf '%s' "$path"
}

clone() {
  local target=${1:-}
  # REFACTOR: A future enhancement could allow stack_on_base to be a bare
  # branch name (repo inferred from target).
  local stack_on_base=${2:-}

  if [[ -z $target ]]
  then
    clone_usage
    return 1
  fi

  # Expand tilde (command-line args are already expanded, but clipboard
  # or variable values passed by callers may not be).
  # shellcheck disable=SC2088  # case patterns match literal '~', not expansion
  case $target in
    '~')   target="$HOME" ;;
    '~/'*) target="${HOME}/${target#'~'/}" ;;
  esac

  # Resolve relative directory paths to absolute for local filesystem checks.
  local resolved_target="$target"
  if [[ $resolved_target != /* && -d $resolved_target ]]
  then
    resolved_target=$(cd "$resolved_target" && pwd -P) || true
  fi

  # --- 2. Remote match: URL, or org/repo shorthand via aliases ---
  # strip_live_prefix converts ~/git/ paths to org/repo/branch shorthands.
  local remote_target
  remote_target=$(strip_live_prefix "$target")

  if [[ -n $stack_on_base ]]
  then
    # shellcheck disable=SC2088  # case patterns match literal '~', not expansion
    case $stack_on_base in
      '~')   stack_on_base="$HOME" ;;
      '~/'*) stack_on_base="${HOME}/${stack_on_base#'~'/}" ;;
    esac
    stack_on_base=$(strip_live_prefix "$stack_on_base")
  fi

  if [[ -n $stack_on_base ]] &&
    is_branch_ish "$remote_target" && is_branch_ish "$stack_on_base"
  then
    clone_stacked "$remote_target" "$stack_on_base"
    return
  fi

  # Route to ensure_worktree when strip_live_prefix produced a shorthand
  # that resolves as a branch-ish.  is_branch_ish is the semantic gate:
  # it succeeds only when the target can be resolved through the managed
  # cache system (cache_trunk + branch_path_for_source).  Local-only
  # repos without a GitHub remote fail is_branch_ish and fall through to
  # the local-directory checks below.
  if [[ $remote_target != /* ]] && is_branch_ish "$remote_target"
  then
    # If the original target was a non-existent path under ~/git/,
    # confirm before creating a new worktree (interactive only).
    if [[ -t 0 && ! -d $resolved_target && $resolved_target == "${live_repo_dir}/"* ]]
    then
      printf 'Create a new worktree at %q? (y/N) ' "$remote_target" >&2
      local reply
      read -r reply
      if [[ $reply != [yY] ]]
      then
        return 1
      fi
    fi
    ensure_worktree "$remote_target"
    return
  fi

  # --- 1. Local directory: bare repo or working tree ---
  # Check bare repos first because --is-inside-work-tree exits 0 (with
  # output "false") for bare repos, making a bare-unaware check incorrect.
  if [[ -d $resolved_target ]]
  then
    local is_bare
    is_bare=$(git -C "$resolved_target" rev-parse --is-bare-repository 2>/dev/null) || true

    if [[ $is_bare == true ]]
    then
      # --- 1a. Bare repo → translate to trunk checkout ---
      local bare_abs
      bare_abs=$(cd "$resolved_target" && pwd -P) || true
      local resolved_trunks
      resolved_trunks=$(cd "$repo_trunks_dir" && pwd -P 2>/dev/null) || true
      local bare_rel="${bare_abs#"${resolved_trunks}/"}"
      if [[ -n $resolved_trunks && $bare_rel != "$bare_abs" ]]
      then
        # Managed bare repo under our cache system — check out trunk.
        local bare_trunk
        bare_trunk=$(get_trunk_branch_name_from_cache "$resolved_target") ||
          die "clone: unable to determine trunk branch for bare repo '%s'" "$resolved_target"
        ensure_worktree "${bare_rel}/${bare_trunk}"
        return
      fi
      # Non-managed bare repo: best-effort tracking setup.
      ensure_existing_repo "$resolved_target"
      return
    fi

    # --- 1b. Git working tree ---
    local is_work_tree
    is_work_tree=$(git -C "$resolved_target" rev-parse --is-inside-work-tree 2>/dev/null) || true
    if [[ $is_work_tree == true ]]
    then
      ensure_existing_repo "$resolved_target"
      return
    fi
  fi

  # --- 3. Error ---
  die "clone: unable to resolve '%s' as a remote or local git repository" "$target"
}

# ---------------------------------------------------------------------------
# Stacked worktree: clone target on top of a base branch.
# ---------------------------------------------------------------------------

clone_stacked() {
  local target=$1 stack_on_base=$2

  # Validate both resolve to the same org/repo.
  local target_org target_repo base_org base_repo
  target_org=$(get_org "$target") ||
    die "clone_stacked: unable to extract org from target '%s'" "$target"
  target_repo=$(get_repo "$target") ||
    die "clone_stacked: unable to extract repo from target '%s'" "$target"
  base_org=$(get_org "$stack_on_base") ||
    die "clone_stacked: unable to extract org from stack-on-base '%s'" "$stack_on_base"
  base_repo=$(get_repo "$stack_on_base") ||
    die "clone_stacked: unable to extract repo from stack-on-base '%s'" "$stack_on_base"

  if [[ $target_org != "$base_org" || $target_repo != "$base_repo" ]]
  then
    die "clone_stacked: target '%s/%s' and stack-on-base '%s/%s' must be the same org/repo" \
      "$target_org" "$target_repo" "$base_org" "$base_repo"
  fi

  # Clone the base first — ensures its worktree and local branch exist.
  info "clone_stacked: ensuring base worktree for '%s'" "$stack_on_base"
  local base_dir
  base_dir=$(ensure_worktree "$stack_on_base") ||
    die "clone_stacked: unable to clone base '%s'" "$stack_on_base"

  # Resolve the base's local branch name.
  local base_branch
  base_branch=$(git -C "$base_dir" rev-parse --abbrev-ref HEAD 2>/dev/null) ||
    die "clone_stacked: unable to determine base branch in '%s'" "$base_dir"
  [[ $base_branch != HEAD ]] ||
    die "clone_stacked: base worktree '%s' is in detached HEAD state" "$base_dir"

  # Clone the target worktree.
  local target_was_new=
  local target_trunk_cache
  target_trunk_cache=$(cache_trunk "$target") ||
    die "clone_stacked: unable to cache trunk for target '%s'" "$target"

  local target_branch_dir_and_branch
  target_branch_dir_and_branch=$(branch_path_for_source "$target" "$target_trunk_cache")
  local target_branch_dir=${target_branch_dir_and_branch%%;*}
  local target_branch_dir_abs="${live_repo_dir}/${target_branch_dir}"

  if [[ ! -d $target_branch_dir_abs ]]
  then
    target_was_new=true
  fi

  info "clone_stacked: ensuring target worktree for '%s'" "$target"
  local target_dir
  target_dir=$(ensure_worktree "$target") ||
    die "clone_stacked: unable to clone target '%s'" "$target"

  # Stack if: target was just created, OR x.stack-pending exists (recovery).
  local stack_pending_file="${target_dir}/x.stack-pending"
  if [[ -n $target_was_new || -f $stack_pending_file ]]
  then
    info "clone_stacked: stacking '%s' onto base branch '%s'" "$target" "$base_branch"

    # Write the marker before resetting, for idempotent recovery.
    printf '%s\n' "$stack_on_base" > "$stack_pending_file" ||
      die "clone_stacked: unable to write x.stack-pending in '%s'" "$target_dir"

    git -C "$target_dir" reset --hard "$base_branch" >&2 ||
      die "clone_stacked: git reset --hard '%s' failed in '%s'" "$base_branch" "$target_dir"

    rm -f "$stack_pending_file" ||
      warn "clone_stacked: unable to remove x.stack-pending (non-fatal)"

    info "clone_stacked: target '%s' is now stacked on '%s'" "$target" "$base_branch"
  else
    info "clone_stacked: target already exists and no x.stack-pending; skipping stacking"
  fi

  printf '%s' "$target_dir"
}

is_branch_ish() {
  local source=${1:-}

  [[ -n $source ]] || return 1

  # Local path: valid branch-ish only if it's a managed worktree
  # (git-common-dir under our cache system).  Purely local repos
  # can't be recloned, so they're not branch-ishes.
  case $source in
    /* | ./* | ../* | ~*)
      local expanded="$source"
      # shellcheck disable=SC2088  # case patterns match literal '~', not expansion
      case $expanded in
        '~')   expanded="$HOME" ;;
        '~/'*) expanded="${HOME}/${expanded#'~'/}" ;;
      esac
      [[ -d $expanded ]] || return 1
      git -C "$expanded" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
      local common_dir
      common_dir=$(cd "$expanded" && \
        cd "$(git -C "$expanded" rev-parse --git-common-dir 2>/dev/null)" && \
        pwd -P 2>/dev/null) || return 1
      local resolved_trunks
      resolved_trunks=$(cd "$repo_trunks_dir" && pwd -P 2>/dev/null) || return 1
      [[ $common_dir == "${resolved_trunks}/"* ]]
      return
      ;;
  esac

  # Remote/shorthand: shape-only match.  No network probe — downstream
  # callers (ensure_worktree → cache_trunk) surface real errors for
  # missing repos, auth failures, unreachable hosts, etc.  A prior
  # design probed cache_trunk here with stderr suppressed, which
  # silently demoted genuine operational failures into "not a branch"
  # and left clone() to die with a misleading generic message.
  case $source in
    */*) return 0 ;;
    *)   return 1 ;;
  esac
}

status__all_published() {
  local real_git dirty=0
  real_git="$(brew --prefix)"/bin/git

  # @{push} must resolve
  if ! "$real_git" rev-parse --verify '@{push}' >/dev/null 2>&1
  then
    die "No push target configured for branch '%s'" \
      "$("$real_git" symbolic-ref --short HEAD 2>/dev/null || echo '(detached)')"
  fi

  # Unpushed commits
  local -a unpushed
  readarray -t unpushed < <("$real_git" log --oneline '@{push}..HEAD')
  if (( 0 < ${#unpushed[@]} ))
  then
    warn "Unpushed commits:"
    info_array '  %s' "${unpushed[@]}"
    dirty=1
  fi

  # Unstaged changes
  local -a unstaged
  readarray -td '' unstaged < <("$real_git" diff --name-only -z)
  if (( 0 < ${#unstaged[@]} ))
  then
    warn "Unstaged changes:"
    info_array '  %s' "${unstaged[@]}"
    dirty=1
  fi

  # Staged changes
  local -a staged
  readarray -td '' staged < <("$real_git" diff --name-only --cached -z)
  if (( 0 < ${#staged[@]} ))
  then
    warn "Staged changes:"
    info_array '  %s' "${staged[@]}"
    dirty=1
  fi

  # Untracked files
  local -a untracked
  readarray -td '' untracked < <("$real_git" ls-files --others --exclude-standard -z)
  if (( 0 < ${#untracked[@]} ))
  then
    warn "Untracked files:"
    info_array '  %s' "${untracked[@]}"
    dirty=1
  fi

  if (( 0 < dirty ))
  then
    return 1
  fi

  info "All changes published"
}

# ---------------------------------------------------------------------------
# worktree gc: remove merged worktrees, archiving workflow files first
# ---------------------------------------------------------------------------

worktree_gc__archive_dir="${XDG_DATA_HOME:-$HOME/.local/share}/timvisher_git/worktree/archives"
worktree_gc__protect_dir="${config_dir}/timvisher_git.config/worktree/gc"

# Collect dev_ci active worktree paths that should be protected from gc.
# Delegates to timvisher_dev_ci worktrees active.
# Populates the associative array whose name is passed as $1.
# Per-worktree keep files are checked inline in the gc loop.
# Returns 1 if dev_ci is available but fails (caller should abort gc).
worktree_gc__collect_protected() {
  local -n __protected=$1

  command -v timvisher_dev_ci &>/dev/null || return 0

  local output
  local stderr_file
  stderr_file=$(mktemp) || return 1
  if ! output=$(timvisher_dev_ci worktrees active 2>"$stderr_file"); then
    error "timvisher_dev_ci worktrees active failed — refusing to gc without protection list:\n%s" "$(cat "$stderr_file")"
    rm -f "$stderr_file"
    return 1
  fi
  rm -f "$stderr_file"

  local wt
  while IFS= read -r wt; do
    [[ -n $wt ]] || continue
    [[ -d $wt ]] || continue
    wt=$(cd "$wt" && pwd -P 2>/dev/null) || continue
    __protected["$wt"]=1
  done <<< "$output"
}

worktree_gc__should_archive() {
  local file=$1

  # Skip: caches and regenerable artifacts
  case "$file" in
    .terraform/*|*/.terraform/*) return 1 ;;
    .cfctl/*|*/.cfctl/*) return 1 ;;
    bazel-*) return 1 ;;
    x.upstream-configured) return 1 ;;
    x.active-worktrees) return 1 ;;
    x.timvisher.terraform.cookie.*) return 1 ;;
    */x.timvisher.terraform.cookie.*) return 1 ;;
    x.timvisher_EXP_terraform_export_format_init_plan*) return 1 ;;
    applied.*|*/applied.*) return 1 ;;
    current.*|*/current.*) return 1 ;;
    *.auto.tfvars*) return 1 ;;
    x.home|x.home/*) return 1 ;;
    x.config|x.config/*) return 1 ;;
    joblog|*/joblog) return 1 ;;
  esac

  # Preserve: known workflow directories
  case "$file" in
    .agent-shell/transcripts/*) return 0 ;;
    .beads/*) return 0 ;;
    .timvisher_bd_topics/*) return 0 ;;
  esac

  # Preserve: workflow files by first path component
  local top="${file%%/*}"
  case "$top" in
    pr.md|pr.md.url|todo.org) return 0 ;;
    [xyz]|[xyz].*) return 0 ;;
  esac

  return 1
}

worktree_gc__count_archivable() {
  local wt_path=$1
  local count=0

  while IFS= read -r file; do
    worktree_gc__should_archive "$file" || continue
    (( count++ )) || true
  done < <(git -C "$wt_path" ls-files --others --ignored --exclude-standard 2>/dev/null)

  printf '%d' "$count"
}

worktree_gc__do_archive() {
  local wt_path=$1
  local rel="${wt_path#"${live_repo_dir}/"}"
  local dest="${worktree_gc__archive_dir}/${rel}"

  while IFS= read -r file; do
    worktree_gc__should_archive "$file" || continue

    local file_dest="${dest}/${file}"
    mkdir -p "$(dirname "$file_dest")" || return 1
    cp -a "${wt_path}/${file}" "$file_dest" || return 1
  done < <(git -C "$wt_path" ls-files --others --ignored --exclude-standard 2>/dev/null)
}

worktree_gc() {
  local dry_run=0
  local cutoff_spec="2 weeks ago"

  while (( 0 < $# )); do
    case $1 in
      --dry-run|-n) dry_run=1; shift ;;
      --cutoff)     [[ -n ${2:-} ]] || die "worktree gc: --cutoff requires a value"
                    cutoff_spec=$2; shift 2 ;;
      --cutoff=*)   cutoff_spec=${1#--cutoff=}; shift ;;
      -*)           die "worktree gc: unknown option '%s'" "$1" ;;
      *)            die "worktree gc: unexpected argument '%s'" "$1" ;;
    esac
  done

  local cutoff
  cutoff=$(gdate -d "$cutoff_spec" +%s) ||
    die "worktree gc: invalid cutoff '%s'" "$cutoff_spec"

  info "Cutoff: %s (%s)" "$(gdate -d "@${cutoff}" '+%Y-%m-%d')" "$cutoff_spec"
  if (( dry_run )); then
    info "Dry run — no changes will be made"
  fi
  echo

  # Collect worktree paths protected by dev_ci; abort if the query fails.
  local -A gc_protected=()
  worktree_gc__collect_protected gc_protected || return 1

  if (( 0 < ${#gc_protected[@]} )); then
    info "Protected worktrees: %d (from dev_ci active worktrees)" "${#gc_protected[@]}"
    echo
  fi

  # Parallel arrays: trunk_cache|wt_path, and archive file counts
  local to_remove=()
  local archive_counts=()
  local archive_labels=()

  local trunk_cache
  for trunk_cache in "${repo_trunks_dir}"/*/*; do
    [[ -d $trunk_cache ]] || continue

    local label="${trunk_cache#"${repo_trunks_dir}/"}"

    # Sweep bogus worktrees before the normal gc pass; these are never
    # legitimate and must go regardless of age/protection.
    sweep_bogus_worktrees_in_cache "$trunk_cache"

    local trunk_branch
    trunk_branch=$(get_trunk_branch_name_from_cache "$trunk_cache" 2>/dev/null) || continue

    # Fetch to ensure merge-base checks are current
    command git -C "$trunk_cache" fetch origin "$trunk_branch" --quiet 2>/dev/null || continue

    local found_any=0

    while IFS=$'\t' read -r wt_path branch_ref; do
      local branch="${branch_ref#refs/heads/}"
      [[ $branch == "$trunk_branch" ]] && continue

      # Skip worktrees protected by dev_ci or per-worktree keep file
      local resolved_wt
      resolved_wt=$(cd "$wt_path" && pwd -P 2>/dev/null) || resolved_wt="$wt_path"
      if [[ -n ${gc_protected["$resolved_wt"]+x} ]]; then
        continue
      fi
      local wt_rel="${wt_path#"${live_repo_dir}/"}"
      if [[ -f "${worktree_gc__protect_dir}/${wt_rel}/keep" ]]; then
        continue
      fi

      local last_epoch
      last_epoch=$(git -C "$wt_path" log -1 --format='%at' 2>/dev/null) || continue
      if (( cutoff < last_epoch )); then
        continue
      fi

      if git -C "$trunk_cache" merge-base --is-ancestor "$branch_ref" "origin/${trunk_branch}" 2>/dev/null; then
        if (( ! found_any )); then
          info "--- %s ---" "$label"
          found_any=1
        fi

        local last_date
        last_date=$(git -C "$wt_path" log -1 --format='%ai' 2>/dev/null | cut -d' ' -f1)
        info "  MERGED  %s  %s" "$last_date" "$branch"

        local file_count
        file_count=$(worktree_gc__count_archivable "$wt_path")

        to_remove+=("${trunk_cache}|${wt_path}")
        archive_counts+=("$file_count")
        archive_labels+=("$wt_rel")
      fi
    done < <(git -C "$trunk_cache" worktree list --porcelain \
      | awk '/^worktree /{wt=$2} /^branch /{br=$2; print wt"\t"br}')

    if (( found_any )); then
      echo
    fi
  done

  if (( ${#to_remove[@]} < 1 )); then
    info "Nothing to remove."
    return 0
  fi

  # Build archive summary
  local total_archive_files=0
  local archive_summary=""
  local i
  for (( i = 0; i < ${#to_remove[@]}; i++ )); do
    (( total_archive_files += archive_counts[i] )) || true
    if (( 0 < archive_counts[i] )); then
      archive_summary+=$(printf '%d\t%s\n' "${archive_counts[i]}" "${archive_labels[i]}")
    fi
  done

  echo
  info "========================================"
  info "Will remove %d worktree(s)." "${#to_remove[@]}"
  echo
  if (( 0 < total_archive_files )); then
    info "Will archive %d file(s):" "$total_archive_files"
    printf '%s' "$archive_summary" | sort -t$'\t' -k2 | column -t >&2
  else
    info "Nothing to archive."
  fi
  echo
  info "Archive base: %s" "$worktree_gc__archive_dir"
  info "========================================"

  if (( dry_run )); then
    return 0
  fi

  printf 'Proceed? [y/N] ' >&2
  local confirm
  read -r confirm
  if [[ $confirm != [yY] ]]; then
    info "Aborted."
    return 1
  fi

  local entry
  for (( i = 0; i < ${#to_remove[@]}; i++ )); do
    entry="${to_remove[i]}"
    local trunk="${entry%%|*}"
    local wt="${entry#*|}"
    if (( 0 < archive_counts[i] )); then
      if ! worktree_gc__do_archive "$wt"; then
        error "Archive failed for %s — skipping removal" "${archive_labels[i]}"
        continue
      fi
      info "Archived %d file(s) from %s" "${archive_counts[i]}" "${archive_labels[i]}"
    fi
    info "Removing %s ..." "$wt"
    if git -C "$trunk" worktree remove --force "$wt"
    then
      info "  done"
    else
      warn "  FAILED"
    fi
  done

  info "Cleanup complete. Archives at: %s" "$worktree_gc__archive_dir"
}

# ---------------------------------------------------------------------------
# Main entry point dispatch
# ---------------------------------------------------------------------------

case $1 in
  clone)        clone "${@:2}" ;;
  info)         info__cmd "${@:2}" ;;
  is-branch-ish) is_branch_ish "${@:2}" ;;
  rewrite-trunk-subpath) maybe_rewrite_trunk_subpath "${@:2}" ;;
  status)
    case ${2:-} in
      --all-published) status__all_published ;;
      *)               git "$@" ;;
    esac
    ;;
  sync-trunk)   sync_trunk "${@:2}" ;;
  worktree)
    case ${2:-} in
      gc)          worktree_gc "${@:3}" ;;
      sweep-bogus) sweep_bogus_worktrees_in_all_caches ;;
      *)           git "$@" ;;
    esac
    ;;
  *)            git "$@" ;;
esac
