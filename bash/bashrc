##########################################################################
### Overrides
##########################################################################

# The above should only be overriden for a good reason. This configuration
# helps us work smoothly with each other. If you want to override
# something, consider changing it in the default and publishing it.
#
# That said if you absolutely must override something, you can do so by
# placing .bash files in the ~/.config/timvisher/ide/bash/functions/
# directory for functions and ~/.config/timvisher/ide/bash/bin/ directory for
# executables.

if [[ -d ~/.config/timvisher/ide/bash ]]
then
  shopt -s nullglob
  for f in ~/.config/timvisher/ide/bash/{,functions/}!(*.ignore).bash
  do
    if [[ $f != *bash/functions/*.bash ]]
    then
      printf '‘%s’ in deprecated ‘~/.config/timvisher/ide/bash/’ location\n' "$f" >&2
      printf 'mv -v "%s" ~/.config/timvisher/ide/bash/functions/\n' "$f" >&2
    fi
    if [[ -f $f ]]
    then
      source "$f"
    fi
  done
  shopt -u nullglob
fi

export PATH=~/bin:~/.local/bin:$PATH

if [[ -d ~/.config/timvisher/ide/bash/bin ]]
then
  export PATH=~/.config/timvisher/ide/bash/bin:$PATH
fi

