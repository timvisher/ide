#!/usr/bin/env bash

source "${HOME}/.functions/logging.bash" ||
  {
    echo "Unable to source logging functions" >&2
    exit 1
  }

display_script "$0"

cd ~/'git/ide/AppleScript/Script Libraries' ||
  die "Couldn't cd"

mkdir -p ~/Library/'Script Libraries' ||
  die "Couldn't make ‘~/Library/Script Libraries’"

for af in *.applescript
do
  of="${HOME}/Library/Script Libraries/${af%.applescript}.scpt"
  if [[ $af -nt $of ]]
  then
    info 'Compiling ‘%s’ to ‘%s’' "$af" "$of"
    osacompile -o "$of" "$af"
  else
    info 'No compilation needed for ‘%s’' "$af"
  fi

  if (( $(GetFileInfo -aE "$of" ) == 0 ))
  then
    # /ht https://superuser.com/a/399918
    info 'Setting extension to hidden for ‘%s’' "$of"
    SetFile -a E "$of"
  else
    info 'Extension already hidden for ‘%s’' "$of"
  fi
done
